  ✕ Invalid select
   ╭─[test.lis:6:9]
 5 │   select {
 6 │     let Some(v) = ch1.receive() => v,
   ·         ───┬───
   ·            ╰── first receive arm
 7 │     let Some(v) = ch2.receive() => v,
   ·         ───┬───
   ·            ╰── second receive arm
 8 │     _ => 0,
