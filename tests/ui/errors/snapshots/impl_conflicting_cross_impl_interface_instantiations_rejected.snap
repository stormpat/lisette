  [error] Conflicting interface bounds
    ╭─[test.lis:6:9]
  5 │ 
  6 │ impl<T: Parent<int>> Box<T> {
    ·         ─────┬─────
    ·              ╰── one impl instantiates it here
  7 │   fn as_int(self) -> int { self.value.p() }
  8 │ }
  9 │ 
 10 │ impl<T: Parent<string>> Box<T> {
