  ✕ Refutable pattern in select receive
   ╭─[test.lis:5:14]
 4 │   select {
 5 │     let Some(1) = ch.receive() => println("one"),
   ·              ┬
   ·              ╰── may not match all received values
 6 │     _ => println("timeout"),
