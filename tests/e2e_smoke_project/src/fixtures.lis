struct Point { x: int, y: int }

impl Point {
  fn sum(self: Point) -> int {
    self.x + self.y
  }
}

struct Rect { origin: Point, width: int, height: int }

struct Inner { value: int }

struct Middle { inner: Inner }

struct Outer { middle: Middle }

impl Inner {
  fn get(self: Inner) -> int {
    self.value
  }

  fn doubled(self: Inner) -> Inner {
    Inner { value: self.value * 2 }
  }
}

pub enum Event {
  Click { x: int, y: int },
  KeyPress { key: string, ctrl: bool },
  Resize { width: int, height: int },
  Close,
}

fn use_int(x: int) -> int {
  x
}

fn divide_for_test(a: int, b: int) -> Result<int, string> {
  if b == 0 { Err("division by zero") } else { Ok(a / b) }
}

fn maybe_int_for_test(b: bool) -> Option<int> {
  if b { Some(42) } else { None }
}
