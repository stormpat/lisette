struct Point { x: int, y: int }

impl Point {
  fn sum(self: Point) -> int {
    self.x + self.y
  }
}

struct Rect { origin: Point, width: int, height: int }

struct Inner { value: int }

struct Middle { inner: Inner }

struct Outer { middle: Middle }

impl Inner {
  fn get(self: Inner) -> int {
    self.value
  }

  fn doubled(self: Inner) -> Inner {
    Inner { value: self.value * 2 }
  }
}

pub enum Event {
  Click { x: int, y: int },
  KeyPress { key: string, ctrl: bool },
  Resize { width: int, height: int },
  Close,
}

fn use_int(x: int) -> int {
  x
}

fn divide_for_test(a: int, b: int) -> Result<int, string> {
  if b == 0 { Err("division by zero") } else { Ok(a / b) }
}

fn maybe_int_for_test(b: bool) -> Option<int> {
  if b { Some(42) } else { None }
}

fn unreachable_from_error(_e: string) -> int {
  panic("mapper or fallback should not be called")
}

enum Tree {
  Tip(int),
  Fork(Branch),
}

struct Branch {
  left: Tree,
  right: Tree,
}

fn tree_sum(t: Tree) -> int {
  match t {
    Tree.Tip(n) => n,
    Tree.Fork(b) => tree_sum(b.left) + tree_sum(b.right),
  }
}

enum Ping {
  Stop,
  Next(Pong),
}

enum Pong {
  Reply(Ping),
}

fn ping_depth(p: Ping) -> int {
  match p {
    Ping.Stop => 0,
    Ping.Next(Pong.Reply(inner)) => 2 + ping_depth(inner),
  }
}
