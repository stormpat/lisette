#[test]
fn if_true() {
  let result = if true { 100 } else { 0 }
  assert result == 100
}

#[test]
fn if_false() {
  let result = if false { 0 } else { 100 }
  assert result == 100
}

#[test]
fn if_chain() {
  let x = 2
  let result = if x == 1 { 1 } else if x == 2 { 2 } else if x == 3 { 3 } else { 0 }
  assert result == 2
}

#[test]
fn if_nested() {
  let x = 5
  let y = 10
  let result = if x > 0 { if y > 5 { 100 } else { 50 } } else { 0 }
  assert result == 100
}

#[test]
fn while_loop() {
  let mut sum = 0
  let mut i = 1
  while i <= 10 {
    sum += i
    i += 1
  }
  assert sum == 55
}

#[test]
fn for_loop() {
  let mut sum = 0
  for i in [1, 2, 3, 4, 5] {
    sum += i
  }
  assert sum == 15
}

#[test]
fn range_exclusive() {
  let mut sum = 0
  for i in 0..5 {
    sum += i
  }
  assert sum == 10
}

#[test]
fn range_inclusive() {
  let mut sum = 0
  for i in 0..=4 {
    sum += i
  }
  assert sum == 10
}

#[test]
fn range_from() {
  let mut sum = 0
  for i in 3.. {
    if i >= 6 { break }
    sum += i
  }
  assert sum == 12
}

#[test]
fn stored_range() {
  let r = 0..5
  let mut sum = 0
  for i in r {
    sum += i
  }
  assert sum == 10
}

#[test]
fn slice_range_exclusive() {
  let arr = [10, 20, 30, 40, 50]
  let sub = arr[1..4]
  let result = sub[0] + sub[1] + sub[2]
  assert result == 90
}

#[test]
fn slice_range_inclusive() {
  let arr = [10, 20, 30, 40, 50]
  let sub = arr[1..=3]
  let result = sub[0] + sub[1] + sub[2]
  assert result == 90
}

#[test]
fn slice_range_from() {
  let arr = [10, 20, 30, 40, 50]
  let sub = arr[2..]
  let result = sub[0] + sub[1] + sub[2]
  assert result == 120
}

#[test]
fn slice_range_to() {
  let arr = [10, 20, 30, 40, 50]
  let sub = arr[..3]
  let result = sub[0] + sub[1] + sub[2]
  assert result == 60
}

#[test]
fn slice_range_full() {
  let arr = [10, 20, 30]
  let sub = arr[..]
  let result = sub[0] + sub[1] + sub[2]
  assert result == 60
}

#[test]
fn subslice_append_no_alias() {
  let source = [1, 2, 3, 4, 5]
  let sub = source[1..3]
  let _ = sub.append(99)
  let result = source[3]
  assert result == 4
}

#[test]
fn mutable_subslice_element_write_no_alias() {
  let source = [1, 2, 3, 4, 5]
  let mut sub = source[1..3]
  sub[0] = 99
  let result = source[1]
  assert result == 2
}

#[test]
fn loop_break() {
  let mut i = 0
  loop {
    i += 1
    if i == 5 { break }
  }
  assert i == 5
}

#[test]
fn loop_continue() {
  let mut sum = 0
  let mut i = 0
  while i < 10 {
    i += 1
    if i % 2 == 0 { continue }
    sum += i
  }
  assert sum == 25
}

#[test]
fn nested_loop() {
  let mut count = 0
  for _ in [1, 2, 3] {
    for _ in [1, 2, 3] {
      count += 1
    }
  }
  assert count == 9
}

#[test]
fn early_return() {
  let x = -5
  if x < 0 { return }
  if x == 0 { return }
  panic("expected a guard clause to return early")
}

#[test]
fn early_return_nested() {
  let x = 1
  if x > 0 {
    match x {
      1 => {
        for i in [1, 2, 3] {
          if i == 2 { return }
        }
      },
      _ => (),
    }
  }
  panic("expected early return from the nested loop")
}

#[test]
fn return_in_match_arm() {
  let x = 3
  let result = match x {
    1 => { return },
    2 => { return },
    3 => 300,
    _ => { return },
  }
  assert result == 300
}

#[test]
fn return_in_if_arm() {
  let x = true
  let result = if x { return } else { 100 }
  assert result == 100
}

#[test]
fn break_nested_labeled() {
  let mut sum = 0
  let mut i = 0
  loop {
    i += 1
    let mut j = 0
    loop {
      j += 1
      sum += 1
      if j >= 3 { break }
    }
    if i >= 4 { break }
  }
  assert sum == 12
}

#[test]
fn continue_in_nested() {
  let mut count = 0
  for _ in [1, 2, 3] {
    for j in [1, 2, 3] {
      if j == 2 { continue }
      count += 1
    }
  }
  assert count == 6
}

#[test]
fn defer_cleanup_on_success() {
  let mut acc = 0
  defer_helper_normal(&acc)
  assert acc == 21
}

#[test]
fn defer_cleanup_on_early_return() {
  let mut acc = 0
  let _ = defer_helper_early_return(&acc)
  assert acc == 1
}

#[test]
fn defer_lifo_order() {
  let mut acc = 0
  defer_helper_lifo(&acc)
  assert acc == 321
}

fn record(acc: Ref<int>, val: int) {
  acc.* = acc.* * 10 + val
}

fn defer_helper_normal(acc: Ref<int>) {
  defer record(acc, 1)
  record(acc, 2)
}

fn defer_helper_early_return(acc: Ref<int>) -> Result<int, string> {
  defer record(acc, 1)
  Err("fail")
}

fn defer_helper_lifo(acc: Ref<int>) {
  defer record(acc, 1)
  defer record(acc, 2)
  defer record(acc, 3)
}
