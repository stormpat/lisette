import "go:fmt"

#[test]
fn channel_basic() {
  let ch = Channel.new<int>()
  let result = select {
    let Some(v) = ch.receive() => v,
    _ => 42,
  }
  assert result == 42
}

#[test]
fn channel_multiple() {
  let ch1 = Channel.new<int>()
  let ch2 = Channel.new<int>()
  let ch3 = Channel.new<int>()
  let result = select {
    match ch1.receive() {
      Some(v) => v,
      None => 100,
    },
    match ch2.receive() {
      Some(v) => v + 10,
      None => 100,
    },
    match ch3.receive() {
      Some(v) => v + 20,
      None => 100,
    },
    _ => 100,
  }
  assert result == 100
}

#[test]
fn select_basic() {
  let ch1 = Channel.new<int>()
  let ch2 = Channel.new<int>()
  let result = select {
    match ch1.receive() {
      Some(x) => x,
      None => 50,
    },
    match ch2.receive() {
      Some(y) => y,
      None => 50,
    },
    _ => 50,
  }
  assert result == 50
}

#[test]
fn select_default() {
  let ch = Channel.new<int>()
  let result = select {
    let Some(v) = ch.receive() => v + 100,
    _ => 0,
  }
  assert result == 0
}

#[test]
fn task_spawn() {
  task {
    fmt.Print("")
  }
}

#[test]
fn buffered_channel() {
  let ch = Channel.buffered<int>(2)
  ch.send(10)
  ch.send(20)
  let v1 = ch.receive().unwrap_or(0)
  let v2 = ch.receive().unwrap_or(0)
  let result = v1 + v2
  assert result == 30
}

#[test]
fn blocking_send_receive() {
  let ch = Channel.new<int>()
  task {
    ch.send(42)
  }
  let result = ch.receive().unwrap_or(0)
  assert result == 42
}

#[test]
fn channel_iteration() {
  let ch = Channel.buffered<int>(3)
  ch.send(1)
  ch.send(2)
  ch.send(3)
  ch.close()
  let mut sum = 0
  for v in ch {
    sum += v
  }
  assert sum == 6
}

#[test]
fn channel_split() {
  let ch = Channel.new<int>()
  let (tx, rx) = ch.split()
  task {
    tx.send(99)
  }
  let result = rx.receive().unwrap_or(0)
  assert result == 99
}

#[test]
fn select_match_receive_value() {
  let ch = Channel.buffered<int>(1)
  ch.send(42)
  let result = select {
    match ch.receive() {
      Some(v) => v,
      None => 0,
    },
    _ => -1,
  }
  assert result == 42
}

#[test]
fn select_match_receive_closed() {
  let ch = Channel.buffered<int>(1)
  ch.close()
  let result = select {
    match ch.receive() {
      Some(v) => v,
      None => 100,
    },
    _ => -1,
  }
  assert result == 100
}
