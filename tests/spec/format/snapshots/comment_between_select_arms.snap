source: tests/spec/format/mod.rs
description: "input: fn f(c: Channel<int>) -> int {\n  select {\n    match c.receive() {\n      Some(v) => v,\n      None => 0,\n    },\n    // between select arms\n    _ => 1,\n  }\n}"
---
fn f(c: Channel<int>) -> int {
  select {
    match c.receive() {
      Some(v) => v,
      None => 0,
    },
    // between select arms
    _ => 1,
  }
}
