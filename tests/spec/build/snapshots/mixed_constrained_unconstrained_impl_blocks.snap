// === main.go ===
package main

import "fmt"

type Printable interface {
	ToString() string
}

type Box[T any] struct {
	value T
}

func Box_print[T Printable](self Box[T]) {
	fmt.Println(self.value.ToString())
}

func (b Box[T]) get() T {
	return b.value
}

type Name struct {
	name string
}

func (n Name) ToString() string {
	return n.name
}

func main() {
	b := Box[Name]{value: Name{name: "Alice"}}
	Box_print(b)
	b2 := Box[int]{value: 42}
	fmt.Printf("int box: %d\n", b2.get())
}
