// === main.go ===
package main

import (
	"encoding/json"
	"fmt"
)

type User struct {
	FirstName  string `json:"firstName,omitempty"`
	MiddleName string `json:"middleName,omitempty"`
}

func (u User) String() string {
	return fmt.Sprintf("User { first_name: %v, middle_name: %v }", u.FirstName, u.MiddleName)
}

func main() {
	u := User{
		FirstName:  "Alice",
		MiddleName: "",
	}
	json.Marshal(u)
}
