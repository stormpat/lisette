// === main.go ===
package main

import "fmt"

type Printable interface {
	PrintVal() string
}

type Summable interface {
	SumVal() int
}

type Container[T any] struct {
	value T
	label string
}

func Container_display[T Printable](self Container[T]) string {
	_fmtarg_1 := self.label
	return fmt.Sprintf("[%s] %s", _fmtarg_1, self.value.PrintVal())
}

func Container_total[T Summable](self Container[T]) int {
	return self.value.SumVal()
}

type Item struct {
	name  string
	count int
}

func (i Item) PrintVal() string {
	return i.name
}

func (i Item) SumVal() int {
	return i.count
}

func main() {
	c := Container[Item]{
		value: Item{
			name:  "widget",
			count: 5,
		},
		label: "box",
	}
	fmt.Println(Container_display(c))
	fmt.Printf("total: %d\n", Container_total(c))
}
