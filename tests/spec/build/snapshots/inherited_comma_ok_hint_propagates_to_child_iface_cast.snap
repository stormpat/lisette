// === main.go ===
package main

import lisette "github.com/ivov/lisette/prelude"

type Entry struct {
	name string
}

type BaseCache interface {
	Get(string) (*Entry, bool)
}

type ExtendedCache interface {
	BaseCache
	Touch()
}

type MyCache struct{}

func (m MyCache) Get(_ string) *Entry {
	return nil
}

func (m MyCache) Touch() {}

func use_extended(_ ExtendedCache) {}

func main() {
	c := MyCache{}
	use_extended(_lisAdapter_MyCache_ExtendedCache_0{inner: c})
}

type _lisAdapter_MyCache_ExtendedCache_0 struct {
	inner MyCache
}

func (a _lisAdapter_MyCache_ExtendedCache_0) Touch() {
	a.inner.Touch()
}

func (a _lisAdapter_MyCache_ExtendedCache_0) Get(arg0 string) (*Entry, bool) {
	raw_1 := a.inner.Get(arg0)
	option_2 := lisette.OptionFromNilable[*Entry](raw_1, raw_1 == nil)
	if option_2.Tag == lisette.OptionSome {
		return option_2.SomeVal, true
	}
	return nil, false
}
