// === a.go ===
package main

import s "github.com/user/myproject/iface_a"

type BoxA[T s.Drawable] struct {
	V T
}

func (b BoxA[T]) Show() string {
	return b.V.Draw()
}


// === b.go ===
package main

import s "github.com/user/myproject/iface_b"

type BoxB[T s.Renderable] struct {
	V T
}

func (b BoxB[T]) Show() string {
	return b.V.Render()
}


