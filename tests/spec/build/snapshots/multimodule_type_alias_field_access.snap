// === geo/lib.go ===
package geo

type Point struct {
	X int
	Y int
}

type Coordinate = Point


// === main.go ===
package main

import "github.com/user/myproject/geo"

func get_x(c geo.Coordinate) int {
	return c.X
}

func main() {
	c := geo.Point{
		X: 10,
		Y: 20,
	}
	_ = get_x(c)
}
