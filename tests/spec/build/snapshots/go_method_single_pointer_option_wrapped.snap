// === main.go ===
package main

import (
	"container/list"
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
)

func main() {
	l := list.New()
	_ = l.PushBack(42)
	raw_1 := l.Front()
	option_2 := lisette.OptionFromNilable[*list.Element](raw_1, raw_1 == nil)
	fmt.Print(option_2.IsSome())
}
