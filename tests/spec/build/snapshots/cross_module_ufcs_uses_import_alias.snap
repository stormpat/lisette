// === lib/box.go ===
package lib

type Box[T any] struct {
	Value T
}

func Box_Map[T any, U any](self Box[T], f func(T) U) Box[U] {
	return Box[U]{Value: f(self.Value)}
}


// === main.go ===
package main

import (
	"fmt"
	L "github.com/user/myproject/lib"
)

func main() {
	b := L.Box[int]{Value: 1}
	c := L.Box_Map(b, func(x int) int {
		return x + 1
	})
	fmt.Println(c.Value)
}
