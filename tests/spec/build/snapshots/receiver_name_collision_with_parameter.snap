// === builder/mod.go ===
package builder

type StringBuilder struct {
	Content string
}

func (ss StringBuilder) Append(s string) StringBuilder {
	return StringBuilder{Content: ss.Content + s}
}


// === main.go ===
package main

import "github.com/user/myproject/builder"

func main() {
	sb := builder.StringBuilder{Content: "hello"}
	sb2 := sb.Append(" world")
	_ = sb2
}
