// === main.go ===
package main

import (
	lisette "github.com/ivov/lisette/prelude"
	"io"
)

type Reader1 struct{}

type Reader2 struct{}

func (r Reader1) Read(_ []uint8) (int, error) {
	return 0, nil
}

func (r Reader2) Read(_ []uint8) (int, error) {
	return 1, nil
}

func pick(flag bool) (io.Reader, int) {
	var result lisette.Tuple2[io.Reader, int]
	if flag {
		result = lisette.MakeTuple2[io.Reader, int](Reader1{}, 1)
	} else {
		result = lisette.MakeTuple2[io.Reader, int](Reader2{}, 2)
	}
	tup_1 := result
	return tup_1.First, tup_1.Second
}

func main() {
	pick(true)
}
