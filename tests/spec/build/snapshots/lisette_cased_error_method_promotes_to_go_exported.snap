// === main.go ===
package main

import "fmt"

type MyErr struct {
	msg string
}

func (m MyErr) String() string {
	return fmt.Sprintf("MyErr { msg: %v }", m.msg)
}

func (m MyErr) Error() string {
	return "ERR: " + m.msg
}

func main() {
	e := MyErr{msg: "boom"}
	fmt.Println(e)
}
