// === main.go ===
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
	"go/parser"
)

func main() {
	ret_1, ret_2 := parser.ParseExpr("1 + 2")
	if ret_2 == nil {
		fmt.Print("ok")
	} else if lisette.IsNilInterface(ret_1) {
		fmt.Print("err")
	} else {
		fmt.Print("both")
	}
}
