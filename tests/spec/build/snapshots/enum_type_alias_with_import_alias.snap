// === lib/lib.go ===
package lib

func MakeEventClick(arg0 int) Event {
	return Event{Tag: EventClick, X: arg0}
}

type EventTag int

const (
	EventClick EventTag = iota
)

type Event struct {
	Tag EventTag
	X   int
}


// === main.go ===
package main

import L "github.com/user/myproject/lib"

type Alias = L.Event

func main() {
	e := L.Event{
		Tag: L.EventClick,
		X:   1,
	}
	_ = e
}
