// === main.go ===
package main

import (
	"fmt"
	"github.com/user/myproject/models"
)

type Describable interface {
	Describe() string
}

func print_it(item Describable) {
	fmt.Println(item.Describe())
}

func main() {
	u := models.User{Name: "Alice"}
	print_it(u)
}


// === models/mod.go ===
package models

type User struct {
	Name string
}

func (u User) Describe() string {
	return u.Name
}
