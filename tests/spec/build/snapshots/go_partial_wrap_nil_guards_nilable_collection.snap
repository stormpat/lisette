// === main.go ===
package main

import (
	"fmt"
	"io"
	"strings"
)

func main() {
	reader := strings.NewReader("hello")
	ret_1, ret_2 := io.ReadAll(reader)
	if ret_2 == nil {
		fmt.Print("ok")
	} else if ret_1 == nil {
		fmt.Print("err")
	} else {
		fmt.Print("both")
	}
}
