// === main.go ===
package main

import "fmt"

type Widget struct {
	name string
}

func (w Widget) String() string {
	return fmt.Sprintf("Widget { name: %v }", w.name)
}

func (w Widget) MarshalJSON() string {
	return "{\"name\":\"" + w.name + "\"}"
}

func main() {
	_ = Widget{name: "x"}
}
