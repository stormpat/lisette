// === main.go ===
package main

import "github.com/user/myproject/types"

func greet_anyone(g types.Greetable) string {
	return g.Greet()
}

func main() {
	p := types.Person{Name: "Alice"}
	_ = greet_anyone(p)
}


// === types/lib.go ===
package types

import "fmt"

type Greetable interface {
	Greet() string
}

type Person struct {
	Name string
}

func (p Person) Greet() string {
	return fmt.Sprintf("Hello, I'm %s", p.Name)
}
