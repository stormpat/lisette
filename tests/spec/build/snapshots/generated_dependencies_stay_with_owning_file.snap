// === types/z_enum.go ===
package types

import f "github.com/user/myproject/foo"

func MakeMyEnumEmpty() MyEnum {
	return MyEnum{Tag: MyEnumEmpty}
}

func MakeMyEnumValue(arg0 f.Foo) MyEnum {
	return MyEnum{Tag: MyEnumValue, Value: arg0}
}

type MyEnumTag int

const (
	MyEnumEmpty MyEnumTag = iota
	MyEnumValue
)

type MyEnum struct {
	Tag   MyEnumTag
	Value f.Foo
}
