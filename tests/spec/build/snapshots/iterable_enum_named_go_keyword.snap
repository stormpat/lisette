// === main.go ===
package main

func Makemap_A() map_ {
	return map_{Tag: mapA}
}

func Makemap_B() map_ {
	return map_{Tag: mapB}
}

type mapTag int

const (
	mapA mapTag = iota
	mapB
)

type map_ struct {
	Tag mapTag
}

func map_variants() []map_ {
	return []map_{
		{Tag: mapA},
		{Tag: mapB},
	}
}

func main() {
	_ = map_variants()
}
