// === main.go ===
package main

import (
	"fmt"
	f "fmt"
)

type Thing struct {
	X int
}

func (t Thing) String() string {
	return fmt.Sprintf("Thing { x: %v }", t.X)
}

func (t Thing) to_string() string {
	return t.String()
}

func main() {
	_ = Thing{X: 1}
	_ = f.Sprintf("x=%d", 1)
}
