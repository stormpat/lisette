// === main.go ===
package main

import lisette "github.com/ivov/lisette/prelude"

type LoadError struct {
	msg string
}

type Loader struct{}

func (l Loader) Load(_ string) lisette.Result[int, LoadError] {
	return lisette.MakeResultOk[int, LoadError](0)
}

func run(l Loader) int {
	subject_1 := l.Load("k")
	if subject_1.Tag == lisette.ResultOk {
		return subject_1.OkVal
	}
	return -1
}

func main() {
	l := Loader{}
	_ = run(l)
}
