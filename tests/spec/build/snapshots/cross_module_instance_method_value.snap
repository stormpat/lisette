// === lib/lib.go ===
package lib

import "fmt"

type Point struct {
	X int
	Y int
}

func (p Point) String() string {
	return fmt.Sprintf("Point { x: %v, y: %v }", p.X, p.Y)
}

func (p Point) Sum() int {
	return p.X + p.Y
}


// === main.go ===
package main

import "github.com/user/myproject/lib"

func main() {
	p := lib.Point{
		X: 1,
		Y: 2,
	}
	_ = lib.Point.Sum(p)
}
