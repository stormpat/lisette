package main

import lisette "github.com/ivov/lisette/prelude"

func test() {
	ch := make(chan int)
	tmp_1 := lisette.ChannelSplit(ch)
	tx := tmp_1.First
	_ = lisette.SenderSend(tx, 42)
}
