package main

import (
	"example.com/dyn"
	lisette "github.com/ivov/lisette/prelude"
)

func main() {
	_ = dyn.Bag{
		Decl: lisette.MakeOptionSome("decl"),
		Data: lisette.MakeOptionNone[any](),
	}
}
