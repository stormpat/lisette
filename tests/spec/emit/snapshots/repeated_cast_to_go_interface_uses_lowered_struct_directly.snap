package main

import "io"

type Doubler struct{}

func (d Doubler) Read(_ []uint8) (int, error) {
	return 0, nil
}

func consume_a(r io.Reader) {
	_ = r
}

func consume_b(r io.Reader) {
	_ = r
}

func main() {
	d := Doubler{}
	consume_a(d)
	consume_b(d)
}
