---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Pair(int, int)
  
  fn bump(i: Ref<int>) -> int {
    i.* = 1
    10
  }
  
  fn main() {
    let mut i = 0
    let p = Pair(i, bump(&i))
    let _ = p
  }
---
package main

type Pair struct {
	F0 int
	F1 int
}

func bump(i *int) int {
	*i = 1
	return 10
}

func main() {
	i := 0
	p := Pair{
		F0: i,
		F1: bump(&i),
	}
	_ = p
}
