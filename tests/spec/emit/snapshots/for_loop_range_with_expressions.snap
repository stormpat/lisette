---
source: tests/spec/emit/control_flow.rs
description: |
  
  fn test(start: int, end: int) -> int {
    let mut sum = 0;
    for i in start..end {
      sum = sum + i;
    };
    sum
  }
---
package main

func test(start, end int) int {
	sum := 0
	_bound_1 := end
	for i := start; i < _bound_1; i++ {
		sum += i
	}
	return sum
}
