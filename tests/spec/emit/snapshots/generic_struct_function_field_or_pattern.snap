---
source: tests/spec/emit/patterns.rs
description: "input: \nstruct Handler<T> { callback: fn(T) -> int }\nenum E { A(Handler<string>), B(Handler<string>) }\n\nfn test(e: E) -> int {\n  let A(Handler { callback }) | B(Handler { callback }) = e else { return 0; };\n  callback(\"test\")\n}\n"
---
package main

func MakeEA(arg0 Handler[string]) E {
	return E{Tag: EA, A: arg0}
}

func MakeEB(arg0 Handler[string]) E {
	return E{Tag: EB, B: arg0}
}

type Handler[T any] struct {
	callback func(T) int
}

type ETag int

const (
	EA ETag = iota
	EB
)

type E struct {
	Tag ETag
	A   Handler[string]
	B   Handler[string]
}

func test(e E) int {
	var callback func(string) int
	if e.Tag == EA {
		callback = e.A.callback
	} else if e.Tag == EB {
		callback = e.B.callback
	} else {
		return 0
	}
	return callback("test")
}
