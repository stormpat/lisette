---
source: tests/spec/emit/interop_matrix.rs
description: |
  
  import "go:path"
  
  fn use_split(f: fn(string) -> (string, string), p: string) -> string {
    let (dir, file) = f(p)
    f"{dir}/{file}"
  }
  
  fn main() {
    let r = use_split(path.Split, "/foo/bar.txt")
    let _ = r
  }
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
	"path"
)

func use_split(f func(string) (string, string), p string) string {
	ret_2, ret_3 := f(p)
	tup_4 := lisette.MakeTuple2(ret_2, ret_3)
	tmp_1 := tup_4
	dir := tmp_1.First
	file := tmp_1.Second
	return fmt.Sprintf("%s/%s", dir, file)
}

func main() {
	r := use_split(path.Split, "/foo/bar.txt")
	_ = r
}
