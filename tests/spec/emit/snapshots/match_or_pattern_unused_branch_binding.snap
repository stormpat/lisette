---
source: tests/spec/emit/control_flow.rs
description: "input: \nenum E { A(int), B(int), C }\nfn test() {\n  let x = 5\n  let e = E.C\n  match e {\n    E.A(x) | E.B(x) => panic(\"unexpected\"),\n    _ => {\n      if x != 5 { panic(\"shadow\") }\n    },\n  }\n}\n"
---
package main

func MakeEA(arg0 int) E {
	return E{Tag: EA, A: arg0}
}

func MakeEB(arg0 int) E {
	return E{Tag: EB, B: arg0}
}

func MakeEC() E {
	return E{Tag: EC}
}

type ETag int

const (
	EA ETag = iota
	EB
	EC
)

type E struct {
	Tag ETag
	A   int
	B   int
}

func test() {
	x := 5
	e := MakeEC()
	switch e.Tag {
	case EA:
		panic("unexpected")
	case EB:
		panic("unexpected")
	default:
		if x != 5 {
			panic("shadow")
		}
	}
}
