---
source: tests/spec/emit/expressions.rs
description: "input: \nstruct Box { x: int }\n\nfn main() {\n  let mut m = Map.from([(\"k\", Box { x: 0 })])\n  let r = &m\n  let mut entry = r.*[\"k\"]\n  entry.x = 1\n  r.*[\"k\"] = entry\n}\n"
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
)

type Box struct {
	x int
}

func (b Box) String() string {
	return fmt.Sprintf("Box { x: %v }", b.x)
}

func main() {
	m := lisette.MapFrom([]lisette.Tuple2[string, Box]{lisette.MakeTuple2("k", Box{x: 0})})
	r := &m
	entry := (*r)["k"]
	entry.x = 1
	(*r)["k"] = entry
}
