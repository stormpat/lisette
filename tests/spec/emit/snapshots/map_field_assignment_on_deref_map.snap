---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Box { x: int }
  
  fn main() {
    let mut m = Map.from([("k", Box { x: 0 })])
    let r = &m
    let mut entry = r.*["k"]
    entry.x = 1
    r.*["k"] = entry
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

type Box struct {
	x int
}

func main() {
	m := lisette.MapFrom([]lisette.Tuple2[string, Box]{lisette.MakeTuple2("k", Box{x: 0})})
	r := &m
	entry := (*r)["k"]
	entry.x = 1
	base_1 := r
	(*base_1)["k"] = entry
}
