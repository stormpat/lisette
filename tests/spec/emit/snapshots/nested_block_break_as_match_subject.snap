---
source: tests/spec/emit/control_flow.rs
description: |
  
  fn test() {
    let _ = loop {
      let _ = match { { break 1 } } {
        1 => 1,
        _ => 2,
      }
      3
    }
  }
---
package main

func test() {
	var tmp_1 int
	for {
		var tmp_2 int
		{
			{
				tmp_1 = 1
				break
			}
		}
		_ = tmp_2
	}
	_ = tmp_1
}
