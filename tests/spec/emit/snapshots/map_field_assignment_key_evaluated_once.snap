source: tests/spec/emit/expressions.rs
description: "input: \nimport \"go:fmt\"\n\nstruct C { value: int }\n\nfn make_key() -> string {\n  fmt.Println(\"key\")\n  \"a\"\n}\n\nfn main() {\n  let mut m: Map<string, C> = Map.new()\n  m[\"a\"] = C { value: 1 }\n  let key = make_key()\n  let mut entry = m[key]\n  entry.value = 2\n  m[key] = entry\n}\n"
---
package main

import "fmt"

type C struct {
	value int
}

func make_key() string {
	fmt.Println("key")
	return "a"
}

func main() {
	m := make(map[string]C)
	m["a"] = C{value: 1}
	key := make_key()
	entry := m[key]
	entry.value = 2
	m[key] = entry
}
