---
source: tests/spec/emit/types.rs
description: "input: \ninterface Displayable {\n  fn display(self) -> string\n}\n\nenum Either<L, R> {\n  Left(L),\n  Right(R),\n}\n\nimpl<L: Displayable, R: Displayable> Either<L, R> {\n  fn display(self) -> string {\n    match self {\n      Either.Left(l) => {\n        let s = l.display()\n        f\"Left({s})\"\n      },\n      Either.Right(r) => {\n        let s = r.display()\n        f\"Right({s})\"\n      },\n    }\n  }\n}\n\nstruct Name { value: string }\nimpl Name { fn display(self) -> string { self.value } }\n\nfn test() -> Either<Name, Name> {\n  Either.Left(Name { value: \"hello\" })\n}\n"
---
package main

import "fmt"

func MakeEitherLeft[L Displayable, R Displayable](arg0 L) Either[L, R] {
	return Either[L, R]{Tag: EitherLeft, Left: arg0}
}

func MakeEitherRight[L Displayable, R Displayable](arg0 R) Either[L, R] {
	return Either[L, R]{Tag: EitherRight, Right: arg0}
}

type Displayable interface {
	display() string
}

type EitherTag int

const (
	EitherLeft EitherTag = iota
	EitherRight
)

type Either[L Displayable, R Displayable] struct {
	Tag   EitherTag
	Left  L
	Right R
}

func (e Either[L, R]) String() string {
	switch e.Tag {
	case EitherLeft:
		return fmt.Sprintf("Left(%v)", e.Left)
	case EitherRight:
		return fmt.Sprintf("Right(%v)", e.Right)
	default:
		return fmt.Sprintf("Either(%d)", e.Tag)
	}
}

func (e Either[L, R]) GoString() string {
	switch e.Tag {
	case EitherLeft:
		return fmt.Sprintf("Either.Left(%v)", e.Left)
	case EitherRight:
		return fmt.Sprintf("Either.Right(%v)", e.Right)
	default:
		return fmt.Sprintf("Either(%d)", e.Tag)
	}
}

func (e Either[L, R]) display() string {
	if e.Tag == EitherLeft {
		s := e.Left.display()
		return fmt.Sprintf("Left(%s)", s)
	}
	s := e.Right.display()
	return fmt.Sprintf("Right(%s)", s)
}

type Name struct {
	value string
}

func (n Name) String() string {
	return fmt.Sprintf("Name { value: %v }", n.value)
}

func (n Name) display() string {
	return n.value
}

func test() Either[Name, Name] {
	return MakeEitherLeft[Name, Name](Name{value: "hello"})
}
