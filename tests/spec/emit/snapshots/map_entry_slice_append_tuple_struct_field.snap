---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Wrap(Slice<int>, int)
  
  fn main() {
    let mut m = Map.new<string, Wrap>()
    m["a"] = Wrap([], 0)
    let mut entry = Wrap(m["a"].0.clone(), m["a"].1)
    entry.0 = entry.0.append(2)
    m["a"] = entry
  }
---
package main

import "slices"

type Wrap struct {
	F0 []int
	F1 int
}

func main() {
	m := make(map[string]Wrap)
	m["a"] = Wrap{
		F0: []int{},
		F1: 0,
	}
	entry := Wrap{
		F0: slices.Clone(m["a"].F0),
		F1: m["a"].F1,
	}
	entry.F0 = append(entry.F0, 2)
	m["a"] = entry
}
