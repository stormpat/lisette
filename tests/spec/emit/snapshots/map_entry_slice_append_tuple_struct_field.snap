---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Wrap(Slice<int>, int)
  
  fn main() {
    let mut m = Map.new<string, Wrap>()
    m["a"] = Wrap([], 0)
    let mut entry = m["a"]
    entry.0 = entry.0.append(2)
    m["a"] = entry
  }
---
package main

type Wrap struct {
	F0 []int
	F1 int
}

func main() {
	m := make(map[string]Wrap)
	m["a"] = Wrap{
		F0: ([]int)(nil),
		F1: 0,
	}
	entry := m["a"]
	entry.F0 = append(entry.F0, 2)
	m["a"] = entry
}
