package main

import "io"

type Doubler struct{}

func (d Doubler) Read(_ []uint8) (int, error) {
	return 0, nil
}

func main() {
	m := make(map[string]io.Reader)
	d := Doubler{}
	m["src"] = d
	_ = m
}
