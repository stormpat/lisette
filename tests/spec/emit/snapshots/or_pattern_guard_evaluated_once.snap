---
source: tests/spec/emit/control_flow.rs
description: "input: \nenum Res { Ok(int), Err(int) }\n\nfn test(r: Res, threshold: int) -> int {\n  match r {\n    Ok(x) | Err(x) if x > threshold => 100,\n    _ => 0,\n  }\n}\n"
---
package main

func MakeResOk(arg0 int) Res {
	return Res{Tag: ResOk, Ok: arg0}
}

func MakeResErr(arg0 int) Res {
	return Res{Tag: ResErr, Err: arg0}
}

type ResTag int

const (
	ResOk ResTag = iota
	ResErr
)

type Res struct {
	Tag ResTag
	Ok  int
	Err int
}

func test(r Res, threshold int) int {
	subject_1 := r
	if subject_1.Tag == ResOk {
		x := subject_1.Ok
		if x > threshold {
			return 100
		}
	}
	if subject_1.Tag == ResErr {
		if subject_1.Err > threshold {
			return 100
		}
	}
	{
		return 0
	}
}
