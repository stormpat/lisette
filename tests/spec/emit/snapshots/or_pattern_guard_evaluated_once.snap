---
source: tests/spec/emit/control_flow.rs
description: |
  
  enum Res { Ok(int), Err(int) }
  
  fn test(r: Res, threshold: int) -> int {
    match r {
      Ok(x) | Err(x) if x > threshold => 100,
      _ => 0,
    }
  }
---
package main

func MakeResOk(arg0 int) Res {
	return Res{Tag: ResOk, Ok: arg0}
}

func MakeResErr(arg0 int) Res {
	return Res{Tag: ResErr, Err: arg0}
}

type ResTag int

const (
	ResOk ResTag = iota
	ResErr
)

type Res struct {
	Tag ResTag
	Ok  int
	Err int
}

func test(r Res, threshold int) int {
	subject_1 := r
	if subject_1.Tag == ResOk {
		x := subject_1.Ok
		if x > threshold {
			return 100
		}
	}
	if subject_1.Tag == ResErr {
		if subject_1.Err > threshold {
			return 100
		}
	}
	{
		return 0
	}
}
