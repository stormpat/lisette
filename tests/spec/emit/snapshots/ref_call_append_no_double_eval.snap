package main

import "fmt"

func get() *[]int {
	fmt.Println("get")
	s := []int{1}
	return &s
}

func arg() int {
	fmt.Println("arg")
	return 2
}

func main() {
	recv_1 := *get()
	_ = append(recv_1, arg())
}
