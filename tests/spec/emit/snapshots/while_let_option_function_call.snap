---
source: tests/spec/emit/result_option_patterns.rs
description: |
  
  import "go:fmt"
  
  fn next_item(counter: int) -> Option<int> {
    if counter < 5 { Some(counter) } else { None }
  }
  
  fn test() {
    let mut i = 0;
    while let Some(x) = next_item(i) {
      fmt.Print(f"Got: {x}\n");
      i = i + 1;
    }
  }
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
)

func next_item(counter int) (int, bool) {
	if counter < 5 {
		return counter, true
	}
	return *new(int), false
}

func test() {
	i := 0
	for {
		option_2 := lisette.OptionFromCommaOk[int](next_item(i))
		subject_1 := option_2
		if subject_1.Tag == lisette.OptionSome {
			x := subject_1.SomeVal
			fmt.Printf("Got: %d\n", x)
			i++
		} else {
			break
		}
	}
}
