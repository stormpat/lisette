---
source: tests/spec/emit/types.rs
description: |
  
  pub struct Base { pub id: int }
  
  struct Outer {
    embed Base,
    extra: int,
  }
  
  fn make() -> Outer {
    Outer { Base: Base { id: 1 }, extra: 2 }
  }
---
package main

type Base struct {
	Id int
}

type Outer struct {
	Base
	extra int
}

func make_() Outer {
	return Outer{
		Base:  Base{Id: 1},
		extra: 2,
	}
}
