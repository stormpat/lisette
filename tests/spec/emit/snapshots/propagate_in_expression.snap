---
source: tests/spec/emit/expressions.rs
description: "input: \nfn get_value() -> Result<int, string> {\n    Ok(100)\n}\n\nfn test() -> Result<int, string> {\n    Ok(get_value()?\n + 10)\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func get_value() lisette.Result[int, string] {
	return lisette.MakeResultOk[int, string](100)
}

func test() lisette.Result[int, string] {
	check_1 := get_value()
	if check_1.Tag != lisette.ResultOk {
		return lisette.MakeResultErr[int, string](check_1.ErrVal)
	}
	return lisette.MakeResultOk[int, string](check_1.OkVal + 10)
}
