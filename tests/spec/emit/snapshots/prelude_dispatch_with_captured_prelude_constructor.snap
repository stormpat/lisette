---
source: tests/spec/emit/prelude.rs
description: |
  
  fn main() {
    let g = Some
    let opt: Option<int> = Some(1)
    let r = opt.and_then(g)
    let _ = r
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func main() {
	cb_1 := lisette.MakeOptionSome[int]
	g := func(arg0 int) (int, bool) {
		opt_2 := cb_1(arg0)
		if opt_2.Tag == lisette.OptionSome {
			return opt_2.SomeVal, true
		}
		return *new(int), false
	}
	opt := lisette.MakeOptionSome(1)
	_arg_6 := opt
	cb_3 := g
	tagged_5 := func(arg0 int) lisette.Option[int] {
		option_4 := lisette.OptionFromCommaOk[int](cb_3(arg0))
		return option_4
	}
	r := lisette.OptionAndThen(_arg_6, tagged_5)
	_ = r
}
