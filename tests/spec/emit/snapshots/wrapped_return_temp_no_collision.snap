---
source: tests/spec/emit/result_option_patterns.rs
description: |
  
  fn foo() -> Option<int> {
    let tmp_1 = 7;
    let _ = tmp_1;
    return if true { Some(1) } else { None };
  }
  
  fn main() {
    let _ = foo();
  }
---
package main

func foo() (int, bool) {
	tmp_1 := 7
	_ = tmp_1
	if true {
		return 1, true
	}
	return *new(int), false
}

func main() {
	foo()
}
