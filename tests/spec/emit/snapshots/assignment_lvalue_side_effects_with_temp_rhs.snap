---
source: tests/spec/emit/expressions.rs
description: |
  
  fn make_a() -> int { 0 }
  fn make_b() -> int { 1 }
  
  fn main() {
    let mut s = [0, 0, 0]
    s[make_a()] = if true { make_b() } else { 0 }
  }
---
package main

func make_a() int {
	return 0
}

func make_b() int {
	return 1
}

func main() {
	s := []int{0, 0, 0}
	base_2 := s
	idx_3 := make_a()
	var tmp_1 int
	if true {
		tmp_1 = make_b()
	} else {
		tmp_1 = 0
	}
	base_2[idx_3] = tmp_1
}
