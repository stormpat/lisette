description: |
  
  fn test() -> (Sender<int>, Receiver<int>) {
    let ch = Channel.new<int>();
    ch.split()
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func test() (chan<- int, <-chan int) {
	ch := make(chan int)
	tup_1 := lisette.ChannelSplit(ch)
	return tup_1.First, tup_1.Second
}
