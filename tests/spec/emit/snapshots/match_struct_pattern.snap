---
source: tests/spec/emit/control_flow.rs
description: |
  
  struct Point { x: int, y: int }
  
  fn test(p: Point) -> int {
    match p {
      Point { x: 0, y: 0 } => 0,
      Point { x, y } => x + y,
    }
  }
---
package main

type Point struct {
	x int
	y int
}

func test(p Point) int {
	if p.x == 0 && p.y == 0 {
		return 0
	}
	return p.x + p.y
}
