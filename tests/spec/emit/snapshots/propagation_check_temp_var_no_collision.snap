---
source: tests/spec/emit/result_option_patterns.rs
description: |
  
  import "go:fmt"
  
  fn foo() -> Result<int, string> {
    let x = Ok(1)?
    let check_1 = 7
    fmt.Println(check_1)
    Ok(x)
  }
  
  fn main() {
    let _ = foo()
  }
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
)

func foo() lisette.Result[int, string] {
	check_1 := lisette.MakeResultOk[int, string](1)
	if check_1.Tag != lisette.ResultOk {
		return lisette.MakeResultErr[int, string](check_1.ErrVal)
	}
	x := check_1.OkVal
	check_1_2 := 7
	fmt.Println(check_1_2)
	return lisette.MakeResultOk[int, string](x)
}

func main() {
	_ = foo()
}
