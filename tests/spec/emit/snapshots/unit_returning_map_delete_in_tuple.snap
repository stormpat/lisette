---
package main

import lisette "github.com/ivov/lisette/prelude"

func main() {
	m := make(map[string]int)
	m["a"] = 1
	delete(m, "a")
	t := lisette.MakeTuple2(struct{}{}, 1)
	_ = t.Second
}
