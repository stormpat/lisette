---
source: tests/spec/emit/types.rs
description: |
  
  struct Point { x: int, y: int }
  
  impl Point {
    fn sum(self) -> int {
      self.x + self.y
    }
  }
  
  fn main() {
    let p = Point { x: 10, y: 20 };
    let s = p.sum();
