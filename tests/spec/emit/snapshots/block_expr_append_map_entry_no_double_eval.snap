---
source: tests/spec/emit/expressions.rs
description: "input: \nstruct Outer { items: Slice<int> }\n\nfn key() -> string { \"a\" }\n\nfn main() {\n  let mut m = Map.new<string, Outer>()\n  m[\"a\"] = Outer{ items: [1] }\n  let k = key()\n  let mut entry = m[k]\n  entry.items = entry.items.append(2)\n  m[k] = entry\n}\n"
---
package main

type Outer struct {
	items []int
}

func key() string {
	return "a"
}

func main() {
	m := make(map[string]Outer)
	m["a"] = Outer{items: []int{1}}
	k := key()
	entry := m[k]
	entry.items = append(entry.items, 2)
	m[k] = entry
}
