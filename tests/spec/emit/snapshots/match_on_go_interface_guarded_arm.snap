---
source: tests/spec/emit/patterns.rs
description: "input: \nimport \"go:example.com/events\"\n\nfn handle(e: events.Event, active: bool) -> int {\n  match e {\n    events.Click { x, y } => x + y,\n    events.KeyPress { .. } if active => -1,\n    _ => 0,\n  }\n}\n"
---
package main

import "example.com/events"

func handle(e events.Event, active bool) int {
	switch e := e.(type) {
	case events.Click:
		x := e.X
		y := e.Y
		return x + y
	case events.KeyPress:
		if active {
			return -1
		}
		return 0
	default:
		return 0
	}
}
