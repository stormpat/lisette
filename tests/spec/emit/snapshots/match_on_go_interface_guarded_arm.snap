---
source: tests/spec/emit/patterns.rs
description: |
  
  import "go:example.com/events"
  
  fn handle(e: events.Event, active: bool) -> int {
    match e {
      events.Click { x, y } => x + y,
      events.KeyPress { .. } if active => -1,
      _ => 0,
    }
  }
---
package main

import "example.com/events"

func handle(e events.Event, active bool) int {
	subject_1 := e
	switch subject_1 := subject_1.(type) {
	case events.Click:
		return subject_1.X + subject_1.Y
	case events.KeyPress:
		if active {
			return -1
		}
		return 0
	default:
		return 0
	}
}
