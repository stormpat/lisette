---
source: tests/spec/emit/control_flow.rs
description: "input: \nenum E {\n  A(int),\n  B(int),\n  C,\n}\nfn test() {\n  let x = 5\n  let e = E.C\n  let E.A(x) | E.B(x) = e else {\n    if x != 5 { panic(\"shadow\") }\n    return\n  }\n  let _ = x\n}\n"
---
package main

func MakeEA(arg0 int) E {
	return E{Tag: EA, A: arg0}
}

func MakeEB(arg0 int) E {
	return E{Tag: EB, B: arg0}
}

func MakeEC() E {
	return E{Tag: EC}
}

type ETag int

const (
	EA ETag = iota
	EB
	EC
)

type E struct {
	Tag ETag
	A   int
	B   int
}

func test() {
	x := 5
	e := MakeEC()
	var x_1 int
	if e.Tag == EA {
		x_1 = e.A
	} else if e.Tag == EB {
		x_1 = e.B
	} else {
		if x != 5 {
			panic("shadow")
		}
		return
	}
	_ = x_1
}
