---
source: tests/spec/emit/expressions.rs
description: |
  
  fn get() -> Slice<int> { [1] }
  fn arg() -> int { 2 }
  
  fn main() {
    let x = { get().append(arg()) }
    let _ = x[1]
  }
---
package main

func get() []int {
	return []int{1}
}

func arg() int {
	return 2
}

func main() {
	var x []int
	recv_1 := get()
	x = append(recv_1[:len(recv_1):len(recv_1)], arg())
	_ = x[1]
}
