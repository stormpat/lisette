---
source: tests/spec/emit/patterns.rs
description: |
  
  import "go:fmt"
  
  fn main() {
    let rest = [99]
    fmt.Println(rest[0])
    let [x, ..rest] | [x, ..rest] = [1, 2] else {
      return
    }
    fmt.Println(x, rest[0])
  }
---
package main

import "fmt"

func main() {
	rest := []int{99}
	fmt.Println(rest[0])
	subject_1 := []int{1, 2}
	var x int
	var rest_2 []int
	if len(subject_1) >= 1 {
		x = subject_1[0]
		rest_2 = subject_1[1:]
	} else if len(subject_1) >= 1 {
		x = subject_1[0]
		rest_2 = subject_1[1:]
	} else {
		return
	}
	fmt.Println(x, rest_2[0])
}
