---
source: tests/spec/emit/types.rs
description: "input: \nenum E {\n  Tag { x: int },\n  Other { x: int },\n}\n\nfn main() {\n  let e = E.Tag { x: 1 }\n  let _ = e\n}\n"
---
package main

import "fmt"

func MakeETag(arg0 int) E {
	return E{Tag: ETag_, X: arg0}
}

func MakeEOther(arg0 int) E {
	return E{Tag: EOther, X: arg0}
}

type ETag int

const (
	ETag_ ETag = iota
	EOther
)

type E struct {
	Tag ETag
	X   int
}

func (e E) String() string {
	switch e.Tag {
	case ETag_:
		return fmt.Sprintf("Tag { x: %v }", e.X)
	case EOther:
		return fmt.Sprintf("Other { x: %v }", e.X)
	default:
		return fmt.Sprintf("E(%d)", e.Tag)
	}
}

func (e E) GoString() string {
	switch e.Tag {
	case ETag_:
		return fmt.Sprintf("E.Tag { x: %v }", e.X)
	case EOther:
		return fmt.Sprintf("E.Other { x: %v }", e.X)
	default:
		return fmt.Sprintf("E(%d)", e.Tag)
	}
}

func main() {
	e := E{
		Tag: ETag_,
		X:   1,
	}
	_ = e
}
