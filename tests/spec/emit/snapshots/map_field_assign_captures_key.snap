---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Pair { x: int }
  
  fn set_key(k: Ref<string>) -> int {
    k.* = "b"
    1
  }
  
  fn main() {
    let mut m = Map.new<string, Pair>()
    m["a"] = Pair { x: 0 }
    let mut k = "a"
    let captured_key = k
    let mut entry = m[captured_key]
    entry.x = set_key(&k)
    m[captured_key] = entry
    let _ = m
  }
---
package main

type Pair struct {
	x int
}

func set_key(k *string) int {
	*k = "b"
	return 1
}

func main() {
	m := make(map[string]Pair)
	m["a"] = Pair{x: 0}
	k := "a"
	captured_key := k
	entry := m[captured_key]
	entry.x = set_key(&k)
	m[captured_key] = entry
	_ = m
}
