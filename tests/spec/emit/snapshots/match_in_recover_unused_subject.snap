---
source: tests/spec/emit/control_flow.rs
description: |
  
  struct P { v: int }
  fn test() {
    let out = recover {
      let p = P { v: 1 }
      match p { P { v } => () }
    }
    let _ = out
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

type P struct {
	v int
}

func test() {
	recoverResult_1 := lisette.RecoverBlock(func() struct{} {
		p := P{v: 1}
		_ = p
		return struct{}{}
	})
	out := recoverResult_1
	_ = out
}
