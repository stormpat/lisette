description: "input: \nimport \"go:errors\"\n\nfn fail() -> Result<int, error> {\n  Err(errors.New(\"boom\"))?\n  Ok(1)\n}\n\nfn main() {\n  let _ = fail()\n}\n"
---
package main

import "errors"

func fail() (int, error) {
	return *new(int), errors.New("boom")
}

func main() {
	fail()
}
