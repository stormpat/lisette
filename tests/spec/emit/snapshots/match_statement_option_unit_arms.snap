---
source: tests/spec/emit/result_option_patterns.rs
description: |
  
  fn noop() {}
  
  fn maybe(b: bool) -> Option<int> {
    if b { Some(42) } else { None }
  }
  
  fn test() {
    match maybe(true) {
      Some(_) => noop(),
      None => noop(),
    }
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func noop() {}

func maybe(b bool) (int, bool) {
	if b {
		return 42, true
	}
	return *new(int), false
}

func test() {
	option_2 := lisette.OptionFromCommaOk[int](maybe(true))
	subject_1 := option_2
	if subject_1.Tag == lisette.OptionSome {
		noop()
	} else {
		noop()
	}
}
