source: tests/spec/emit/interop_matrix.rs
description: |
  
  import "go:os"
  
  fn make_lookup() -> fn(string) -> Option<string> {
    os.LookupEnv
  }
  
  fn main() {
    let f = make_lookup()
    let r = f("HOME")
    match r {
      Some(v) => { let _ = v },
      None => { let _ = "" },
    }
  }
---
package main

import (
	lisette "github.com/ivov/lisette/prelude"
	"os"
)

func make_lookup() func(string) (string, bool) {
	return os.LookupEnv
}

func main() {
	f := make_lookup()
	option_1 := lisette.OptionFromCommaOk[string](f("HOME"))
	r := option_1
	if r.Tag == lisette.OptionSome {
		_ = r.SomeVal
	} else {
	}
}
