source: tests/spec/emit/expressions.rs
description: "input: \nstruct Box { x: int }\n\nimpl Box {\n  pub fn add(self, y: int) -> int { self.x + y }\n}\n\nfn main() {\n  let f = Box.add\n  let _ = f(Box { x: 1 }, 2)\n}\n"
---
package main

type Box struct {
	x int
}

func (b Box) Add(y int) int {
	return b.x + y
}

func main() {
	f := Box.Add
	_ = f(Box{x: 1}, 2)
}
