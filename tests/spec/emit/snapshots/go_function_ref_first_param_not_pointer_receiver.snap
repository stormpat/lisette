---
source: tests/spec/emit/functions.rs
description: |
  
  import "go:flag"
  
  fn main() {
    let f = flag.UnquoteUsage
    let fl = flag.Lookup("verbose")
    match fl {
      Some(v) => { let _ = f(v) },
      None => {},
    }
  }
---
package main

import (
	"flag"
	lisette "github.com/ivov/lisette/prelude"
)

func main() {
	f := flag.UnquoteUsage
	raw_1 := flag.Lookup("verbose")
	fl := lisette.OptionFromNilable[*flag.Flag](raw_1, raw_1 == nil)
	if fl.Tag == lisette.OptionSome {
		f(fl.SomeVal)
	}
}
