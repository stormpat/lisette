---
source: tests/spec/emit/patterns.rs
description: "input: \nimport \"go:example.com/events\"\n\nfn handle(e: events.Event) -> int {\n  match e {\n    events.Click { x: 5 } | events.Scroll { delta: 10 } => 1,\n    _ => 0,\n  }\n}\n"
---
package main

import "example.com/events"

func handle(e events.Event) int {
	switch e := e.(type) {
	case events.Click:
		if e.X == 5 {
			return 1
		}
		return 0
	case events.Scroll:
		if e.Delta == 10 {
			return 1
		}
		return 0
	default:
		return 0
	}
}
