---
source: tests/spec/emit/types.rs
description: "input: \nenum Tree {\n  Leaf(int),\n  Node(Tree, Tree),\n}\n\nfn test() -> Tree {\n  Tree.Node(Tree.Leaf(1), Tree.Leaf(2))\n}\n"
---
package main

func MakeTreeLeaf(arg0 int) Tree {
	return Tree{Tag: TreeLeaf, Leaf: arg0}
}

func MakeTreeNode(arg0 *Tree, arg1 *Tree) Tree {
	return Tree{Tag: TreeNode, Node0: arg0, Node1: arg1}
}

type TreeTag int

const (
	TreeLeaf TreeTag = iota
	TreeNode
)

type Tree struct {
	Tag   TreeTag
	Leaf  int
	Node0 *Tree
	Node1 *Tree
}

func test() Tree {
	ptr_1 := MakeTreeLeaf(1)
	ptr_2 := MakeTreeLeaf(2)
	return MakeTreeNode(&ptr_1, &ptr_2)
}
