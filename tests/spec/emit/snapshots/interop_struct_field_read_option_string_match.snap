---
package main

import (
	"example.com/aws"
	lisette "github.com/ivov/lisette/prelude"
)

func main() {
	bucket := aws.Bucket{}
	raw_2 := bucket.Name
	option_3 := lisette.OptionFromPointer[string](raw_2)
	if option_3.Tag == lisette.OptionSome {
		_ = option_3.SomeVal
	}
}
