---
source: tests/spec/emit/expressions.rs
description: |
  
  fn make_i() -> int { 0 }
  
  fn main() {
    let mut outer = [[1], [2], [3]]
    outer[make_i()] = outer[make_i()].append(4)
  }
---
package main

func make_i() int {
	return 0
}

func main() {
	outer := [][]int{[]int{1}, []int{2}, []int{3}}
	base_2 := outer
	idx_3 := make_i()
	recv_1 := outer[make_i()]
	base_2[idx_3] = append(recv_1[:len(recv_1):len(recv_1)], 4)
}
