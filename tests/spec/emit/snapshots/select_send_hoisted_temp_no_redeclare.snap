source: tests/spec/emit/concurrency.rs
description: "input: \nfn get(ch: Channel<int>) -> Channel<int> {\n  ch\n}\n\nfn main() {\n  let ch = Channel.buffered<int>(1)\n\n  select {\n    (&get(ch)).send(1) => { let _ = 0 },\n    _ => { let _ = 1 },\n  }\n\n  let ref_1 = 2\n  let _ = ref_1\n}\n"
---
package main

func get(ch chan int) chan int {
	return ch
}

func main() {
	ch := make(chan int, 1)
	ref_1 := get(ch)
	select {
	case ref_1 <- 1:
	default:
	}
	_ = 2
}
