---
source: tests/spec/emit/types.rs
description: |
  
  struct Thing {
    name: string,
  }
  
  impl Thing {
    fn maybe_create(name: string) -> Option<Thing> {
      if name.length() > 0 { Some(Thing { name: name }) }
      else { None }
    }
  }
  
  fn test() -> Option<Thing> {
    Thing.maybe_create("hello")
  }
---
package main

type Thing struct {
	name string
}

func Thing_maybe_create(name string) (Thing, bool) {
	if len(name) > 0 {
		return Thing{name: name}, true
	}
	return *new(Thing), false
}

func test() (Thing, bool) {
	return Thing_maybe_create("hello")
}
