package main

func test() {
	var tmp_1 int
loop_2:
	for {
		x := 0
		var tmp_3 int
		if 1 == 1 {
			tmp_1 = 1
			break loop_2
		}
		tmp_3 = 1
		x = tmp_3
		_ = x
	}
	_ = tmp_1
}
