---
package main

type Numbers = []int

type MoreNumbers = Numbers

func first(nums MoreNumbers) int {
	return nums[0]
}

func sum(nums MoreNumbers) int {
	total := 0
	for _, n := range nums {
		total += n
	}
	return total
}
