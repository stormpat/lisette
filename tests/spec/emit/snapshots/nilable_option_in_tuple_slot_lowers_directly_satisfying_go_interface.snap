package main

import "example.com/tea"

type Model struct{}

func (m Model) Update(_ tea.Msg) (tea.Model, tea.Cmd) {
	return m, tea.Quit
}

func (m Model) View() string {
	return ""
}

func main() {
	_ = tea.NewProgram(Model{})
}
