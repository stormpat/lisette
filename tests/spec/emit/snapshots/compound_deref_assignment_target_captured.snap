---
source: tests/spec/emit/expressions.rs
description: |
  
  struct H { ptr: Ref<int> }
  
  impl H {
    fn repoint(self: Ref<H>, q: Ref<int>) -> int {
      self.ptr = q
      9
    }
  }
  
  fn main() {
    let mut a = 1
    let mut b = 2
    let mut h = H { ptr: &a }
    h.ptr.* += h.repoint(&b)
    let _ = a
    let _ = b
  }
---
package main

type H struct {
	ptr *int
}

func (h *H) repoint(q *int) int {
	h.ptr = q
	return 9
}

func main() {
	a := 1
	b := 2
	h := H{ptr: &a}
	ref_1 := h.ptr
	_left_2 := *ref_1
	*ref_1 = _left_2 + h.repoint(&b)
	_ = a
	_ = b
}
