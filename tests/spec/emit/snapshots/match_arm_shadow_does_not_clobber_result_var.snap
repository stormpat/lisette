---
source: tests/spec/emit/control_flow.rs
description: "input: \nfn test(x: int) -> string {\n  let result = match x {\n    n if n < 10 => {\n      let result = n * n\n      f\"small({result})\"\n    },\n    _ => \"other\",\n  }\n  result\n}\n"
---
package main

import "fmt"

func test(x int) string {
	subject_1 := x
	for {
		{
			n := subject_1
			if n < 10 {
				result_3 := n * n
				return fmt.Sprintf("small(%v)", result_3)
			}
		}
		return "other"
	}
}
