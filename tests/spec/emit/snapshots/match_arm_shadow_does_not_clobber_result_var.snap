---
source: tests/spec/emit/control_flow.rs
description: |
  
  fn test(x: int) -> string {
    let result = match x {
      n if n < 10 => {
        let result = n * n
        f"small({result})"
      },
      _ => "other",
    }
    result
  }
---
package main

import "fmt"

func test(x int) string {
	var result string
	subject_1 := x
match_2:
	for {
		{
			n := subject_1
			if n < 10 {
				result_3 := n * n
				result = fmt.Sprintf("small(%d)", result_3)
				break match_2
			}
		}
		{
			result = "other"
			break match_2
		}
	}
	return result
}
