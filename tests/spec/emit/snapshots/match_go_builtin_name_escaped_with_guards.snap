---
source: tests/spec/emit/patterns.rs
description: |
  
  fn categorize(items: Slice<int>) -> string {
    let len = items.length();
    match len {
      0 => "empty",
      n if n == 1 => "single",
      n if n <= 3 => "few",
      _ => "many",
    }
  }
---
package main

func categorize(items []int) string {
	len_ := len(items)
	subject_1 := len_
	if subject_1 == 0 {
		return "empty"
	}
	n := subject_1
	if n == 1 {
		return "single"
	}
	if subject_1 <= 3 {
		return "few"
	}
	return "many"
}
