---
source: tests/spec/emit/patterns.rs
description: "input: \nfn categorize(items: Slice<int>) -> string {\n  let len = items.length();\n  match len {\n    0 => \"empty\",\n    n if n == 1 => \"single\",\n    n if n <= 3 => \"few\",\n    _ => \"many\",\n  }\n}\n"
---
package main

func categorize(items []int) string {
	len_ := len(items)
	subject_1 := len_
	if subject_1 == 0 {
		return "empty"
	}
	if subject_1 == 1 {
		return "single"
	}
	if subject_1 <= 3 {
		return "few"
	}
	return "many"
}
