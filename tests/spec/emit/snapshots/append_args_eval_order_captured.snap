---
source: tests/spec/emit/expressions.rs
description: |
  
  fn bump(i: Ref<int>) -> int {
    i.* = 1
    10
  }
  
  fn main() {
    let mut i = 0
    let mut items: Slice<int> = []
    items = items.append(i, bump(&i))
    let _ = items
  }
---
package main

func bump(i *int) int {
	*i = 1
	return 10
}

func main() {
	i := 0
	items := []int{}
	_arg_1 := i
	items = append(items, _arg_1, bump(&i))
	_ = items
}
