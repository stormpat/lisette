---
source: tests/spec/emit/expressions.rs
description: "input: \nfn bump(i: Ref<int>) -> int {\n  i.* = 1\n  10\n}\n\nfn main() {\n  let mut i = 0\n  let mut items: Slice<int> = []\n  items.append(i, bump(&i))\n  let _ = items\n}\n"
---
package main

func bump(i *int) int {
	*i = 1
	return 10
}

func main() {
	i := 0
	items := ([]int)(nil)
	_ = append(items, i, bump(&i))
	_ = items
}
