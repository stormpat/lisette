package main

import lisette "github.com/ivov/lisette/prelude"

func noop() {}

func test() {
	ch := make(chan struct{}, 1)
	_arg_1 := ch
	noop()
	_ = lisette.ChannelSend(_arg_1, struct{}{})
}
