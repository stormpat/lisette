---
source: tests/spec/emit/control_flow.rs
description: "input: \nenum E { A(int), B(int) }\n\nfn test(e: E) -> int {\n  match e {\n    A(x) | B(x) => x,\n  }\n}\n"
---
package main

func MakeEA(arg0 int) E {
	return E{Tag: EA, A: arg0}
}

func MakeEB(arg0 int) E {
	return E{Tag: EB, B: arg0}
}

type ETag int

const (
	EA ETag = iota
	EB
)

type E struct {
	Tag ETag
	A   int
	B   int
}

func test(e E) int {
	if e.Tag == EA {
		return e.A
	}
	return e.B
}
