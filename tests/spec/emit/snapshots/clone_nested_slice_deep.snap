---
source: tests/spec/emit/types.rs
description: |
  
  fn main() {
    let a = [[1, 2], [3, 4]]
    let mut b = a.clone()
    b[0][0] = 9
    let _ = a
    let _ = b
  }
---
package main

import (
	lisette "github.com/ivov/lisette/prelude"
	"slices"
)

func main() {
	a := [][]int{[]int{1, 2}, []int{3, 4}}
	b := lisette.SliceCloneFunc(a, func(e_1 []int) []int { return slices.Clone(e_1) })
	b[0][0] = 9
	_ = a
	_ = b
}
