---
source: tests/spec/emit/patterns.rs
description: "input: \nenum Shape {\n  Rectangle { x: int, y: int, width: int, height: int },\n}\n\nfn area(s: Shape) -> int {\n  match s {\n    Rectangle { width, height, .. } => width * height,\n  }\n}\n"
---
package main

func MakeShapeRectangle(arg0 int, arg1 int, arg2 int, arg3 int) Shape {
	return Shape{Tag: ShapeRectangle, X: arg0, Y: arg1, Width: arg2, Height: arg3}
}

type ShapeTag int

const (
	ShapeRectangle ShapeTag = iota
)

type Shape struct {
	Tag    ShapeTag
	X      int
	Y      int
	Width  int
	Height int
}

func area(s Shape) int {
	return s.Width * s.Height
}
