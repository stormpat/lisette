---
source: tests/spec/emit/control_flow.rs
description: |
  
  fn maybe_get() -> Option<int> {
    Some(42)
  }
  
  fn test() -> int {
    let opt: Option<int> = try {
      let x = maybe_get()?;
      x + 1
    };
    match opt {
      Some(v) => v,
      None => 0,
    }
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func maybe_get() (int, bool) {
	return 42, true
}

func test() int {
	var opt lisette.Option[int]
	tryResult_1 := func() lisette.Option[int] {
		option_2 := lisette.OptionFromCommaOk[int](maybe_get())
		check_3 := option_2
		if check_3.Tag != lisette.OptionSome {
			return lisette.MakeOptionNone[int]()
		}
		x := check_3.SomeVal
		return lisette.MakeOptionSome[int](x + 1)
	}()
	opt = tryResult_1
	if opt.Tag == lisette.OptionSome {
		return opt.SomeVal
	}
	return 0
}
