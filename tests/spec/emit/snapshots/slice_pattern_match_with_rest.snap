description: "input: \nfn test() -> int {\n  let arr = [1, 2, 3, 4, 5];\n  match arr {\n    [first, ..rest] => first + rest[0],\n    [] => 0,\n  }\n}\n"
---
package main

func test() int {
	arr := []int{1, 2, 3, 4, 5}
	if len(arr) >= 1 {
		return arr[0] + arr[1:][0]
	}
	return 0
}
