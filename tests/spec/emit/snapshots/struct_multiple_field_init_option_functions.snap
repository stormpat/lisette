---
source: tests/spec/emit/result_option_patterns.rs
description: |
  
  struct MultiWrapper {
    first: Option<int>,
    second: Option<string>,
  }
  
  fn get_int(x: int) -> Option<int> {
    if x > 0 { Some(x) } else { None }
  }
  
  fn get_string(s: string) -> Option<string> {
    if s != "" { Some(s) } else { None }
  }
  
  fn test() {
    let w = MultiWrapper {
      first: get_int(5),
      second: get_string("hello")
    };
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

type MultiWrapper struct {
	first  lisette.Option[int]
	second lisette.Option[string]
}

func get_int(x int) (int, bool) {
	if x > 0 {
		return x, true
	}
	return *new(int), false
}

func get_string(s string) (string, bool) {
	if s != "" {
		return s, true
	}
	return *new(string), false
}

func test() {
	option_1 := lisette.OptionFromCommaOk[int](get_int(5))
	option_2 := lisette.OptionFromCommaOk[string](get_string("hello"))
	_ = MultiWrapper{
		first:  option_1,
		second: option_2,
	}
}
