---
source: tests/spec/emit/expressions.rs
description: |
  
  fn get() -> Ref<Slice<int>> {
    let mut s = [1]
    &s
  }
  fn arg() -> int { 2 }
  
  fn main() {
    let x = { get().*.append(arg()) }
    let _ = x[1]
  }
---
package main

func get() *[]int {
	s := []int{1}
	return &s
}

func arg() int {
	return 2
}

func main() {
	var x []int
	ref_1 := get()
	recv_2 := *ref_1
	x = append(recv_2[:len(recv_2):len(recv_2)], arg())
	_ = x[1]
}
