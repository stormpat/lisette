source: tests/spec/emit/expressions.rs
description: "input: \nstruct Box<T> { value: T }\n\nimpl<T> Box<T> {\n  fn make<U>(self) -> U { panic(\"boom\") }\n}\n\nfn main() {\n  let b = Box { value: 1 };\n  let x: string = b.make();\n  let _ = x;\n}\n"
---
package main

type Box[T any] struct {
	value T
}

func Box_make[T any, U any](_ Box[T]) U {
	panic("boom")
}

func main() {
	b := Box[int]{value: 1}
	x := Box_make[int, string](b)
	_ = x
}
