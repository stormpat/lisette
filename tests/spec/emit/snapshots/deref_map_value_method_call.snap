---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Counter { count: int }
  
  impl Counter {
    fn increment(self: Ref<Counter>) {
      self.*.count += 1
    }
  }
  
  fn test(m: Map<string, Ref<Counter>>) {
    let Some(c) = m.get("a") else { return; };
    c.*.increment()
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

type Counter struct {
	count int
}

func (c *Counter) increment() {
	c.count++
}

func test(m map[string]*Counter) {
	subject_1 := lisette.MapGet(m, "a")
	if subject_1.Tag != lisette.OptionSome {
		return
	}
	c := subject_1.SomeVal
	c.increment()
}
