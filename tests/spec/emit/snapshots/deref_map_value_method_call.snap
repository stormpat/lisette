---
source: tests/spec/emit/expressions.rs
description: "input: \nstruct Counter { count: int }\n\nimpl Counter {\n  fn increment(self: Ref<Counter>) {\n    self.*.count += 1\n  }\n}\n\nfn test(m: Map<string, Ref<Counter>>) {\n  m[\"a\"].*.increment()\n}\n"
---
package main

type Counter struct {
	count int
}

func (c *Counter) increment() {
	c.count++
}

func test(m map[string]*Counter) {
	m["a"].increment()
}
