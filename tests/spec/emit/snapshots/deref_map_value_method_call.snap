---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Counter { count: int }
  
  impl Counter {
    fn increment(self: Ref<Counter>) {
      self.*.count += 1
    }
  }
  
  fn test(m: Map<string, Ref<Counter>>) {
    m["a"].*.increment()
  }
---
package main

type Counter struct {
	count int
}

func (c *Counter) increment() {
	c.count++
}

func test(m map[string]*Counter) {
	m["a"].increment()
}
