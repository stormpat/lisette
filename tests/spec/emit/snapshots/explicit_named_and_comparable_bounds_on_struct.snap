---
source: tests/spec/emit/types.rs
description: |
  
  interface Named {
    fn name(self) -> string
  }
  
  struct Person {
    value: string,
  }
  
  impl Person {
    fn name(self) -> string {
      self.value
    }
  }
  
  struct Box<T: Named + Comparable> {
    table: Map<T, int>,
  }
  
  fn main() {
    let p = Person { value: "Ada" }
    let _ = p.name()
    let b: Box<Person> = Box { table: Map.new() }
    let _ = b
  }
---
package main

type Named interface {
	name() string
}

type Person struct {
	value string
}

func (p Person) name() string {
	return p.value
}

type Box[T interface {
	Named
	comparable
}] struct {
	table map[T]int
}

func main() {
	p := Person{value: "Ada"}
	_ = p.name()
	b := Box[Person]{table: make(map[Person]int)}
	_ = b
}
