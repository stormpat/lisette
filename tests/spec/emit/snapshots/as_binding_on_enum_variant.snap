---
source: tests/spec/emit/patterns.rs
description: "input: \nenum Status { Good(int), Bad(string) }\n\nfn test(s: Status) -> int {\n  match s {\n    Good(n) as g => n,\n    Bad(_) => -1,\n  }\n}\n"
---
package main

func MakeStatusGood(arg0 int) Status {
	return Status{Tag: StatusGood, Good: arg0}
}

func MakeStatusBad(arg0 string) Status {
	return Status{Tag: StatusBad, Bad: arg0}
}

type StatusTag int

const (
	StatusGood StatusTag = iota
	StatusBad
)

type Status struct {
	Tag  StatusTag
	Good int
	Bad  string
}

func test(s Status) int {
	if s.Tag == StatusGood {
		return s.Good
	}
	return -1
}
