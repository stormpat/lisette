---
source: tests/spec/emit/types.rs
description: "input: \nenum Tag { A, B, C }\n\nfn test() -> bool {\n  let u1 = Tag.A\n  let u2 = Tag.B\n  u1 == u2\n}\n"
---
package main

import "fmt"

func MakeTagA() Tag {
	return Tag{Tag: TagA}
}

func MakeTagB() Tag {
	return Tag{Tag: TagB}
}

func MakeTagC() Tag {
	return Tag{Tag: TagC}
}

type TagTag int

const (
	TagA TagTag = iota
	TagB
	TagC
)

type Tag struct {
	Tag TagTag
}

func (t Tag) String() string {
	switch t.Tag {
	case TagA:
		return "A"
	case TagB:
		return "B"
	case TagC:
		return "C"
	default:
		return fmt.Sprintf("Tag(%d)", t.Tag)
	}
}

func (t Tag) GoString() string {
	switch t.Tag {
	case TagA:
		return "Tag.A"
	case TagB:
		return "Tag.B"
	case TagC:
		return "Tag.C"
	default:
		return fmt.Sprintf("Tag(%d)", t.Tag)
	}
}

func test() bool {
	u1 := MakeTagA()
	u2 := MakeTagB()
	return u1 == u2
}
