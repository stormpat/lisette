---
source: tests/spec/emit/types.rs
description: "input: \nenum Tag { A, B, C }\n\nfn test() -> bool {\n  let u1 = Tag.A\n  let u2 = Tag.B\n  u1 == u2\n}\n"
---
package main

func MakeTagA() Tag {
	return Tag{Tag: TagA}
}

func MakeTagB() Tag {
	return Tag{Tag: TagB}
}

func MakeTagC() Tag {
	return Tag{Tag: TagC}
}

type TagTag int

const (
	TagA TagTag = iota
	TagB
	TagC
)

type Tag struct {
	Tag TagTag
}

func test() bool {
	u1 := MakeTagA()
	u2 := MakeTagB()
	return u1 == u2
}
