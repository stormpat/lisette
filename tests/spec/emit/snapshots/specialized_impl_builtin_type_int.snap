---
source: tests/spec/emit/types.rs
description: |
  
  struct Box<T> {
    item: T,
  }
  
  impl Box<int> {
    fn unwrap(self) -> int {
      self.item
    }
  }
  
  fn test() -> int {
    let b = Box { item: 42 };
    b.unwrap()
  }
---
package main

type Box[T any] struct {
	item T
}

func Box_unwrap(self Box[int]) int {
	return self.item
}

func test() int {
	b := Box[int]{item: 42}
	return Box_unwrap(b)
}
