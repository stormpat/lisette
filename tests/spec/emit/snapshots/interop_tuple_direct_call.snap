---
source: tests/spec/emit/interop_matrix.rs
description: |
  
  import "go:path"
  
  fn main() {
    let r = path.Split("/foo/bar.txt")
    let _ = r
  }
---
package main

import (
	lisette "github.com/ivov/lisette/prelude"
	"path"
)

func main() {
	ret_1, ret_2 := path.Split("/foo/bar.txt")
	tup_3 := lisette.MakeTuple2(ret_1, ret_2)
	r := tup_3
	_ = r
}
