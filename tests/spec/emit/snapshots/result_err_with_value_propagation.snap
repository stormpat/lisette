---
source: tests/spec/emit/result_option_patterns.rs
description: "input: \nfn fallible() -> Result<int, string> {\n  Err(\"something went wrong\")\n}\n\nfn process() -> Result<int, string> {\n  let x = fallible()?;\n  Ok(x)\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func fallible() lisette.Result[int, string] {
	return lisette.MakeResultErr[int, string]("something went wrong")
}

func process() lisette.Result[int, string] {
	check_1 := fallible()
	if check_1.Tag != lisette.ResultOk {
		return lisette.MakeResultErr[int, string](check_1.ErrVal)
	}
	return lisette.MakeResultOk[int, string](check_1.OkVal)
}
