---
source: tests/spec/emit/control_flow.rs
description: |
  
  struct Point { x: int, y: int }
  
  fn test(p: Point) -> string {
    match p {
      Point { x, y } if x == y => "diagonal",
      Point { x, y } if x > y => "above",
      Point { x, y } => "below",
    }
  }
---
package main

type Point struct {
	x int
	y int
}

func test(p Point) string {
	subject_1 := p
	{
		x := subject_1.x
		y := subject_1.y
		if x == y {
			return "diagonal"
		}
	}
	{
		if subject_1.x > subject_1.y {
			return "above"
		}
	}
	{
		return "below"
	}
}
