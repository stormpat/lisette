---
source: tests/spec/emit/control_flow.rs
description: "input: \nstruct Point { x: int, y: int }\n\nfn test(p: Point) -> string {\n  match p {\n    Point { x, y } if x == y => \"diagonal\",\n    Point { x, y } if x > y => \"above\",\n    Point { x, y } => \"below\",\n  }\n}\n"
---
package main

import "fmt"

type Point struct {
	x int
	y int
}

func (p Point) String() string {
	return fmt.Sprintf("Point { x: %v, y: %v }", p.x, p.y)
}

func test(p Point) string {
	subject_1 := p
	{
		x := subject_1.x
		y := subject_1.y
		if x == y {
			return "diagonal"
		}
	}
	{
		if subject_1.x > subject_1.y {
			return "above"
		}
	}
	{
		return "below"
	}
}
