---
source: tests/spec/emit/expressions.rs
description: |
  
  fn bump(i: Ref<int>) -> string {
    i.* = 1
    ","
  }
  
  fn main() {
    let mut i = 0
    let items = ["a", "b", "c"]
    let joined = items.join(bump(&i))
    let _ = joined
  }
---
package main

import "strings"

func bump(i *int) string {
	*i = 1
	return ","
}

func main() {
	i := 0
	items := []string{"a", "b", "c"}
	joined := strings.Join(items, bump(&i))
	_ = joined
}
