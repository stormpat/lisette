---
source: tests/spec/emit/types.rs
description: "input: \nenum Tree {\n  Leaf(int),\n  Node(Ref<Tree>, Ref<Tree>),\n}\n\nfn leaf(n: int) -> Ref<Tree> {\n  let t = Tree.Leaf(n);\n  &t\n}\n\nfn node(l: Ref<Tree>, r: Ref<Tree>) -> Ref<Tree> {\n  let t = Tree.Node(l, r);\n  &t\n}\n"
---
package main

func MakeTreeLeaf(arg0 int) Tree {
	return Tree{Tag: TreeLeaf, Leaf: arg0}
}

func MakeTreeNode(arg0 *Tree, arg1 *Tree) Tree {
	return Tree{Tag: TreeNode, Node0: arg0, Node1: arg1}
}

type TreeTag int

const (
	TreeLeaf TreeTag = iota
	TreeNode
)

type Tree struct {
	Tag   TreeTag
	Leaf  int
	Node0 *Tree
	Node1 *Tree
}

func leaf(n int) *Tree {
	t := MakeTreeLeaf(n)
	return &t
}

func node(l, r *Tree) *Tree {
	t := MakeTreeNode(l, r)
	return &t
}
