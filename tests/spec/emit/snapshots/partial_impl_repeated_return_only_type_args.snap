---
source: tests/spec/emit/types.rs
description: |
  
  struct Pair<A, B> { a: A, b: B }
  
  impl<T> Pair<T, T> {
    fn make<U>(self) -> U { panic("boom") }
  }
  
  fn test() {
    let p = Pair { a: 1, b: 2 };
    let x: string = p.make();
    let _ = x;
  }
---
package main

type Pair[A any, B any] struct {
	a A
	b B
}

func Pair_make[T any, U any](_ Pair[T, T]) U {
	panic("boom")
}

func test() {
	p := Pair[int, int]{
		a: 1,
		b: 2,
	}
	x := Pair_make[int, string](p)
	_ = x
}
