---
source: tests/spec/emit/expressions.rs
description: |
  
  import "go:fmt"
  
  fn idx() -> int { let _ = fmt.Println("idx"); 0 }
  fn cond() -> bool { let _ = fmt.Println("cond"); true }
  
  fn main() {
    let mut s = [1]
    let _ = { s[idx()] = if cond() { 2 } else { 3 } }
    let _ = fmt.Println(s[0])
  }
---
package main

import "fmt"

func idx() int {
	fmt.Println("idx")
	return 0
}

func cond() bool {
	fmt.Println("cond")
	return true
}

func main() {
	s := []int{1}
	base_2 := s
	idx_3 := idx()
	var tmp_1 int
	if cond() {
		tmp_1 = 2
	} else {
		tmp_1 = 3
	}
	base_2[idx_3] = tmp_1
	fmt.Println(s[0])
}
