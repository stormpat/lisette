---
source: tests/spec/emit/control_flow.rs
description: "input: \nenum Dir { North, South }\n\nfn check(d: Dir, urgent: bool) -> string {\n  match d {\n    Dir.North if urgent => \"NORTH!\",\n    Dir.North => \"north\",\n    Dir.South => \"south\",\n  }\n}\n"
---
package main

func MakeDirNorth() Dir {
	return Dir{Tag: DirNorth}
}

func MakeDirSouth() Dir {
	return Dir{Tag: DirSouth}
}

type DirTag int

const (
	DirNorth DirTag = iota
	DirSouth
)

type Dir struct {
	Tag DirTag
}

func check(d Dir, urgent bool) string {
	subject_1 := d
	if subject_1.Tag == DirNorth {
		if urgent {
			return "NORTH!"
		}
		return "north"
	}
	return "south"
}
