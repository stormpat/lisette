---
source: tests/spec/emit/control_flow.rs
description: |
  
  fn test() {
    let mut i = 0;
    while i < 100 {
      let v = match i >= 5 {
        true => break,
        false => i,
      };
      let _ = v;
      i += 1;
    }
  }
---
package main

func test() {
	i := 0
	for i < 100 {
		var v int
		subject_1 := i >= 5
		if subject_1 {
			break
		}
		v = i
		_ = v
		i++
	}
}
