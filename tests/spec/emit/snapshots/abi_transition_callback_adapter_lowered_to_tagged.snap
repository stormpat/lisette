---
source: tests/spec/emit/functions.rs
description: |
  
  fn double(x: int) -> Option<int> { Some(x + x) }
  
  fn run() -> Option<int> {
    Option.and_then(Some(2), double)
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func double(x int) (int, bool) {
	return x + x, true
}

func run() (int, bool) {
	_arg_4 := lisette.MakeOptionSome(2)
	cb_1 := double
	tagged_3 := func(arg0 int) lisette.Option[int] {
		option_2 := lisette.OptionFromCommaOk[int](cb_1(arg0))
		return option_2
	}
	v_5 := lisette.OptionAndThen(_arg_4, tagged_3)
	if v_5.Tag == lisette.OptionSome {
		return v_5.SomeVal, true
	}
	return *new(int), false
}
