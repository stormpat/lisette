---
source: tests/spec/emit/control_flow.rs
description: |
  
  fn bump_false(r: Ref<int>) -> bool {
    r.* = 1
    false
  }
  
  fn test() -> int {
    let mut x = 0
    match x {
      0 if bump_false(&x) => -1,
      1 => 1,
      _ => 0,
    }
  }
---
package main

func bump_false(r *int) bool {
	*r = 1
	return false
}

func test() int {
	x := 0
	subject_1 := x
	if subject_1 == 0 {
		if bump_false(&x) {
			return -1
		}
	}
	if subject_1 == 1 {
		return 1
	}
	{
		return 0
	}
}
