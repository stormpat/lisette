---
source: tests/spec/emit/control_flow.rs
description: |
  
  fn get_range() -> Range<int> { 0..5 }
  
  fn test() -> int {
    let mut sum = 0;
    for i in get_range() {
      sum = sum + i;
    };
    sum
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func get_range() lisette.Range[int] {
	return lisette.Range[int]{
		Start: 0,
		End:   5,
	}
}

func test() int {
	sum := 0
	_range_1 := get_range()
	for i := _range_1.Start; i < _range_1.End; i++ {
		sum += i
	}
	return sum
}
