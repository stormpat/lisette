---
source: tests/spec/emit/expressions.rs
description: |
  
  fn lo() -> int { 0 }
  
  fn run() -> int {
    let mut rs = [0..0, 0..0]
    let mut i = 0
    let bump = || -> int { i = 1; 5 }
    rs[i] = lo()..bump()
    rs[0].end
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func lo() int {
	return 0
}

func run() int {
	rs := []lisette.Range[int]{
		lisette.Range[int]{
			Start: 0,
			End:   0,
		},
		lisette.Range[int]{
			Start: 0,
			End:   0,
		},
	}
	i := 0
	bump := func() int {
		i = 1
		return 5
	}
	idx_1 := i
	rs[idx_1] = lisette.Range[int]{
		Start: lo(),
		End:   bump(),
	}
	return rs[0].End
}
