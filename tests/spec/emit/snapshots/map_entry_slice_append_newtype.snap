source: tests/spec/emit/expressions.rs
description: |
  
  struct Wrap(Slice<int>)
  
  fn main() {
    let mut m = Map.new<string, Wrap>()
    m["a"] = Wrap([])
    m["a"] = Wrap(m["a"].0.append(1))
