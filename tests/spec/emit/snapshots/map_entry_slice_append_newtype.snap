---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Wrap(Slice<int>)
  
  fn main() {
    let mut m = Map.new<string, Wrap>()
    m["a"] = Wrap([])
    m["a"] = Wrap(m["a"].0.append(1))
  }
---
package main

type Wrap []int

func main() {
	m := make(map[string]Wrap)
	m["a"] = Wrap([]int{})
	base_2 := m
	recv_1 := []int(m["a"])
	base_2["a"] = Wrap(append(recv_1[:len(recv_1):len(recv_1)], 1))
}
