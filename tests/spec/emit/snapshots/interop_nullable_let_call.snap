---
source: tests/spec/emit/interop_matrix.rs
description: |
  
  import "go:flag"
  
  fn main() {
    let f = flag.Lookup
    let r = f("verbose")
    match r {
      Some(v) => { let _ = v },
      None => {},
    }
  }
---
package main

import (
	"flag"
	lisette "github.com/ivov/lisette/prelude"
)

func main() {
	f := flag.Lookup
	raw_1 := f("verbose")
	option_2 := lisette.OptionFromNilable[*flag.Flag](raw_1, raw_1 == nil)
	r := option_2
	if r.Tag == lisette.OptionSome {
		_ = r.SomeVal
	}
}
