---
source: tests/spec/emit/expressions.rs
description: |
  
  fn main() {
    let (a, (b, c)) = (1, (2, 3));
    let tmp_1 = 7;
    let _ = a;
    let _ = b;
    let _ = c;
    let _ = tmp_1;
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func main() {
	tmp_1 := lisette.MakeTuple2(1, lisette.MakeTuple2(2, 3))
	a := tmp_1.First
	b := tmp_1.Second.First
	c := tmp_1.Second.Second
	tmp_1_2 := 7
	_ = a
	_ = b
	_ = c
	_ = tmp_1_2
}
