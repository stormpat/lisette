---
source: tests/spec/emit/control_flow.rs
description: |
  
  fn get_value(s: string) -> Option<int> {
    if s == "ok" { Some(42) } else { None }
  }
  
  fn test() -> int {
    let Some(x) = get_value("ok") else { return 0; };
    x
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func get_value(s string) (int, bool) {
	if s == "ok" {
		return 42, true
	}
	return 0, false
}

func test() int {
	option_2 := lisette.OptionFromCommaOk[int](get_value("ok"))
	subject_1 := option_2
	if subject_1.Tag != lisette.OptionSome {
		return 0
	}
	x := subject_1.SomeVal
	return x
}
