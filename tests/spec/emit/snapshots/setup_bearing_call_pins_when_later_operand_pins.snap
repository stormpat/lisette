---
source: tests/spec/emit/expressions.rs
description: |
  
  fn foo(a: int, b: int) -> int { a + b }
  
  fn run() -> int {
    let mut x = 1
    let setx = || -> int { x = 50; 100 }
    let bump = |v: int| -> int { x += 7; v }
    let r = [foo(x, setx()), x, bump(5)]
    r[0] + r[1] + r[2]
  }
---
package main

func foo(a, b int) int {
	return a + b
}

func run() int {
	x := 1
	setx := func() int {
		x = 50
		return 100
	}
	bump := func(v int) int {
		x += 7
		return v
	}
	_arg_1 := x
	_v_2 := foo(_arg_1, setx())
	_v_3 := x
	r := []int{_v_2, _v_3, bump(5)}
	return r[0] + r[1] + r[2]
}
