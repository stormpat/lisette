---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Wrap(Slice<int>)
  
  fn main() {
    let mut w = Wrap([1])
    let mut m = Map.new<string, Ref<Wrap>>()
    m["a"] = &w
    m["a"].* = Wrap(m["a"].0.append(2))
    let _ = w
  }
---
package main

type Wrap []int

func main() {
	w := Wrap([]int{1})
	m := make(map[string]*Wrap)
	m["a"] = &w
	ref_1 := m["a"]
	*ref_1 = Wrap(append([]int(*m["a"]), 2))
	_ = w
}
