---
source: tests/spec/emit/types.rs
description: |
  
  enum MyResult<T> { Success(T), Failure }
  
  fn test() -> MyResult<int> {
    Success(42)
  }
---
package main

func MakeMyResultSuccess[T any](arg0 T) MyResult[T] {
	return MyResult[T]{Tag: MyResultSuccess, Success: arg0}
}

func MakeMyResultFailure[T any]() MyResult[T] {
	return MyResult[T]{Tag: MyResultFailure}
}

type MyResultTag int

const (
	MyResultSuccess MyResultTag = iota
	MyResultFailure
)

type MyResult[T any] struct {
	Tag     MyResultTag
	Success T
}

func test() MyResult[int] {
	return MakeMyResultSuccess(42)
}
