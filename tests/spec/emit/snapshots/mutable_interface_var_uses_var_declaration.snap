---
source: tests/spec/emit/types.rs
description: "input: \ninterface Printable {\n  fn to_string(self) -> string\n}\n\nstruct Box { label: string }\nimpl Box {\n  pub fn to_string(self) -> string { self.label }\n}\n\nfn test() {\n  let p: Printable = Box { label: \"hello\" }\n}\n"
---
package main

import "fmt"

type Printable interface {
	ToString() string
}

type Box struct {
	label string
}

func (b Box) String() string {
	return fmt.Sprintf("Box { label: %v }", b.label)
}

func (b Box) ToString() string {
	return b.label
}

func test() {
	_ = Box{label: "hello"}
}
