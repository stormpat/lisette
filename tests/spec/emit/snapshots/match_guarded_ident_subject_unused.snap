package main

import "fmt"

type P struct {
	v int
}

func (p P) String() string {
	return fmt.Sprintf("P { v: %v }", p.v)
}

func test() {
	_ = P{v: 1}
match_2:
	for {
		{
			if false {
				break match_2
			}
		}
		break match_2
	}
}
