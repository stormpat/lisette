---
source: tests/spec/emit/control_flow.rs
description: |
  
  fn get_end() -> int { 5 }
  
  fn test() -> int {
    let mut sum = 0;
    for i in 0..get_end() {
      sum = sum + i;
    };
    sum
  }
---
package main

func get_end() int {
	return 5
}

func test() int {
	sum := 0
	_bound_1 := get_end()
	for i := 0; i < _bound_1; i++ {
		sum += i
	}
	return sum
}
