---
source: tests/spec/emit/control_flow.rs
description: |
  
  fn die() -> Never { panic("dead") }
  
  fn test(x: int) -> int {
    match x {
      0 => die(),
      _ => x + 1,
    }
  }
---
package main

func die() struct{} {
	panic("dead")
}

func test(x int) int {
	if x == 0 {
		die()
		panic("unreachable")
	}
	return x + 1
}
