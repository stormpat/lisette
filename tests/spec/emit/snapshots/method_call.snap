---
source: tests/spec/emit/functions.rs
description: |
  
  struct Point { x: int, y: int }
  
  impl Point {
    fn get_x(self: Point) -> int {
      self.x
    }
  }
  
  fn test(p: Point) -> int {
    p.get_x()
  }
---
package main

type Point struct {
	x int
	y int
}

func (p Point) get_x() int {
	return p.x
}

func test(p Point) int {
	return p.get_x()
}
