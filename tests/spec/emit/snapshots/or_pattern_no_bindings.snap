---
source: tests/spec/emit/control_flow.rs
description: "input: \nenum Status { Pending, Running, Complete, Failed }\n\nfn test(s: Status) -> string {\n  match s {\n    Pending | Running => \"in progress\",\n    Complete | Failed => \"finished\",\n  }\n}\n"
---
package main

func MakeStatusPending() Status {
	return Status{Tag: StatusPending}
}

func MakeStatusRunning() Status {
	return Status{Tag: StatusRunning}
}

func MakeStatusComplete() Status {
	return Status{Tag: StatusComplete}
}

func MakeStatusFailed() Status {
	return Status{Tag: StatusFailed}
}

type StatusTag int

const (
	StatusPending StatusTag = iota
	StatusRunning
	StatusComplete
	StatusFailed
)

type Status struct {
	Tag StatusTag
}

func test(s Status) string {
	if s.Tag == StatusPending || s.Tag == StatusRunning {
		return "in progress"
	}
	return "finished"
}
