source: tests/spec/emit/functions.rs
description: |
  
  type Handler = fn(int) -> string
  
  fn my_handler(x: int) -> string {
    "ok"
  }
  
  fn test() -> fn(int) -> string {
    let h = my_handler as Handler
    h as fn(int) -> string
