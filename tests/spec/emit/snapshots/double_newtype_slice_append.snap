---
source: tests/spec/emit/types.rs
description: "input: \nstruct A(Slice<int>)\nstruct B(A)\n\nfn main() {\n  let mut w = B(A([]))\n  w = B(A(w.0.0.append(1)))\n}\n"
---
package main

import "fmt"

type A []int

func (a A) String() string {
	return fmt.Sprintf("A(%v)", []int(a))
}

type B A

func (b B) String() string {
	return fmt.Sprintf("B(%v)", A(b))
}

func main() {
	w := B(A(([]int)(nil)))
	w = B(A(append([]int(A(w)), 1)))
}
