---
source: tests/spec/emit/interop_matrix.rs
description: |
  
  import "go:os"
  
  fn main() {
    let f = os.LookupEnv
    let r = f("HOME")
    match r {
      Some(v) => { let _ = v },
      None => { let _ = "" },
    }
  }
---
package main

import (
	lisette "github.com/ivov/lisette/prelude"
	"os"
)

func main() {
	f := os.LookupEnv
	option_1 := lisette.OptionFromCommaOk[string](f("HOME"))
	r := option_1
	if r.Tag == lisette.OptionSome {
		_ = r.SomeVal
	} else {
	}
}
