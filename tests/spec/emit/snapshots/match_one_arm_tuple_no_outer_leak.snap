---
source: tests/spec/emit/patterns.rs
description: "input: \nfn test() -> string {\n  let n = 50;\n  let s = \"original\";\n  let pair = (100, \"replaced\");\n  let r = match pair {\n    (n, s) => f\"{n}-{s}\",\n  };\n  f\"{n} {s} {r}\"\n}\n"
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
)

func test() string {
	n := 50
	s := "original"
	pair := lisette.MakeTuple2(100, "replaced")
	var r string
	{
		r = fmt.Sprintf("%v-%v", pair.First, pair.Second)
	}
	return fmt.Sprintf("%v %v %v", n, s, r)
}
