---
source: tests/spec/emit/control_flow.rs
description: |
  
  fn safe_divide(a: float64, b: float64) -> Option<float64> {
    if b == 0.0 { None } else { Some(a / b) }
  }
  
  fn parse_and_divide(a: float64, b: float64) -> Result<string, string> {
    let result = match safe_divide(a, b) {
      Some(v) => v,
      None => return Err("division by zero"),
    };
    Ok(f"{result}")
  }
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
)

func safe_divide(a, b float64) (float64, bool) {
	if b == 0.0 {
		return *new(float64), false
	}
	return a / b, true
}

func parse_and_divide(a, b float64) lisette.Result[string, string] {
	var result float64
	option_2 := lisette.OptionFromCommaOk[float64](safe_divide(a, b))
	subject_1 := option_2
	if subject_1.Tag == lisette.OptionSome {
		result = subject_1.SomeVal
	} else {
		return lisette.MakeResultErr[string, string]("division by zero")
	}
	return lisette.MakeResultOk[string, string](fmt.Sprint(result))
}
