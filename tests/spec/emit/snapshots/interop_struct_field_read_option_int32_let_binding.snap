package main

import (
	"example.com/aws"
	lisette "github.com/ivov/lisette/prelude"
)

func main() {
	input := aws.ListInput{}
	raw_1 := input.MaxItems
	option_2 := lisette.OptionFromPointer[int32](raw_1)
	n := option_2
	_ = n
}
