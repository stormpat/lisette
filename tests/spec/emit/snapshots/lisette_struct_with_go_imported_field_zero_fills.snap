package main

import (
	"fmt"
	"net/http"
)

type Wrapper struct {
	srv http.Server
}

func (w Wrapper) String() string {
	return fmt.Sprintf("Wrapper { srv: %v }", w.srv)
}

func test() Wrapper {
	return Wrapper{srv: http.Server{}}
}
