---
source: tests/spec/emit/control_flow.rs
description: "input: \nenum E { A(int), B(int), C }\n\nfn test(e: E) -> int {\n  let A(x) | B(x) = e else { return 0; };\n  x\n}\n"
---
package main

func MakeEA(arg0 int) E {
	return E{Tag: EA, A: arg0}
}

func MakeEB(arg0 int) E {
	return E{Tag: EB, B: arg0}
}

func MakeEC() E {
	return E{Tag: EC}
}

type ETag int

const (
	EA ETag = iota
	EB
	EC
)

type E struct {
	Tag ETag
	A   int
	B   int
}

func test(e E) int {
	var x int
	if e.Tag == EA {
		x = e.A
	} else if e.Tag == EB {
		x = e.B
	} else {
		return 0
	}
	return x
}
