---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Wrap(int)
  
  fn main() {
    let mut w = Wrap(1)
    let mut m = Map.new<string, Ref<Wrap>>()
    m["a"] = &w
    m["a"].* = Wrap(2)
    let _ = w
  }
---
package main

type Wrap int

func main() {
	w := Wrap(1)
	m := make(map[string]*Wrap)
	m["a"] = &w
	*m["a"] = Wrap(2)
	_ = w
}
