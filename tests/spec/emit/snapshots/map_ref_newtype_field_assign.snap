source: tests/spec/emit/expressions.rs
description: "input: \nstruct Wrap(int)\n\nfn main() {\n  let mut w = Wrap(1)\n  let mut m = Map.new<string, Ref<Wrap>>()\n  m[\"a\"] = &w\n  m[\"a\"].* = Wrap(2)\n  let _ = w\n}\n"
---
package main

type Wrap int

func main() {
	w := Wrap(1)
	m := make(map[string]*Wrap)
	m["a"] = &w
	*m["a"] = Wrap(2)
	_ = w
}
