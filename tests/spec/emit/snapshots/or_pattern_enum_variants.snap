---
source: tests/spec/emit/control_flow.rs
description: |
  
  enum Color { Red, Green, Blue }
  
  fn test(c: Color) -> string {
    match c {
      Red | Green => "warm",
      Blue => "cool",
    }
  }
---
package main

func MakeColorRed() Color {
	return Color{Tag: ColorRed}
}

func MakeColorGreen() Color {
	return Color{Tag: ColorGreen}
}

func MakeColorBlue() Color {
	return Color{Tag: ColorBlue}
}

type ColorTag int

const (
	ColorRed ColorTag = iota
	ColorGreen
	ColorBlue
)

type Color struct {
	Tag ColorTag
}

func test(c Color) string {
	if c.Tag == ColorRed || c.Tag == ColorGreen {
		return "warm"
	}
	return "cool"
}
