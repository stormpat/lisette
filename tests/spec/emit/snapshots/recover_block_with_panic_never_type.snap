---
source: tests/spec/emit/recover.rs
description: |
  
  fn panicky() -> int {
    let arr: Slice<int> = [];
    arr[0]
  }
  
  fn test() {
    let result = recover { panicky() };
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func panicky() int {
	arr := ([]int)(nil)
	return arr[0]
}

func test() {
	recoverResult_1 := lisette.RecoverBlock(func() int {
		return panicky()
	})
	_ = recoverResult_1
}
