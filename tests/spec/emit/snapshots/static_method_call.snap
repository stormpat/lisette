---
source: tests/spec/emit/functions.rs
description: |
  
  struct Point { x: int, y: int }
  
  impl Point {
    fn new(x: int, y: int) -> Point {
      Point { x: x, y: y }
    }
  }
  
  fn main() -> int {
    let p = Point.new(1, 2);
    p.x
  }
---
package main

type Point struct {
	x int
	y int
}

func Point_new(x, y int) Point {
	return Point{
		x: x,
		y: y,
	}
}

func main() int {
	p := Point_new(1, 2)
	return p.x
}
