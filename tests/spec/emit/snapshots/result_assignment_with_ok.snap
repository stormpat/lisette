source: tests/spec/emit/result_option_patterns.rs
description: |
  
  fn test() {
    let mut res: Result<int, string> = Err("initial");
    res = Ok(42);
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func test() {
	_ = lisette.MakeResultErr[int, string]("initial")
	_ = lisette.MakeResultOk[int, string](42)
}
