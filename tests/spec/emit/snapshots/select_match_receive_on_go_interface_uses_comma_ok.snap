---
source: tests/spec/emit/patterns.rs
description: "input: \nimport \"go:example.com/shapes\"\n\nfn drain(ch: Receiver<shapes.Shape>) -> int {\n  select {\n    match ch.receive() {\n      Some(shapes.Rect { W: w, H: h }) => w * h,\n      None => -1,\n    },\n  }\n}\n"
---
package main

import "example.com/shapes"

func drain(ch <-chan shapes.Shape) int {
	select {
	case recv_1, ok := <-ch:
		if ok {
			asserted_2, ok_3 := recv_1.(shapes.Rect)
			if ok_3 {
				return asserted_2.W * asserted_2.H
			} else {
				return -1
			}
		} else {
			return -1
		}
	}
}
