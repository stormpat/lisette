---
source: tests/spec/emit/interop_matrix.rs
description: |
  
  import "go:strconv"
  
  fn main() {
    let xs: Slice<string> = ["1"]
    let ys = xs.map(strconv.Atoi)
    match ys[0] {
      Ok(v) => { let _ = v },
      Err(_) => { let _ = 0 },
    }
  }
---
package main

import (
	lisette "github.com/ivov/lisette/prelude"
	"strconv"
)

func main() {
	xs := []string{"1"}
	ys := lisette.SliceMap(xs, func(arg0 string) lisette.Result[int, error] {
		ret_1, ret_2 := strconv.Atoi(arg0)
		if ret_2 != nil {
			return lisette.MakeResultErr[int, error](ret_2)
		} else {
			return lisette.MakeResultOk[int, error](ret_1)
		}
	})
	subject_3 := ys[0]
	if subject_3.Tag == lisette.ResultOk {
		_ = subject_3.OkVal
	} else {
	}
}
