package main

type GameModeParam string

type Inner struct {
	X int
}

type Wrapper Inner

type Name string

type DoubleName Name

type Command struct {
	Gamemode GameModeParam
	Wrapper  Wrapper
	Double   DoubleName
}

func register() Command {
	return Command{
		Gamemode: GameModeParam(""),
		Wrapper:  Wrapper(Inner{X: 0}),
		Double:   DoubleName(Name("")),
	}
}
