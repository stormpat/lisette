---
source: tests/spec/emit/prelude.rs
description: |
  
  fn main() {
    let mut s = "ab"
    let mut count = 0
    for b in s.bytes() {
      count += 1
      s = ""
      let _ = b
    }
    if count != 2 {
      panic("expected count 2 — bytes loop must iterate over the original string")
    }
  }
---
package main

func main() {
	s := "ab"
	count := 0
	_s_1 := s
	for _i_2 := 0; _i_2 < len(_s_1); _i_2++ {
		b := _s_1[_i_2]
		count++
		s = ""
		_ = b
	}
	if count != 2 {
		panic("expected count 2 — bytes loop must iterate over the original string")
	}
}
