---
source: tests/spec/emit/interop_matrix.rs
description: |
  
  import "go:bufio"
  import "go:fmt"
  import "go:io"
  import "go:os"
  
  fn main() {
    let reader = bufio.NewReader(os.Stdin)
    while true {
      let r = match reader.ReadRune() {
        Ok((r, _)) => r,
        Err(io.EOF) => break,
        Err(_) => panic("error"),
      }
      fmt.Printf("%c", r)
    }
  }
---
package main

import (
	"bufio"
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
	"io"
	"os"
)

func main() {
	reader := bufio.NewReader(os.Stdin)
loop_1:
	for {
		var r_2 rune
		ret_4, ret_5, ret_6 := reader.ReadRune()
		tup_7 := lisette.MakeTuple2(ret_4, ret_5)
		var result_8 lisette.Result[lisette.Tuple2[rune, int], error]
		if ret_6 != nil {
			result_8 = lisette.MakeResultErr[lisette.Tuple2[rune, int], error](ret_6)
		} else {
			result_8 = lisette.MakeResultOk[lisette.Tuple2[rune, int], error](tup_7)
		}
		if result_8.Tag == lisette.ResultOk {
			r_2 = result_8.OkVal.First
		} else {
			if result_8.ErrVal == io.EOF {
				break loop_1
			}
			panic("error")
		}
		fmt.Printf("%c", r_2)
	}
}
