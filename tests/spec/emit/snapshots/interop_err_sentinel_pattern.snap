---
source: tests/spec/emit/interop_matrix.rs
description: |
  
  import "go:bufio"
  import "go:fmt"
  import "go:io"
  import "go:os"
  
  fn main() {
    let reader = bufio.NewReader(os.Stdin)
    while true {
      let r = match reader.ReadRune() {
        Ok((r, _)) => r,
        Err(io.EOF) => break,
        Err(_) => panic("error"),
      }
      fmt.Printf("%c", r)
    }
  }
---
package main

import (
	"bufio"
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
	"io"
	"os"
)

func main() {
	reader := bufio.NewReader(os.Stdin)
	for {
		var r_1 rune
		ret_3, ret_4, ret_5 := reader.ReadRune()
		tup_6 := lisette.MakeTuple2(ret_3, ret_4)
		var result_7 lisette.Result[lisette.Tuple2[rune, int], error]
		if ret_5 != nil {
			result_7 = lisette.MakeResultErr[lisette.Tuple2[rune, int], error](ret_5)
		} else {
			result_7 = lisette.MakeResultOk[lisette.Tuple2[rune, int], error](tup_6)
		}
		if result_7.Tag == lisette.ResultOk {
			r_1 = result_7.OkVal.First
		} else {
			if result_7.ErrVal == io.EOF {
				break
			}
			panic("error")
		}
		fmt.Printf("%c", r_1)
	}
}
