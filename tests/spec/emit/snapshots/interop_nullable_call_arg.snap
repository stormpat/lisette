---
source: tests/spec/emit/interop_matrix.rs
description: |
  
  import "go:flag"
  
  fn apply(f: fn(string) -> Option<Ref<flag.Flag>>, name: string) -> bool {
    match f(name) {
      Some(_) => true,
      None => false,
    }
  }
  
  fn main() {
    let r = apply(flag.Lookup, "verbose")
    let _ = r
  }
---
package main

import (
	"flag"
	lisette "github.com/ivov/lisette/prelude"
)

func apply(f func(string) *flag.Flag, name string) bool {
	raw_2 := f(name)
	option_3 := lisette.OptionFromNilable[*flag.Flag](raw_2, raw_2 == nil)
	subject_1 := option_3
	if subject_1.Tag == lisette.OptionSome {
		return true
	}
	return false
}

func main() {
	r := apply(flag.Lookup, "verbose")
	_ = r
}
