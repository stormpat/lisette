---
source: tests/spec/emit/patterns.rs
description: |
  
  import "go:example.com/shapes"
  
  fn drain(ch: Receiver<shapes.Shape>) -> int {
    select {
      let Some(shapes.Rect { W: w, H: h }) = ch.receive() => w * h,
      _ => 0,
    }
  }
---
package main

import "example.com/shapes"

func drain(ch <-chan shapes.Shape) int {
	ch_1 := ch
	for {
		select {
		case recv_2, ok := <-ch_1:
			if ok {
				asserted_3, ok_4 := recv_2.(shapes.Rect)
				if ok_4 {
					return asserted_3.W * asserted_3.H
				} else {
					return 0
				}
			} else {
				ch_1 = nil
				continue
			}
		default:
			return 0
		}
	}
}
