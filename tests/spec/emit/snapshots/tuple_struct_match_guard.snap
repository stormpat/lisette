---
source: tests/spec/emit/types.rs
description: |
  
  struct Point(int, int)
  
  fn test(p: Point) -> int {
    match p {
      Point(x, y) if x > 0 => x + y,
      Point(_, y) => y,
    }
  }
---
package main

type Point struct {
	F0 int
	F1 int
}

func test(p Point) int {
	subject_1 := p
	{
		x := subject_1.F0
		y := subject_1.F1
		if x > 0 {
			return x + y
		}
	}
	{
		return subject_1.F1
	}
}
