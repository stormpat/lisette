---
source: tests/spec/emit/functions.rs
description: |
  
  fn fallible() -> Result<int, string> {
    Ok(10)
  }
  
  fn test() -> int {
    let f = |x: int| -> Result<int, string> {
      let v = fallible()?;
      Ok(v + x)
    };
    match f(5) {
      Ok(n) => n,
      Err(_) => -1,
    }
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func fallible() lisette.Result[int, string] {
	return lisette.MakeResultOk[int, string](10)
}

func test() int {
	f := func(x int) lisette.Result[int, string] {
		check_1 := fallible()
		if check_1.Tag != lisette.ResultOk {
			return lisette.MakeResultErr[int, string](check_1.ErrVal)
		}
		v := check_1.OkVal
		return lisette.MakeResultOk[int, string](v + x)
	}
	subject_2 := f(5)
	if subject_2.Tag == lisette.ResultOk {
		return subject_2.OkVal
	}
	return -1
}
