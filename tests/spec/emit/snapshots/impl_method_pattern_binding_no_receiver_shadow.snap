---
source: tests/spec/emit/types.rs
description: |
  
  struct Node {
    pub value: int,
    pub next: Option<int>,
  }
  
  impl Node {
    fn sum(self) -> int {
      match self.next {
        Some(n) => self.value + n,
        None => self.value,
      }
    }
  }
  
  fn test() -> int {
    let node = Node { value: 10, next: Some(5) }
    node.sum()
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

type Node struct {
	Value int
	Next  lisette.Option[int]
}

func (n Node) sum() int {
	subject_1 := n.Next
	if subject_1.Tag == lisette.OptionSome {
		return n.Value + subject_1.SomeVal
	}
	return n.Value
}

func test() int {
	node := Node{
		Value: 10,
		Next:  lisette.MakeOptionSome(5),
	}
	return node.sum()
}
