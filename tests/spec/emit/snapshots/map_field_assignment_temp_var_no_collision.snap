---
source: tests/spec/emit/expressions.rs
description: "input: \nimport \"go:fmt\"\n\nstruct Box { x: int }\n\nfn main() {\n  let mut m = Map.from([(\"a\", Box { x: 1 })])\n  let mut entry = m[\"a\"]\n  entry.x = 2\n  m[\"a\"] = entry\n  let entry_1 = 3\n  fmt.Println(entry_1)\n}\n"
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
)

type Box struct {
	x int
}

func main() {
	m := lisette.MapFrom([]lisette.Tuple2[string, Box]{lisette.MakeTuple2("a", Box{x: 1})})
	entry := m["a"]
	entry.x = 2
	m["a"] = entry
	entry_1 := 3
	fmt.Println(entry_1)
}
