---
source: tests/spec/emit/types.rs
description: |
  
  #[display]
  struct Point { x: int, y: int }
  
  impl Point {
    fn string(self) -> string {
      "p"
    }
  }
---
package main

import "fmt"

type Point struct {
	x int
	y int
}

func (p Point) GoString() string {
	return fmt.Sprintf("Point { x: %v, y: %v }", p.x, p.y)
}

func (p Point) to_string() string {
	return p.String()
}

func (p Point) String() string {
	return "p"
}
