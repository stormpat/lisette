---
package main

func bump(i *int) int {
	*i = 1
	return 9
}

func first(a, _ int) int {
	return a
}

func main() {
	i := 0
	m := [][]int{[]int{10}, []int{20}}
	ip := &i
	_arg_2 := m[i][0]
	_base_1 := []int{bump(ip)}
	x := first(_arg_2, _base_1[0])
	_ = x
}
