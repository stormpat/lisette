---
source: tests/spec/emit/expressions.rs
description: |
  
  fn bump(i: Ref<int>) -> int {
    i.* = 1
    9
  }
  
  fn first(a: int, _b: int) -> int { a }
  
  fn main() {
    let mut i = 0
    let m = [[10], [20]]
