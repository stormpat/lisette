---
source: tests/spec/emit/concurrency.rs
description: |
  
  fn mark() -> int {
    2
  }
  
  fn test() {
    let mut xs = [1]
    defer xs.append(mark())
  }
---
package main

func mark() int {
	return 2
}

func test() {
	xs := []int{1}
	_arg_1 := xs
	_arg_2 := mark()
	defer func() {
		_ = append(_arg_1[:len(_arg_1):len(_arg_1)], _arg_2)
	}()
}
