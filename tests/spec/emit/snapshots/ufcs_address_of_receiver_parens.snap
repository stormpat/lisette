---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Counter { x: int }
  
  impl Counter {
    fn inc(self: Ref<Counter>) -> int {
      self.x = self.x + 1
      self.x
    }
  }
  
  fn main() {
    let c = Counter { x: 0 }
    let _ = Counter.inc(&c)
  }
---
package main

type Counter struct {
	x int
}

func (c *Counter) inc() int {
	c.x++
	return c.x
}

func main() {
	c := Counter{x: 0}
	_ = c.inc()
}
