---
source: tests/spec/emit/expressions.rs
description: "input: \nstruct Counter { x: int }\n\nimpl Counter {\n  fn inc(self: Ref<Counter>) -> int {\n    self.x = self.x + 1\n    self.x\n  }\n}\n\nfn main() {\n  let c = Counter { x: 0 }\n  let _ = Counter.inc(&c)\n}\n"
---
package main

type Counter struct {
	x int
}

func (c *Counter) inc() int {
	c.x++
	return c.x
}

func main() {
	c := Counter{x: 0}
	_ = c.inc()
}
