package main

import lisette "github.com/ivov/lisette/prelude"

func test() string {
	recoverResult_1 := lisette.RecoverBlock(func() struct{} {
		panic("oh no!")
	})
	if recoverResult_1.Tag == lisette.ResultOk {
		return "ok"
	}
	return "caught panic"
}
