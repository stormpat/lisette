---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Pair { a: int, b: int }
  
  fn bump(i: Ref<int>) -> int {
    i.* = 1
    10
  }
  
  fn main() {
    let mut i = 0
    let p = Pair { a: i, b: bump(&i) }
    let _ = p
  }
---
package main

type Pair struct {
	a int
	b int
}

func bump(i *int) int {
	*i = 1
	return 10
}

func main() {
	i := 0
	_field_1 := i
	p := Pair{
		a: _field_1,
		b: bump(&i),
	}
	_ = p
}
