---
source: tests/spec/emit/expressions.rs
description: "input: \nstruct Pair { a: int, b: int }\n\nfn bump(i: Ref<int>) -> int {\n  i.* = 1\n  10\n}\n\nfn main() {\n  let mut i = 0\n  let p = Pair { a: i, b: bump(&i) }\n  let _ = p\n}\n"
---
package main

type Pair struct {
	a int
	b int
}

func bump(i *int) int {
	*i = 1
	return 10
}

func main() {
	i := 0
	p := Pair{
		a: i,
		b: bump(&i),
	}
	_ = p
}
