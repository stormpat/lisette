---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Base { pub id: int }
  
  impl Base {
    pub fn bump(self: Ref<Base>) { self.id += 1 }
  }
  
  struct Outer { embed Base }
  
  fn main() {
    let g = Outer.bump
    let mut o = Outer { Base: Base { id: 1 } }
    g(&o)
  }
---
package main

type Base struct {
	Id int
}

func (b *Base) Bump() {
	b.Id++
}

type Outer struct {
	Base
}

func main() {
	g := (*Outer).Bump
	o := Outer{Base: Base{Id: 1}}
	g(&o)
}
