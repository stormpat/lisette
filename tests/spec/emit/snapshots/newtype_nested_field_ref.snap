---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Inner { x: int }
  struct Wrap(Inner)
  
  fn main() {
    let mut w = Wrap(Inner { x: 1 })
    let inner = w.0
    let r = &inner.x
    let _ = r
  }
---
package main

type Inner struct {
	x int
}

type Wrap Inner

func main() {
	w := Wrap(Inner{x: 1})
	inner := Inner(w)
	r := &inner.x
	_ = r
}
