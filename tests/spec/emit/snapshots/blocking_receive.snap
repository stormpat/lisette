---
source: tests/spec/emit/concurrency.rs
description: |
  
  fn test() -> Option<int> {
    let ch = Channel.new<int>();
    ch.receive()
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func test() (int, bool) {
	ch := make(chan int)
	v_1 := lisette.ChannelReceive(ch)
	if v_1.Tag == lisette.OptionSome {
		return v_1.SomeVal, true
	}
	return *new(int), false
}
