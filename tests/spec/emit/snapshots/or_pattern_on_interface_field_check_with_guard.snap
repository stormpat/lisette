---
source: tests/spec/emit/patterns.rs
description: |
  
  import "go:example.com/events"
  
  fn handle(e: events.Event, active: bool) -> int {
    match e {
      events.Click { x: 5 } | events.Scroll { .. } if active => 1,
      _ => 0,
    }
  }
---
package main

import "example.com/events"

func handle(e events.Event, active bool) int {
	subject_1 := e
	switch subject_1 := subject_1.(type) {
	case events.Click:
		if subject_1.X == 5 {
			if active {
				return 1
			}
			return 0
		}
		return 0
	case events.Scroll:
		if active {
			return 1
		}
		return 0
	default:
		return 0
	}
}
