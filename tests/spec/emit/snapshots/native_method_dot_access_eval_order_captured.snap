---
source: tests/spec/emit/expressions.rs
description: |
  
  fn bump(i: Ref<int>) -> int {
    i.* = 1
    10
  }
  
  fn main() {
    let mut i = 0
    let items = [10, 20, 30]
    let v = items.contains(bump(&i))
    let _ = v
  }
---
package main

import "slices"

func bump(i *int) int {
	*i = 1
	return 10
}

func main() {
	i := 0
	items := []int{10, 20, 30}
	v := slices.Contains(items, bump(&i))
	_ = v
}
