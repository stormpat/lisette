---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Foo { ch: Channel<int> }
  
  impl Foo {
    fn new() -> Channel<int> {
      Channel.new<int>()
    }
  }
  
  fn test() -> Channel<int> {
    Foo.new()
  }
---
package main

type Foo struct {
	ch chan int
}

func Foo_new() chan int {
	return make(chan int)
}

func test() chan int {
	return Foo_new()
}
