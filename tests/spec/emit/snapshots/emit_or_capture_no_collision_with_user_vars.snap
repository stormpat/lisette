description: |
  
  import "go:fmt"
  
  fn main() {
    let _bound_0 = 10
    for i in 0..(1 + 2) {
      fmt.Println(i)
    }
    fmt.Println(_bound_0)
  }
---
package main

import "fmt"

func main() {
	_bound_0 := 10
	_bound_1 := (1 + 2)
	for i := 0; i < _bound_1; i++ {
		fmt.Println(i)
	}
	fmt.Println(_bound_0)
}
