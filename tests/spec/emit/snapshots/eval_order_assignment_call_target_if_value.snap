---
source: tests/spec/emit/expressions.rs
description: |
  
  fn get_items() -> Slice<int> { [1, 2, 3] }
  
  fn main() {
    let mut items = [0, 0, 0]
    items[get_items()[0]] = if true { 42 } else { 0 }
  }
---
package main

func get_items() []int {
	return []int{1, 2, 3}
}

func main() {
	items := []int{0, 0, 0}
	base_2 := items
	_base_3 := get_items()
	idx_4 := _base_3[0]
	var tmp_1 int
	if true {
		tmp_1 = 42
	} else {
		tmp_1 = 0
	}
	base_2[idx_4] = tmp_1
}
