---
source: tests/spec/emit/types.rs
description: |
  
  struct Container<T> {
    items: Slice<T>,
    name: string,
  }
  
  impl<T> Container<T> {
    fn new(name: string) -> Container<T> {
      Container { items: [], name: name }
    }
  }
  
  fn test() -> Container<string> {
    Container.new("things")
  }
---
package main

type Container[T any] struct {
	items []T
	name  string
}

func Container_new[T any](name string) Container[T] {
	return Container[T]{name: name}
}

func test() Container[string] {
	return Container_new[string]("things")
}
