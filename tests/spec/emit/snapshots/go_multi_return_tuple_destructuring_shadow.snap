---
source: tests/spec/emit/functions.rs
description: |
  
  import "go:math"
  
  fn main() {
    let x = "hi"
    let _ = x
    let (x, y) = math.Modf(1.25)
    let _ = (x, y)
  }
---
package main

import (
	lisette "github.com/ivov/lisette/prelude"
	"math"
)

func main() {
	x := "hi"
	_ = x
	x_1, y := math.Modf(1.25)
	_ = lisette.MakeTuple2(x_1, y)
}
