---
source: tests/spec/emit/result_option_patterns.rs
description: "input: \nstruct Container {\n  res: Result<int, string>,\n}\n\nfn get_res(b: bool) -> Result<int, string> {\n  if b { Ok(42) } else { Err(\"failed\") }\n}\n\nfn test() {\n  let c = Container { res: get_res(true) };\n}\n"
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
)

type Container struct {
	res lisette.Result[int, string]
}

func (c Container) String() string {
	return fmt.Sprintf("Container { res: %v }", c.res)
}

func get_res(b bool) lisette.Result[int, string] {
	if b {
		return lisette.MakeResultOk[int, string](42)
	}
	return lisette.MakeResultErr[int, string]("failed")
}

func test() {
	_ = Container{res: get_res(true)}
}
