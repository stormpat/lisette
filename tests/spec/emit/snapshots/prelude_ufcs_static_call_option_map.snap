---
source: tests/spec/emit/prelude.rs
description: |
  
  fn main() {
    let opt = Some(1)
    let mapped = Option.map(opt, |x| x + 1)
    let _ = mapped
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func main() {
	opt := lisette.MakeOptionSome(1)
	mapped := lisette.OptionMap(opt, func(x int) int {
		return x + 1
	})
	_ = mapped
}
