---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Holder { p: Ref<int> }
  struct Carrier { h: Ref<Holder>, np: Ref<int> }
  
  fn retarget(mut c: Carrier) -> int {
    c.h.p = c.np
    9
  }
  
  fn main() {
    let mut a = 1
    let mut b = 2
    let mut h = Holder { p: &a }
    let mut c = Carrier { h: &h, np: &b }
    h.p.* = retarget(c)
    let _ = a
  }
---
package main

type Holder struct {
	p *int
}

type Carrier struct {
	h  *Holder
	np *int
}

func retarget(c Carrier) int {
	c.h.p = c.np
	return 9
}

func main() {
	a := 1
	b := 2
	h := Holder{p: &a}
	c := Carrier{
		h:  &h,
		np: &b,
	}
	ref_1 := h.p
	*ref_1 = retarget(c)
	_ = a
}
