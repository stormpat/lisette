---
source: tests/spec/emit/interop_matrix.rs
description: |
  
  import "go:path"
  
  fn make_splitter() -> fn(string) -> (string, string) {
    path.Split
  }
  
  fn main() {
    let f = make_splitter()
    let r = f("/foo/bar.txt")
    let _ = r
