---
source: tests/spec/emit/types.rs
description: |
  
  import "go:fmt"
  
  struct Point { x: int, y: int }
  
  fn make_x() -> int { fmt.Println("x"); 1 }
  fn make_base() -> Point { fmt.Println("base"); Point { x: 0, y: 0 } }
  
  fn main() {
    let _ = Point { x: make_x(), ..make_base() }
  }
---
package main

import "fmt"

type Point struct {
	x int
	y int
}

func make_x() int {
	fmt.Println("x")
	return 1
}

func make_base() Point {
	fmt.Println("base")
	return Point{
		x: 0,
		y: 0,
	}
}

func main() {
	field_1 := make_x()
	copy_2 := make_base()
	copy_2.x = field_1
	_ = copy_2
}
