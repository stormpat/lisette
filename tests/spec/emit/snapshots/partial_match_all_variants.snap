---
source: tests/spec/emit/partial.rs
description: |
  
  fn test(p: Partial<int, string>) -> int {
    match p {
      Partial.Ok(n) => n,
      Partial.Err(_) => 0,
      Partial.Both(n, _) => n,
    }
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func test(p lisette.Partial[int, string]) int {
	switch p.Tag {
	case lisette.PartialOk:
		return p.OkVal
	case lisette.PartialErr:
		return 0
	default:
		return p.OkVal
	}
}
