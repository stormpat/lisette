---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Wrap(Slice<int>)
  
  fn main() {
    let mut w = Wrap([1])
    let r = &w
    r.* = Wrap(r.0.append(2))
    let _ = w
  }
---
package main

type Wrap []int

func main() {
	w := Wrap([]int{1})
	r := &w
	ref_1 := r
	*ref_1 = Wrap(append([]int(*r), 2))
	_ = w
}
