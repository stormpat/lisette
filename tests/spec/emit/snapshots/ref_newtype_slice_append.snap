description: "input: \nstruct Wrap(Slice<int>)\n\nfn main() {\n  let mut w = Wrap([1])\n  let r = &w\n  r.* = Wrap(r.0.append(2))\n  let _ = w\n}\n"
---
package main

type Wrap []int

func main() {
	w := Wrap([]int{1})
	r := &w
	ref_1 := r
	*ref_1 = Wrap(append([]int(*r), 2))
	_ = w
}
