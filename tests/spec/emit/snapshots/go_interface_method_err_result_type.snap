---
package main

import (
	"context"
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
)

func main() {
	ctx := context.Background()
	raw_1 := ctx.Err()
	err := lisette.OptionFromNilable[error](raw_1, lisette.IsNilInterface(raw_1))
	fmt.Printf("err=%v\n", err)
}
