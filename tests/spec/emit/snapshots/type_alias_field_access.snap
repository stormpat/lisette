---
source: tests/spec/emit/types.rs
description: |
  
  struct Point { pub x: int, pub y: int }
  
  type Location = Point
  
  fn get_x(loc: Location) -> int {
    loc.x
  }
---
package main

type Point struct {
	X int
	Y int
}

type Location = Point

func get_x(loc Location) int {
	return loc.X
}
