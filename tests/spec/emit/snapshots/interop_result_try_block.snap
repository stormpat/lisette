---
source: tests/spec/emit/interop_matrix.rs
description: |
  
  import "go:strconv"
  
  fn make() -> Result<fn(string) -> Result<int, error>, error> {
    try {
      let _ = Ok(1)?
      strconv.Atoi
    }
  }
  
  fn main() {
    let r = make()
    match r {
      Ok(f) => {
        let r2 = f("1")
        match r2 {
          Ok(v) => { let _ = v },
          Err(_) => { let _ = 0 },
        }
      },
      Err(_) => { let _ = 0 },
    }
  }
---
package main

import (
	lisette "github.com/ivov/lisette/prelude"
	"strconv"
)

func make_() (func(string) (int, error), error) {
	tryResult_1 := func() lisette.Result[func(string) (int, error), error] {
		check_2 := lisette.MakeResultOk[int, error](1)
		if check_2.Tag != lisette.ResultOk {
			return lisette.MakeResultErr[func(string) (int, error), error](check_2.ErrVal)
		}
		return lisette.MakeResultOk[func(string) (int, error), error](strconv.Atoi)
	}()
	v_3 := tryResult_1
	if v_3.Tag == lisette.ResultOk {
		return v_3.OkVal, nil
	}
	return *new(func(string) (int, error)), v_3.ErrVal
}

func main() {
	ret_1, ret_2 := make_()
	var result_3 lisette.Result[func(string) (int, error), error]
	if ret_2 != nil {
		result_3 = lisette.MakeResultErr[func(string) (int, error), error](ret_2)
	} else {
		result_3 = lisette.MakeResultOk[func(string) (int, error), error](ret_1)
	}
	r := result_3
	if r.Tag == lisette.ResultOk {
		ret_4, ret_5 := r.OkVal("1")
		var result_6 lisette.Result[int, error]
		if ret_5 != nil {
			result_6 = lisette.MakeResultErr[int, error](ret_5)
		} else {
			result_6 = lisette.MakeResultOk[int, error](ret_4)
		}
		r2 := result_6
		if r2.Tag == lisette.ResultOk {
			_ = r2.OkVal
		} else {
		}
	} else {
	}
}
