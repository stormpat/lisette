description: "input: \nfn find_first_negative(items: Slice<int>) -> int {\n  let mut result = 0\n  for item in items {\n    match item {\n      n if n < 0 => { result = n; break },\n      _ => (),\n    }\n  }\n  result\n}\n"
---
package main

func find_first_negative(items []int) int {
	result := 0
loop_1:
	for _, item := range items {
		subject_2 := item
	match_3:
		for {
			{
				n := subject_2
				if n < 0 {
					result = n
					break loop_1
				}
			}
			break match_3
		}
	}
	return result
}
