---
source: tests/spec/emit/concurrency.rs
description: |
  
  fn test() -> int {
    let closed = Channel.new<int>()
    closed.close()
    let sink = Channel.buffered<int>(1)
    select {
      let Some(_x) = closed.receive() => 10,
      sink.send(5) => 20,
      _ => 30,
    }
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func test() int {
	closed := make(chan int)
	lisette.ChannelClose(closed)
	sink := make(chan int, 1)
	ch_1 := closed
	for {
		select {
		case _, ok := <-ch_1:
			if ok {
				return 10
			} else {
				ch_1 = nil
				continue
			}
		case sink <- 5:
			return 20
		default:
			return 30
		}
	}
}
