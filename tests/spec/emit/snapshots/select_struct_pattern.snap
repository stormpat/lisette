---
source: tests/spec/emit/concurrency.rs
description: "input: \nstruct Message { id: int, data: int }\n\nfn test(ch: Receiver<Message>) -> int {\n  select {\n    let Some(Message { id, data }) = ch.receive() => id + data,\n    _ => 0,\n  }\n}\n"
---
package main

import "fmt"

type Message struct {
	id   int
	data int
}

func (m Message) String() string {
	return fmt.Sprintf("Message { id: %v, data: %v }", m.id, m.data)
}

func test(ch <-chan Message) int {
	ch_1 := ch
	for {
		select {
		case recv_2, ok := <-ch_1:
			if ok {
				return recv_2.id + recv_2.data
			} else {
				ch_1 = nil
				continue
			}
		default:
			return 0
		}
	}
}
