---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Pair(int, int)
  struct Wrap(Pair)
  
  fn main() {
    let mut w = Wrap(Pair(0, 0))
    let mut p = w.0
    p.1 = 9
    w = Wrap(p)
    let _ = w.0.1
  }
---
package main

type Pair struct {
	F0 int
	F1 int
}

type Wrap Pair

func main() {
	w := Wrap(Pair{
		F0: 0,
		F1: 0,
	})
	p := Pair(w)
	p.F1 = 9
	w = Wrap(p)
	_ = Pair(w).F1
}
