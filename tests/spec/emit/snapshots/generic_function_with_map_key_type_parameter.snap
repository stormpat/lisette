---
source: tests/spec/emit/functions.rs
description: |
  
  fn put_in_map<K: Comparable, V>(key: K, value: V) -> Map<K, V> {
    let mut m: Map<K, V> = Map.new()
    m[key] = value
    m
  }
---
package main

func put_in_map[K comparable, V any](key K, value V) map[K]V {
	m := make(map[K]V)
	m[key] = value
	return m
}
