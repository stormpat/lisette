---
source: tests/spec/emit/patterns.rs
description: |
  
  fn maybe() -> Option<int> { Some(1) }
  
  fn main() {
    let Some(x) | Some(x) = maybe() else { return };
    let _ = x;
    let x = 2;
    let _ = x;
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func maybe() (int, bool) {
	return 1, true
}

func main() {
	option_2 := lisette.OptionFromCommaOk[int](maybe())
	subject_1 := option_2
	var x int
	if subject_1.Tag == lisette.OptionSome {
		x = subject_1.SomeVal
	} else if subject_1.Tag == lisette.OptionSome {
		x = subject_1.SomeVal
	} else {
		return
	}
	_ = x
	x_3 := 2
	_ = x_3
}
