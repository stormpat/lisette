---
source: tests/spec/emit/expressions.rs
description: |
  
  fn side() -> int { 1 }
  
  fn get_y() -> Result<int, error> { Ok(2) }
  
  fn add(_a: int, _b: int) -> int { 0 }
  
  fn run() -> Result<int, error> {
    Ok(add(side(), get_y()?))
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func side() int {
	return 1
}

func get_y() (int, error) {
	return 2, nil
}

func add(_, _ int) int {
	return 0
}

func run() (int, error) {
	_arg_5 := side()
	ret_1, ret_2 := get_y()
	var result_3 lisette.Result[int, error]
	if ret_2 != nil {
		result_3 = lisette.MakeResultErr[int, error](ret_2)
	} else {
		result_3 = lisette.MakeResultOk[int, error](ret_1)
	}
	check_4 := result_3
	if check_4.Tag != lisette.ResultOk {
		return 0, check_4.ErrVal
	}
	return add(_arg_5, check_4.OkVal), nil
}
