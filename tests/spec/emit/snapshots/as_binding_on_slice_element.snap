---
source: tests/spec/emit/patterns.rs
description: "input: \nstruct Point { x: int, y: int }\n\nfn test(pts: Slice<Point>) -> int {\n  match pts {\n    [Point { x, .. } as p, ..] => p.x,\n    _ => 0,\n  }\n}\n"
---
package main

type Point struct {
	x int
	y int
}

func test(pts []Point) int {
	if len(pts) >= 1 {
		return pts[0].x
	}
	return 0
}
