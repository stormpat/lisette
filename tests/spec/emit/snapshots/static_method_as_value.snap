---
source: tests/spec/emit/expressions.rs
description: "input: \nstruct Box { x: int }\n\nimpl Box {\n  fn new(x: int) -> Box { Box { x } }\n}\n\nfn main() {\n  let f = Box.new\n  let _ = f(1)\n}\n"
---
package main

import "fmt"

type Box struct {
	x int
}

func (b Box) String() string {
	return fmt.Sprintf("Box { x: %v }", b.x)
}

func Box_new(x int) Box {
	return Box{x: x}
}

func main() {
	_ = Box_new(1)
}
