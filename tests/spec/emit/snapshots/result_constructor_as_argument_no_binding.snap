---
source: tests/spec/emit/result_option_patterns.rs
description: "input: \nfn describe(r: Result<int, string>) -> string {\n  match r { Ok(v) => f\"{v}\", Err(e) => e }\n}\n\nfn test() -> string {\n  describe(Ok(42))\n}\n"
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
)

func describe(r lisette.Result[int, string]) string {
	if r.Tag == lisette.ResultOk {
		return fmt.Sprint(r.OkVal)
	}
	return r.ErrVal
}

func test() string {
	return describe(lisette.MakeResultOk[int, string](42))
}
