assertion_line: 1763
description: "input: \n#[tailcall]\nfn factorial(n: int, acc: int) -> int {\n  if n <= 1 { acc } else { (factorial(n - 1, acc * n)) }\n}\n"
---
package main

func factorial(n, acc int) int {
	for {
		if n <= 1 {
			return acc
		}
		n, acc = n-1, acc*n
		continue
	}
}
