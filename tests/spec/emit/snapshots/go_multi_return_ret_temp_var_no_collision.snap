---
source: tests/spec/emit/expressions.rs
description: |
  
  import "go:fmt"
  import "go:strconv"
  
  fn main() {
    let n = strconv.Atoi("42")
    let ret_1 = 7
    fmt.Println(n)
    fmt.Println(ret_1)
  }
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
	"strconv"
)

func main() {
	ret_1, ret_2 := strconv.Atoi("42")
	var n lisette.Result[int, error]
	if ret_2 != nil {
		n = lisette.MakeResultErr[int, error](ret_2)
	} else {
		n = lisette.MakeResultOk[int, error](ret_1)
	}
	ret_1_3 := 7
	fmt.Println(n)
	fmt.Println(ret_1_3)
}
