---
source: tests/spec/emit/control_flow.rs
description: "input: \nfn test() -> int {\n  let items = [(1,2), (3,4)]\n  let mut sum = 0\n  for (i, (a, b)) in items.enumerate() {\n    sum = sum + i\n  }\n  sum\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func test() int {
	items := []lisette.Tuple2[int, int]{lisette.MakeTuple2(1, 2), lisette.MakeTuple2(3, 4)}
	sum := 0
	for key_1, value_2 := range items {
		_ = value_2
		sum += key_1
	}
	return sum
}
