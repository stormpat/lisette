---
source: tests/spec/emit/result_option_patterns.rs
description: "input: \ninterface Printable {\n  fn to_string(self) -> string\n}\n\nstruct Text { content: string }\n\nimpl Text {\n  fn to_string(self) -> string { self.content }\n}\n\nfn test() {\n  let a: Option<Printable> = Some(Text { content: \"hello\" })\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

type Printable interface {
	to_string() string
}

type Text struct {
	content string
}

func (t Text) to_string() string {
	return t.content
}

func test() {
	_ = lisette.MakeOptionSome[Printable](Text{content: "hello"})
}
