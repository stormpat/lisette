---
source: tests/spec/emit/result_option_patterns.rs
description: |
  
  interface Printable {
    fn to_string() -> string
  }
  
  struct Text { content: string }
  
  impl Text {
    fn to_string(self) -> string { self.content }
  }
  
  fn test() {
    let a: Option<Printable> = Some(Text { content: "hello" })
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

type Printable interface {
	to_string() string
}

type Text struct {
	content string
}

func (t Text) to_string() string {
	return t.content
}

func test() {
	_ = lisette.MakeOptionSome[Printable](Text{content: "hello"})
}
