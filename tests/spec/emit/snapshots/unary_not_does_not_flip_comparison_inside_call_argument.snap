---
source: tests/spec/emit/expressions.rs
description: |
  
  fn always_false(b: bool) -> bool { false }
  
  fn test(x: int, y: int) -> bool {
    !always_false(x == y)
  }
---
package main

func always_false(_ bool) bool {
	return false
}

func test(x, y int) bool {
	return !always_false(x == y)
}
