---
source: tests/spec/emit/expressions.rs
description: "input: \nstruct Foo { value: int }\n\nimpl Foo {\n  fn increment(self: Ref<Foo>) {\n    self.value = self.value + 1\n  }\n}\n\nfn make_foo() -> Foo {\n  Foo { value: 42 }\n}\n\nfn test() {\n  (make_foo()).increment()\n}\n"
---
package main

type Foo struct {
	value int
}

func (f *Foo) increment() {
	f.value++
}

func make_foo() Foo {
	return Foo{value: 42}
}

func test() {
	ref_1 := (make_foo())
	ref_1.increment()
}
