---
source: tests/spec/emit/expressions.rs
description: |
  
  fn pure_add(a: int) -> int { a + 100 }
  
  fn run() -> int {
    let mut ws = [1, 2, 3]
    ws[0] = pure_add(7)
    ws[0]
  }
---
package main

func pure_add(a int) int {
	return a + 100
}

func run() int {
	ws := []int{1, 2, 3}
	ws[0] = pure_add(7)
	return ws[0]
}
