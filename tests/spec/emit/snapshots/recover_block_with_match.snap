---
source: tests/spec/emit/recover.rs
description: |
  
  fn may_panic() -> int { 42 }
  
  fn test() -> int {
    let result = recover { may_panic() };
    match result {
      Ok(x) => x,
      Err(pv) => 0,
    }
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func may_panic() int {
	return 42
}

func test() int {
	recoverResult_1 := lisette.RecoverBlock(func() int {
		return may_panic()
	})
	result := recoverResult_1
	if result.Tag == lisette.ResultOk {
		return result.OkVal
	}
	return 0
}
