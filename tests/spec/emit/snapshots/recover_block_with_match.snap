source: tests/spec/emit/recover.rs
description: "input: \nfn may_panic() -> int { 42 }\n\nfn test() -> int {\n  let result = recover { may_panic() };\n  match result {\n    Ok(x) => x,\n    Err(pv) => 0,\n  }\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func may_panic() int {
	return 42
}

func test() int {
	recoverResult_1 := lisette.RecoverBlock(func() int {
		return may_panic()
	})
	result := recoverResult_1
	if result.Tag == lisette.ResultOk {
		return result.OkVal
	}
	return 0
}
