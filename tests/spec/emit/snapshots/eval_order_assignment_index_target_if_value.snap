---
source: tests/spec/emit/expressions.rs
description: |
  
  fn main() {
    let mut items = [10, 20]
    let mut i = 0
    items[i] = if true { i = 1; 9 } else { 0 }
    let _ = items
  }
---
package main

func main() {
	items := []int{10, 20}
	i := 0
	idx_2 := i
	var tmp_1 int
	if true {
		i = 1
		tmp_1 = 9
	} else {
		tmp_1 = 0
	}
	items[idx_2] = tmp_1
	_ = items
}
