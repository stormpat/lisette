---
source: tests/spec/emit/patterns.rs
description: "input: \nstruct Point { x: int, y: int }\n\nfn test(pair: (Point, int)) -> int {\n  match pair {\n    (Point { x, .. } as p, z) => p.x + z,\n  }\n}\n"
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
)

type Point struct {
	x int
	y int
}

func (p Point) String() string {
	return fmt.Sprintf("Point { x: %v, y: %v }", p.x, p.y)
}

func test(pair lisette.Tuple2[Point, int]) int {
	p := pair.First
	z := pair.Second
	return p.x + z
}
