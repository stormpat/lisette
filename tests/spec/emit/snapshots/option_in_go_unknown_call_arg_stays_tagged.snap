---
package main

import (
	"example.com/dyn"
	lisette "github.com/ivov/lisette/prelude"
)

func main() {
	_ = dyn.Store("k", lisette.MakeOptionNone[any]())
	_ = dyn.Store("k", lisette.MakeOptionSome(1))
}
