---
source: tests/spec/emit/control_flow.rs
description: |
  
  fn get_items() -> Result<Slice<int>, string> { Ok([1, 2, 3]) }
  
  fn test() -> int {
    let result = try {
      let items = get_items()?;
      let mut sum = 0;
      for item in items {
        if item > 10 {
          break;
        }
        sum = sum + item;
      };
      sum
    };
    match result {
      Ok(s) => s,
      Err(_) => 0,
    }
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func get_items() lisette.Result[[]int, string] {
	return lisette.MakeResultOk[[]int, string]([]int{1, 2, 3})
}

func test() int {
	var result lisette.Result[int, string]
	tryResult_1 := func() lisette.Result[int, string] {
		check_2 := get_items()
		if check_2.Tag != lisette.ResultOk {
			return lisette.MakeResultErr[int, string](check_2.ErrVal)
		}
		items := check_2.OkVal
		sum := 0
		for _, item := range items {
			if item > 10 {
				break
			}
			sum += item
		}
		return lisette.MakeResultOk[int, string](sum)
	}()
	result = tryResult_1
	if result.Tag == lisette.ResultOk {
		return result.OkVal
	}
	return 0
}
