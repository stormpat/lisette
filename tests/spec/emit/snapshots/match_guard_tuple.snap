---
source: tests/spec/emit/control_flow.rs
description: |
  
  fn test(pair: (int, int)) -> string {
    match pair {
      (x, y) if x == y => "equal",
      (x, y) if x > y => "greater",
      _ => "less",
    }
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func test(pair lisette.Tuple2[int, int]) string {
	subject_1 := pair
	{
		x := subject_1.First
		y := subject_1.Second
		if x == y {
			return "equal"
		}
	}
	{
		if subject_1.First > subject_1.Second {
			return "greater"
		}
	}
	{
		return "less"
	}
}
