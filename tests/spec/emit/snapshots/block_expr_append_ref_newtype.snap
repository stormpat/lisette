source: tests/spec/emit/expressions.rs
description: "input: \nstruct Wrap(Slice<int>)\n\nfn get() -> Ref<Wrap> {\n  let mut w = Wrap([1])\n  &w\n}\n\nfn main() {\n  let x = { get().0.append(2) }\n  let _ = x[0]\n}\n"
---
package main

type Wrap []int

func get() *Wrap {
	w := Wrap([]int{1})
	return &w
}

func main() {
	var x []int
	x = append([]int(*get()), 2)
	_ = x[0]
}
