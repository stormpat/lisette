---
source: tests/spec/emit/types.rs
description: |
  
  struct inner { x: int }
  
  struct Outer {
    embed inner,
  }
  
  fn make() -> Outer {
    Outer { inner: inner { x: 1 } }
  }
---
package main

type inner struct {
	x int
}

type Outer struct {
	inner
}

func make_() Outer {
	return Outer{inner: inner{x: 1}}
}
