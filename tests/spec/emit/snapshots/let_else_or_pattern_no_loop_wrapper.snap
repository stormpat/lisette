---
source: tests/spec/emit/control_flow.rs
description: "input: \nenum Val { A(int), B(int), C }\n\nfn test(items: Slice<Val>) -> int {\n  let mut sum = 0\n  for item in items {\n    let Val.A(n) | Val.B(n) = item else {\n      continue\n    }\n    sum += n\n  }\n  sum\n}\n"
---
package main

import "fmt"

func MakeValA(arg0 int) Val {
	return Val{Tag: ValA, A: arg0}
}

func MakeValB(arg0 int) Val {
	return Val{Tag: ValB, B: arg0}
}

func MakeValC() Val {
	return Val{Tag: ValC}
}

type ValTag int

const (
	ValA ValTag = iota
	ValB
	ValC
)

type Val struct {
	Tag ValTag
	A   int
	B   int
}

func (v Val) String() string {
	switch v.Tag {
	case ValA:
		return fmt.Sprintf("A(%v)", v.A)
	case ValB:
		return fmt.Sprintf("B(%v)", v.B)
	case ValC:
		return "C"
	default:
		return fmt.Sprintf("Val(%d)", v.Tag)
	}
}

func (v Val) GoString() string {
	switch v.Tag {
	case ValA:
		return fmt.Sprintf("Val.A(%v)", v.A)
	case ValB:
		return fmt.Sprintf("Val.B(%v)", v.B)
	case ValC:
		return "Val.C"
	default:
		return fmt.Sprintf("Val(%d)", v.Tag)
	}
}

func test(items []Val) int {
	sum := 0
	for _, item := range items {
		var n int
		if item.Tag == ValA {
			n = item.A
		} else if item.Tag == ValB {
			n = item.B
		} else {
			continue
		}
		sum += n
	}
	return sum
}
