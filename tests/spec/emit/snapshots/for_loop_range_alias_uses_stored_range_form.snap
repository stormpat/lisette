---
source: tests/spec/emit/control_flow.rs
description: |
  
  type Span = Range<int>
  
  fn sum(r: Span) -> int {
    let mut total = 0
    for i in r {
      total = total + i
    }
    total
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

type Span = lisette.Range[int]

func sum(r Span) int {
	total := 0
	for i := r.Start; i < r.End; i++ {
		total += i
	}
	return total
}
