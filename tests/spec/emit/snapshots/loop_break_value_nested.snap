---
source: tests/spec/emit/control_flow.rs
description: |
  
  fn test() -> int {
    let x = loop {
      let inner = loop {
        break 10
      };
      break inner + 1
    };
    x
  }
---
package main

func test() int {
	var x int
	for {
		var inner int
		for {
			inner = 10
			break
		}
		x = inner + 1
		break
	}
	return x
}
