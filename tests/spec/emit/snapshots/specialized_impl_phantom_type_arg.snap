---
source: tests/spec/emit/types.rs
description: |
  
  struct Box<T> { value: T }
  
  impl Box<int> {
    fn tag<U>(self) -> int { 1 }
  }
  
  fn test() -> int {
    let b = Box { value: 1 };
    b.tag<string>()
  }
---
package main

type Box[T any] struct {
	value T
}

func Box_tag[U any](_ Box[int]) int {
	return 1
}

func test() int {
	b := Box[int]{value: 1}
	return Box_tag[string](b)
}
