---
source: tests/spec/emit/control_flow.rs
description: |
  
  fn test() {
    loop {
      let _ = if true { { continue } } else { { 1 } }
      break
    }
  }
---
package main

func test() {
	for {
		var tmp_1 int
		if true {
			{
				continue
			}
			panic("unreachable")
		}
		var tmp_2 int
		tmp_2 = 1
		tmp_1 = tmp_2
		_ = tmp_1
		break
	}
}
