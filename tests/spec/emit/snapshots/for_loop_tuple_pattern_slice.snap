package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
)

func test(pairs []lisette.Tuple2[int, string]) {
	for _, item_1 := range pairs {
		fmt.Println(item_1.First, item_1.Second)
	}
}
