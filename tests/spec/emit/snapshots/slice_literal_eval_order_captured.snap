---
source: tests/spec/emit/expressions.rs
description: |
  
  fn bump(i: Ref<int>) -> int {
    i.* = 1
    10
  }
  
  fn main() {
    let mut i = 0
    let s = [i, bump(&i)]
    let _ = s
  }
---
package main

func bump(i *int) int {
	*i = 1
	return 10
}

func main() {
	i := 0
	s := []int{i, bump(&i)}
	_ = s
}
