---
source: tests/spec/emit/control_flow.rs
description: |
  
  fn test(key: string, value: int) {
    let mut m = Map.new()
    match key {
      "a" => m[key] = value,
      _ => m["default"] = 0,
    }
  }
---
package main

func test(key string, value int) {
	m := make(map[string]int)
	if key == "a" {
		m[key] = value
	} else {
		m["default"] = 0
	}
}
