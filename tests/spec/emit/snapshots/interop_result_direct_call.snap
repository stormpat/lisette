source: tests/spec/emit/interop_matrix.rs
description: "input: \nimport \"go:strconv\"\n\nfn main() {\n  let r = strconv.Atoi(\"42\")\n  match r {\n    Ok(v) => { let _ = v },\n    Err(_) => { let _ = 0 },\n  }\n}\n"
---
package main

import (
	lisette "github.com/ivov/lisette/prelude"
	"strconv"
)

func main() {
	ret_1, ret_2 := strconv.Atoi("42")
	var result_3 lisette.Result[int, error]
	if ret_2 != nil {
		result_3 = lisette.MakeResultErr[int, error](ret_2)
	} else {
		result_3 = lisette.MakeResultOk[int, error](ret_1)
	}
	r := result_3
	if r.Tag == lisette.ResultOk {
		_ = r.OkVal
	} else {
	}
}
