---
source: tests/spec/emit/expressions.rs
description: |
  
  fn bump(i: Ref<int>) -> int {
    i.* = 1
    99
  }
  
  fn test() -> int {
    let xss = [[10], [20]]
    let mut i = 0
    let ys = xss[i].append(bump(&i))
    ys[0]
  }
---
package main

func bump(i *int) int {
	*i = 1
	return 99
}

func test() int {
	xss := [][]int{[]int{10}, []int{20}}
	i := 0
	recv_1 := xss[i]
	ys := append(recv_1, bump(&i))
	return ys[0]
}
