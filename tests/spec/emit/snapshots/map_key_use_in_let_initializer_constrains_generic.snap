source: tests/spec/emit/types.rs
description: |
  
  fn is_empty<T>() -> bool {
    let empty = Map.new<T, int>().is_empty()
    empty
  }
  
  fn main() {
    let _ = is_empty<int>()
  }
---
package main

func is_empty[T comparable]() bool {
	empty := len(make(map[T]int)) == 0
	return empty
}

func main() {
	_ = is_empty[int]()
}
