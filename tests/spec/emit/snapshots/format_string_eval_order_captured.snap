---
source: tests/spec/emit/expressions.rs
description: |
  
  fn bump(i: Ref<int>) -> int {
    i.* = 1
    10
  }
  
  fn main() {
    let mut i = 0
    let s = f"{i},{bump(&i)}"
    let _ = s
  }
---
package main

import "fmt"

func bump(i *int) int {
	*i = 1
	return 10
}

func main() {
	i := 0
	_fmtarg_1 := i
	s := fmt.Sprintf("%d,%d", _fmtarg_1, bump(&i))
	_ = s
}
