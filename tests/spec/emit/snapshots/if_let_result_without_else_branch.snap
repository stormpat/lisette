---
source: tests/spec/emit/control_flow.rs
description: "input: \nimport \"go:fmt\"\n\nfn try_parse(s: string) -> Result<int, string> {\n  if s == \"42\" { Ok(42) } else { Err(\"not 42\") }\n}\n\nfn test() {\n  if let Ok(x) = try_parse(\"42\") {\n    let _ = fmt.Print(f\"Parsed: {x}\\n\");\n  }\n}\n"
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
)

func try_parse(s string) lisette.Result[int, string] {
	if s == "42" {
		return lisette.MakeResultOk[int, string](42)
	}
	return lisette.MakeResultErr[int, string]("not 42")
}

func test() {
	subject_1 := try_parse("42")
	if subject_1.Tag == lisette.ResultOk {
		x := subject_1.OkVal
		fmt.Printf("Parsed: %v\n", x)
	}
}
