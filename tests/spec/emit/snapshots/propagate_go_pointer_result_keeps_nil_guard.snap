---
source: tests/spec/emit/interop_matrix.rs
description: |
  
  import "go:os"
  
  fn open_first(path: string) -> Result<int, error> {
    let _ = os.Open(path)?
    Ok(0)
  }
---
package main

import (
	"errors"
	"os"
)

func open_first(path string) (int, error) {
	ret_1, ret_2 := os.Open(path)
	if ret_2 != nil {
		return 0, ret_2
	}
	if ret_1 == nil {
		return 0, errors.New("unexpected nil")
	}
	return 0, nil
}
