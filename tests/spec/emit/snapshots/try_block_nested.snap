---
source: tests/spec/emit/control_flow.rs
description: |
  
  fn risky_a() -> Result<int, string> { Ok(1) }
  fn risky_b() -> Result<int, string> { Ok(2) }
  
  fn test() -> int {
    let outer = try {
      let inner: Result<int, string> = try {
        risky_a()?
      };
      let inner_val = match inner {
        Ok(x) => x,
        Err(_) => 0,
      };
      inner_val + risky_b()?
    };
    match outer {
      Ok(x) => x,
      Err(_) => -1,
    }
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func risky_a() lisette.Result[int, string] {
	return lisette.MakeResultOk[int, string](1)
}

func risky_b() lisette.Result[int, string] {
	return lisette.MakeResultOk[int, string](2)
}

func test() int {
	var outer lisette.Result[int, string]
	tryResult_1 := func() lisette.Result[int, string] {
		var inner lisette.Result[int, string]
		tryResult_2 := func() lisette.Result[int, string] {
			check_3 := risky_a()
			if check_3.Tag != lisette.ResultOk {
				return lisette.MakeResultErr[int, string](check_3.ErrVal)
			}
			return lisette.MakeResultOk[int, string](check_3.OkVal)
		}()
		inner = tryResult_2
		var inner_val int
		if inner.Tag == lisette.ResultOk {
			inner_val = inner.OkVal
		} else {
			inner_val = 0
		}
		_left_5 := inner_val
		check_4 := risky_b()
		if check_4.Tag != lisette.ResultOk {
			return lisette.MakeResultErr[int, string](check_4.ErrVal)
		}
		return lisette.MakeResultOk[int, string](_left_5 + check_4.OkVal)
	}()
	outer = tryResult_1
	if outer.Tag == lisette.ResultOk {
		return outer.OkVal
	}
	return -1
}
