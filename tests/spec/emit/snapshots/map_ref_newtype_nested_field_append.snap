---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Inner { items: Slice<int> }
  struct Wrap(Inner)
  
  fn main() {
    let mut w = Wrap(Inner { items: [1] })
    let mut m = Map.new<string, Ref<Wrap>>()
    m["a"] = &w
    let mut inner = m["a"].0
    inner.items = inner.items.append(2)
    m["a"].* = Wrap(inner)
    let _ = w
  }
---
package main

type Inner struct {
	items []int
}

type Wrap Inner

func main() {
	w := Wrap(Inner{items: []int{1}})
	m := make(map[string]*Wrap)
	m["a"] = &w
	inner := Inner(*m["a"])
	inner.items = append(inner.items, 2)
	*m["a"] = Wrap(inner)
	_ = w
}
