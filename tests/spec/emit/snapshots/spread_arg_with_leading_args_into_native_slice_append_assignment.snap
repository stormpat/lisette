---
source: tests/spec/emit/functions.rs
description: |
  
  fn test(mut s: Slice<int>, extra: int, more: Slice<int>) -> Slice<int> {
    s = s.append(extra, more...)
    s
  }
---
package main

func test(s []int, extra int, more []int) []int {
	s = append(s, append([]int{extra}, more...)...)
	return s
}
