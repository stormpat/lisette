---
source: tests/spec/emit/expressions.rs
description: |
  
  struct S { x: int }
  
  fn get(r: Ref<S>) -> Ref<S> { r }
  
  fn main() {
    let mut s = S { x: 0 }
    (get(&s)).x = 1
    let _ = s
  }
---
package main

type S struct {
	x int
}

func get(r *S) *S {
	return r
}

func main() {
	s := S{x: 0}
	ref_1 := get(&s)
	ref_1.x = 1
	_ = s
}
