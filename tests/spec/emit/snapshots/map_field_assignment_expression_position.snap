---
source: tests/spec/emit/expressions.rs
description: "input: \nimport \"go:fmt\"\n\nstruct Config {\n  value: int,\n}\n\nfn main() {\n  let mut m: Map<string, Config> = Map.new()\n  m[\"a\"] = Config { value: 1 }\n  let _ = {\n    let mut entry = m[\"a\"]\n    entry.value = 2\n    m[\"a\"] = entry\n  }\n  fmt.Println(m[\"a\"].value)\n}\n"
---
package main

import "fmt"

type Config struct {
	value int
}

func main() {
	m := make(map[string]Config)
	m["a"] = Config{value: 1}
	entry := m["a"]
	entry.value = 2
	m["a"] = entry
	fmt.Println(m["a"].value)
}
