package main

import "fmt"

type Box[T any] struct {
	v T
}

func (b Box[T]) String() string {
	return fmt.Sprintf("Box { v: %v }", b.v)
}

func (b Box[T]) ok() bool {
	return true
}

func test() {
	if (Box[int]{v: 1}).ok() {
	}
}
