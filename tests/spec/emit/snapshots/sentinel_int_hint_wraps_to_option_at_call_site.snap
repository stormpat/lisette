---
source: tests/spec/emit/go_interface_adapter.rs
description: |
  
  import "go:example.com/idx"
  
  fn main() {
    let pos = idx.Find("hello", "lo")
    let _ = match pos {
      Some(i) => i,
      None => -2,
    }
  }
---
package main

import (
	"example.com/idx"
	lisette "github.com/ivov/lisette/prelude"
)

func main() {
	ret_1 := idx.Find("hello", "lo")
	pos := lisette.OptionFromCommaOk[int](ret_1, ret_1 != -1)
	var tmp_2 int
	if pos.Tag == lisette.OptionSome {
		tmp_2 = pos.SomeVal
	} else {
		tmp_2 = -2
	}
	_ = tmp_2
}
