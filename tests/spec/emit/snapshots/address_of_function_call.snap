---
source: tests/spec/emit/expressions.rs
description: "input: \nstruct Foo { value: int }\n\nfn make_foo() -> Foo {\n  Foo { value: 42 }\n}\n\nfn takes_ref(f: Ref<Foo>) -> int {\n  f.value\n}\n\nfn test() -> int {\n  let tmp = make_foo()\n  takes_ref(&tmp)\n}\n"
---
package main

type Foo struct {
	value int
}

func make_foo() Foo {
	return Foo{value: 42}
}

func takes_ref(f *Foo) int {
	return f.value
}

func test() int {
	tmp := make_foo()
	return takes_ref(&tmp)
}
