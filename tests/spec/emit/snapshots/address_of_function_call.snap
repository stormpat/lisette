---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Foo { value: int }
  
  fn make_foo() -> Foo {
    Foo { value: 42 }
  }
  
  fn takes_ref(f: Ref<Foo>) -> int {
    f.value
  }
  
  fn test() -> int {
    let tmp = make_foo()
    takes_ref(&tmp)
  }
---
package main

type Foo struct {
	value int
}

func make_foo() Foo {
	return Foo{value: 42}
}

func takes_ref(f *Foo) int {
	return f.value
}

func test() int {
	tmp := make_foo()
	return takes_ref(&tmp)
}
