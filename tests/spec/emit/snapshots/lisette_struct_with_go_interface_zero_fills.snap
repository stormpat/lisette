package main

import (
	"context"
	"fmt"
)

type Wrapper struct {
	ctx context.Context
}

func (w Wrapper) String() string {
	return fmt.Sprintf("Wrapper { ctx: %v }", w.ctx)
}

func test() Wrapper {
	return Wrapper{ctx: nil}
}
