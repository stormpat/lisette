---
source: tests/spec/emit/patterns.rs
description: "input: \nimport \"go:example.com/events\"\n\nfn handle(e: events.Event) -> int {\n  match e {\n    events.Click { x } if x > 100 => 3,\n    events.Click { x } if x > 50 => 2,\n    events.Click { x } if x > 0 => 1,\n    _ => 0,\n  }\n}\n"
---
package main

import "example.com/events"

func handle(e events.Event) int {
	subject_1 := e
	switch subject_1 := subject_1.(type) {
	case events.Click:
		x := subject_1.X
		if x > 100 {
			return 3
		}
		x_2 := subject_1.X
		if x_2 > 50 {
			return 2
		}
		if subject_1.X > 0 {
			return 1
		}
		return 0
	default:
		return 0
	}
}
