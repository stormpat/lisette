---
source: tests/spec/emit/concurrency.rs
description: |
  
  fn run(out: Ref<Slice<int>>) {
    defer out.copy_from([1, 2, 3])
    out.* = [7, 7, 7, 7, 7]
  }
---
package main

func run(out *[]int) {
	_arg_1 := *out
	_arg_2 := []int{1, 2, 3}
	defer func() {
		_ = copy(_arg_1, _arg_2)
	}()
	*out = []int{7, 7, 7, 7, 7}
}
