---
source: tests/spec/emit/recover.rs
description: |
  
  fn main() {
    let result = recover { 1 };
    let recoverResult_1 = 7;
    let _ = recoverResult_1;
    let _ = result;
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func main() {
	recoverResult_1 := lisette.RecoverBlock(func() int {
		return 1
	})
	result := recoverResult_1
	recoverResult_1_2 := 7
	_ = recoverResult_1_2
	_ = result
}
