---
source: tests/spec/emit/expressions.rs
description: "input: \nfn extract(opt: Option<int>) -> int {\n  let x = match opt {\n    Some(x) => x,\n    None => 0,\n  }\n  x\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func extract(opt lisette.Option[int]) int {
	var x_1 int
	if opt.Tag == lisette.OptionSome {
		x_1 = opt.SomeVal
	} else {
		x_1 = 0
	}
	return x_1
}
