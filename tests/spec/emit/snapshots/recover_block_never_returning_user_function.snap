---
source: tests/spec/emit/recover.rs
description: "input: \nfn fail(msg: string) -> Never { panic(msg) }\n\nfn test() -> string {\n  let result = recover { fail(\"intentional\") };\n  match result {\n    Ok(_) => \"ok\",\n    Err(_) => \"caught\",\n  }\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func fail(msg string) struct{} {
	panic(msg)
}

func test() string {
	recoverResult_1 := lisette.RecoverBlock(func() struct{} {
		fail("intentional")
		panic("unreachable")
	})
	if recoverResult_1.Tag == lisette.ResultOk {
		return "ok"
	}
	return "caught"
}
