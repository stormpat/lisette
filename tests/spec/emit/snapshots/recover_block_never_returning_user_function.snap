---
source: tests/spec/emit/recover.rs
description: |
  
  fn fail(msg: string) -> Never { panic(msg) }
  
  fn test() -> string {
    let result = recover { fail("intentional") };
    match result {
      Ok(_) => "ok",
      Err(_) => "caught",
    }
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func fail(msg string) struct{} {
	panic(msg)
}

func test() string {
	recoverResult_1 := lisette.RecoverBlock(func() struct{} {
		fail("intentional")
		panic("unreachable")
	})
	result := recoverResult_1
	if result.Tag == lisette.ResultOk {
		return "ok"
	}
	return "caught"
}
