---
source: tests/spec/emit/control_flow.rs
description: |
  
  fn test(res: Result<int, string>) {
    let mut current = res;
    while let Ok(value) = current {
      current = Err("done");
      let _ = value;
    }
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func test(res lisette.Result[int, string]) {
	current := res
	for {
		if current.Tag == lisette.ResultOk {
			value := current.OkVal
			current = lisette.MakeResultErr[int, string]("done")
			_ = value
		} else {
			break
		}
	}
}
