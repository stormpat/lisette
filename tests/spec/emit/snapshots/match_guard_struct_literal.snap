---
source: tests/spec/emit/control_flow.rs
description: "input: \nstruct Point { x: int, y: int }\n\nfn main() {\n  let p = Point { x: 1, y: 2 }\n  match p {\n    _ if p == Point { x: 1, y: 2 } => { let _ = 1 },\n    _ => { let _ = 2 },\n  }\n}\n"
---
package main

import "fmt"

type Point struct {
	x int
	y int
}

func (p Point) String() string {
	return fmt.Sprintf("Point { x: %v, y: %v }", p.x, p.y)
}

func main() {
	p := Point{
		x: 1,
		y: 2,
	}
match_1:
	for {
		if (p == Point{
			x: 1,
			y: 2,
		}) {
			break match_1
		}
		break match_1
	}
}
