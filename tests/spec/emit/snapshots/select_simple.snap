---
source: tests/spec/emit/concurrency.rs
description: |
  
  fn test() -> int {
    let ch1 = Channel.new<int>();
    let ch2 = Channel.new<int>();
  
    select {
      match ch1.receive() {
        Some(val) => val + 10,
        None => 0,
      },
      match ch2.receive() {
        Some(val) => val + 20,
        None => 0,
      },
      _ => 0,
    }
  }
---
package main

func test() int {
	ch1 := make(chan int)
	ch2 := make(chan int)
	select {
	case val, ok := <-ch1:
		if ok {
			return val + 10
		} else {
			return 0
		}
	case val, ok := <-ch2:
		if ok {
			return val + 20
		} else {
			return 0
		}
	default:
		return 0
	}
}
