---
source: tests/spec/emit/types.rs
description: "input: \n/// Represents the status of a task.\nenum Status { Pending, Running, Complete }\n"
---
package main

func MakeStatusPending() Status {
	return Status{Tag: StatusPending}
}

func MakeStatusRunning() Status {
	return Status{Tag: StatusRunning}
}

func MakeStatusComplete() Status {
	return Status{Tag: StatusComplete}
}

// Represents the status of a task.
type StatusTag int

const (
	StatusPending StatusTag = iota
	StatusRunning
	StatusComplete
)

type Status struct {
	Tag StatusTag
}
