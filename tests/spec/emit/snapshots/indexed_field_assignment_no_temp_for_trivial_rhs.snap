---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Pos { x: int, y: int }
  
  struct Snake {
    parts: Slice<Pos>,
    head:  int
  }
  
  impl Snake {
    fn set_head(self: Ref<Snake>, x: int, y: int) {
      self.parts[self.head].x = x
      self.parts[self.head].y = y
    }
  }
---
package main

type Pos struct {
	x int
	y int
}

type Snake struct {
	parts []Pos
	head  int
}

func (s *Snake) set_head(x, y int) {
	s.parts[s.head].x = x
	s.parts[s.head].y = y
}
