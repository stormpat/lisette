---
source: tests/spec/emit/control_flow.rs
description: |
  
  import "go:fmt"
  
  struct IntList {
    items: Slice<int>,
  }
  
  impl IntList {
    fn display(self) -> string {
      let mut s = "["
      for i in self.items {
        if s != "[" {
          s = s + ", "
        }
        s = s + f"{i}"
      }
      s + "]"
    }
  }
  
  fn main() {
    let list = IntList { items: [1, 2, 3] }
    fmt.Println(list.display())
  }
---
package main

import "fmt"

type IntList struct {
	items []int
}

func (i IntList) display() string {
	s := "["
	for _, i_1 := range i.items {
		if s != "[" {
			s += ", "
		}
		s += fmt.Sprint(i_1)
	}
	return s + "]"
}

func main() {
	list := IntList{items: []int{1, 2, 3}}
	fmt.Println(list.display())
}
