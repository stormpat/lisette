---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Outer { items: Ref<Slice<int>> }
  
  fn main() {
    let mut items = [1]
    let mut m = Map.new<string, Outer>()
    m["a"] = Outer { items: &items }
    let _ = { m["a"].items.*.append(2) }
    let _ = items
  }
---
package main

type Outer struct {
	items *[]int
}

func main() {
	items := []int{1}
	m := make(map[string]Outer)
	m["a"] = Outer{items: &items}
	var tmp_1 []int
	tmp_1 = append(*m["a"].items, 2)
	_ = tmp_1
	_ = items
}
