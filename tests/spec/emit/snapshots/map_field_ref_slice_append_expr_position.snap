---
source: tests/spec/emit/expressions.rs
description: "input: \nstruct Outer { items: Ref<Slice<int>> }\n\nfn main() {\n  let mut items = [1]\n  let mut m = Map.new<string, Outer>()\n  m[\"a\"] = Outer { items: &items }\n  let _ = { m[\"a\"].items.*.append(2) }\n  let _ = items\n}\n"
---
package main

type Outer struct {
	items *[]int
}

func main() {
	items := []int{1}
	m := make(map[string]Outer)
	m["a"] = Outer{items: &items}
	var tmp_1 []int
	tmp_1 = append(*m["a"].items, 2)
	_ = tmp_1
	_ = items
}
