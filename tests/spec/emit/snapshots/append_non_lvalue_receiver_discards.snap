---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Items { items: Slice<int> }
  
  fn get() -> Items { Items { items: [1] } }
  
  fn main() {
    get().items.append(2)
  }
---
package main

type Items struct {
	items []int
}

func get() Items {
	return Items{items: []int{1}}
}

func main() {
	recv_1 := get().items
	_ = append(recv_1[:len(recv_1):len(recv_1)], 2)
}
