---
source: tests/spec/emit/types.rs
description: |
  
  struct Inner { x: int }
  struct Wrap(Inner)
  
  fn main() {
    let mut w = Wrap(Inner { x: 1 })
    let mut inner = w.0
    inner.x = 2
    w = Wrap(inner)
  }
---
package main

type Inner struct {
	x int
}

type Wrap Inner

func main() {
	w := Wrap(Inner{x: 1})
	inner := Inner(w)
	inner.x = 2
	w = Wrap(inner)
}
