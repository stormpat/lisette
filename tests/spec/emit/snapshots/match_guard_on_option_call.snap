---
source: tests/spec/emit/control_flow.rs
description: |
  
  fn get_option() -> Option<int> { Some(42) }
  
  fn test() -> int {
    match get_option() {
      Some(x) if x > 0 => x,
      Some(_) => 0,
      None => -1,
    }
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func get_option() (int, bool) {
	return 42, true
}

func test() int {
	option_2 := lisette.OptionFromCommaOk[int](get_option())
	subject_1 := option_2
	if subject_1.Tag == lisette.OptionSome {
		x := subject_1.SomeVal
		if x > 0 {
			return x
		}
		return 0
	}
	return -1
}
