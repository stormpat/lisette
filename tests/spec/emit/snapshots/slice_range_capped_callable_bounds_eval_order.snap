---
source: tests/spec/emit/expressions.rs
description: |
  
  fn start() -> int { 1 }
  fn end() -> int { 3 }
  
  fn test() -> int {
    let xs = [10, 20, 30, 40]
    let ys = xs[start()..end()]
    ys.length()
  }
---
package main

func start() int {
	return 1
}

func end() int {
	return 3
}

func test() int {
	xs := []int{10, 20, 30, 40}
	start_1 := start()
	end_2 := end()
	ys := xs[start_1:end_2:end_2]
	return len(ys)
}
