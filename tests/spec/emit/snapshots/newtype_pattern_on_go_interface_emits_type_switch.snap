---
source: tests/spec/emit/patterns.rs
description: |
  
  import "go:example.com/events"
  
  fn describe(e: events.Event) -> int {
    match e {
      events.Token(s) => s.length(),
      _ => 0,
    }
  }
---
package main

import "example.com/events"

func describe(e events.Event) int {
	switch e := e.(type) {
	case events.Token:
		return len(string(e))
	default:
		return 0
	}
}
