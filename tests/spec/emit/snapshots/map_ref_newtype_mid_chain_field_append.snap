---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Inner { items: Slice<int> }
  struct Wrap(Inner)
  struct Outer { w: Ref<Wrap> }
  
  fn main() {
    let mut w = Wrap(Inner { items: [1] })
    let mut m = Map.new<string, Outer>()
    m["a"] = Outer { w: &w }
    let mut inner = m["a"].w.0
    inner.items = inner.items.append(2)
    m["a"].w.* = Wrap(inner)
    let _ = w
  }
---
package main

type Inner struct {
	items []int
}

type Wrap Inner

type Outer struct {
	w *Wrap
}

func main() {
	w := Wrap(Inner{items: []int{1}})
	m := make(map[string]Outer)
	m["a"] = Outer{w: &w}
	inner := Inner(*m["a"].w)
	inner.items = append(inner.items, 2)
	*m["a"].w = Wrap(inner)
	_ = w
}
