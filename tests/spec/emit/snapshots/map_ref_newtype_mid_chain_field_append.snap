---
source: tests/spec/emit/expressions.rs
description: "input: \nstruct Inner { items: Slice<int> }\nstruct Wrap(Inner)\nstruct Outer { w: Ref<Wrap> }\n\nfn main() {\n  let mut w = Wrap(Inner { items: [1] })\n  let mut m = Map.new<string, Outer>()\n  m[\"a\"] = Outer { w: &w }\n  let mut inner = m[\"a\"].w.0\n  inner.items = inner.items.append(2)\n  m[\"a\"].w.* = Wrap(inner)\n  let _ = w\n}\n"
---
package main

type Inner struct {
	items []int
}

type Wrap Inner

type Outer struct {
	w *Wrap
}

func main() {
	w := Wrap(Inner{items: []int{1}})
	m := make(map[string]Outer)
	m["a"] = Outer{w: &w}
	inner := Inner(*m["a"].w)
	inner.items = append(inner.items, 2)
	*m["a"].w = Wrap(inner)
	_ = w
}
