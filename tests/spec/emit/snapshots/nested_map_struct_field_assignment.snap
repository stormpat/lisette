---
source: tests/spec/emit/expressions.rs
description: "input: \nstruct Inner {\n  value: int,\n}\n\nstruct Outer {\n  inner: Inner,\n  name: string,\n}\n\nfn test() {\n    let mut m = Map.new<string, Outer>()\n    m[\"test\"] = Outer { inner: Inner { value: 0 }, name: \"test\" }\n    let mut entry = m[\"test\"]\n    entry.name = \"updated\"\n    entry.inner.value = 42\n    m[\"test\"] = entry\n}\n"
---
package main

type Inner struct {
	value int
}

type Outer struct {
	inner Inner
	name  string
}

func test() {
	m := make(map[string]Outer)
	m["test"] = Outer{
		inner: Inner{value: 0},
		name:  "test",
	}
	entry := m["test"]
	entry.name = "updated"
	entry.inner.value = 42
	m["test"] = entry
}
