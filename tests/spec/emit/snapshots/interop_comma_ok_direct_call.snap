---
source: tests/spec/emit/interop_matrix.rs
description: |
  
  import "go:os"
  
  fn main() {
    let r = os.LookupEnv("HOME")
    match r {
      Some(v) => { let _ = v },
      None => { let _ = "" },
    }
  }
---
package main

import (
	lisette "github.com/ivov/lisette/prelude"
	"os"
)

func main() {
	r := lisette.OptionFromCommaOk[string](os.LookupEnv("HOME"))
	if r.Tag == lisette.OptionSome {
		_ = r.SomeVal
	} else {
	}
}
