---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Holder { p: Ref<int> }
  
  fn retarget(h: Ref<Holder>, np: Ref<int>) -> int {
    h.p = np
    9
  }
  
  fn main() {
    let mut a = 1
    let mut b = 2
    let mut h = Holder { p: &a }
    let hp = &h
    let np = &b
    h.p.* = retarget(hp, np)
    let _ = a
  }
---
package main

type Holder struct {
	p *int
}

func retarget(h *Holder, np *int) int {
	h.p = np
	return 9
}

func main() {
	a := 1
	b := 2
	h := Holder{p: &a}
	hp := &h
	np := &b
	ref_1 := h.p
	*ref_1 = retarget(hp, np)
	_ = a
}
