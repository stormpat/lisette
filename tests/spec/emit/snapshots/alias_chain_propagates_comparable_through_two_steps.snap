---
source: tests/spec/emit/types.rs
description: |
  
  type B<T> = Map<T, int>
  type A<T> = B<T>
  
  struct Box<T> {
    table: A<T>,
  }
  
  fn main() {
    let b = Box { table: Map.new<string, int>() }
    let _ = b
  }
---
package main

type B[T comparable] = map[T]int

type A[T comparable] = B[T]

type Box[T comparable] struct {
	table A[T]
}

func main() {
	b := Box[string]{table: make(map[string]int)}
	_ = b
}
