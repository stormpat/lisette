---
package main

import (
	"example.com/dyn"
	lisette "github.com/ivov/lisette/prelude"
)

func main() {
	obj := dyn.Bag{
		Decl: "",
		Data: lisette.MakeOptionNone[any](),
	}
	obj.Decl = lisette.MakeOptionNone[any]()
	_ = obj
}
