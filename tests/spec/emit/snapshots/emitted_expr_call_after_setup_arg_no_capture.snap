---
source: tests/spec/emit/expressions.rs
description: "input: \nfn side() -> int { 1 }\n\nfn get_x() -> Result<int, error> { Ok(2) }\n\nfn add(_a: int, _b: int) -> int { 0 }\n\nfn run() -> Result<int, error> {\n  Ok(add(get_x()?, side()))\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func side() int {
	return 1
}

func get_x() (int, error) {
	return 2, nil
}

func add(_, _ int) int {
	return 0
}

func run() (int, error) {
	ret_1, ret_2 := get_x()
	var check_4 lisette.Result[int, error]
	if ret_2 != nil {
		check_4 = lisette.MakeResultErr[int, error](ret_2)
	} else {
		check_4 = lisette.MakeResultOk[int, error](ret_1)
	}
	if check_4.Tag != lisette.ResultOk {
		return *new(int), check_4.ErrVal
	}
	return add(check_4.OkVal, side()), nil
}
