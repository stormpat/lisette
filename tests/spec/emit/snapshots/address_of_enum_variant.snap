---
source: tests/spec/emit/expressions.rs
description: |
  
  enum List {
    Cons(int, Ref<List>),
    Nil,
  }
  
  fn test() -> List {
    List.Cons(42, &List.Nil)
  }
---
package main

func MakeListCons(arg0 int, arg1 *List) List {
	return List{Tag: ListCons, Cons0: arg0, Cons1: arg1}
}

func MakeListNil() List {
	return List{Tag: ListNil}
}

type ListTag int

const (
	ListCons ListTag = iota
	ListNil
)

type List struct {
	Tag   ListTag
	Cons0 int
	Cons1 *List
}

func test() List {
	ref_1 := MakeListNil()
	return MakeListCons(42, &ref_1)
}
