---
source: tests/spec/emit/expressions.rs
description: |
  
  fn takes_two(a: int, b: Ref<int>) -> int { a + b.* }
  fn make_int() -> int { 2 }
  
  fn test() -> int {
    takes_two(1, &make_int())
  }
---
package main

func takes_two(a int, b *int) int {
	return a + *b
}

func make_int() int {
	return 2
}

func test() int {
	ref_1 := make_int()
	return takes_two(1, &ref_1)
}
