---
source: tests/spec/emit/result_option_patterns.rs
description: |
  
  import "go:errors"
  
  fn fail_unit() -> Result<(), error> {
    Err(errors.New("boom"))?
    Ok(())
  }
  
  fn main() {
    let _ = fail_unit()
  }
---
package main

import "errors"

func fail_unit() error {
	return errors.New("boom")
}

func main() {
	fail_unit()
}
