description: |
  
  fn test(opt: Option<int>) {
    if let Some(x) = opt {
      let y = x + 1;
    }
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func test(opt lisette.Option[int]) {
	if opt.Tag == lisette.OptionSome {
		_ = opt.SomeVal + 1
	}
}
