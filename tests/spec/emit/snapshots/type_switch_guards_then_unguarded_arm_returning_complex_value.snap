---
source: tests/spec/emit/patterns.rs
description: "input: \nimport \"go:example.com/events\"\n\nfn handle(e: events.Event) -> Option<int> {\n  match e {\n    events.Click { x } if x > 100 => Some(x * 10),\n    events.Click { x } if x > 0 => Some(x),\n    events.Click { x } => Some(-x),\n    _ => None,\n  }\n}\n"
---
package main

import "example.com/events"

func handle(e events.Event) (int, bool) {
	subject_1 := e
	switch subject_1 := subject_1.(type) {
	case events.Click:
		x := subject_1.X
		if x > 100 {
			return x * 10, true
		}
		x_2 := subject_1.X
		if x_2 > 0 {
			return x_2, true
		}
		return -subject_1.X, true
	default:
		return *new(int), false
	}
}
