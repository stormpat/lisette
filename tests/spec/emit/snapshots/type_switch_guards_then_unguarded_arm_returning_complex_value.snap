---
source: tests/spec/emit/patterns.rs
description: |
  
  import "go:example.com/events"
  
  fn handle(e: events.Event) -> Option<int> {
    match e {
      events.Click { x } if x > 100 => Some(x * 10),
      events.Click { x } if x > 0 => Some(x),
      events.Click { x } => Some(-x),
      _ => None,
    }
  }
---
package main

import "example.com/events"

func handle(e events.Event) (int, bool) {
	subject_1 := e
	switch subject_1 := subject_1.(type) {
	case events.Click:
		x := subject_1.X
		if x > 100 {
			return x * 10, true
		}
		x_2 := subject_1.X
		if x_2 > 0 {
			return x_2, true
		}
		return -subject_1.X, true
	default:
		return *new(int), false
	}
}
