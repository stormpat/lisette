---
source: tests/spec/emit/expressions.rs
description: |
  
  const BASE = 10
  
  fn eff(x: Ref<int>) -> int {
    x.* = 1
    2
  }
  
  fn run() -> int {
    let mut i = 0
    let r = [BASE, eff(&i)]
    r[0] + r[1]
