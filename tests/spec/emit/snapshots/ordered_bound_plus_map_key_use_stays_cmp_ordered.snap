description: "input: \nfn count<T: Ordered>(x: T) -> int {\n  let mut m: Map<T, int> = Map.new()\n  m[x] = 1\n  m.length()\n}\n\nfn main() {\n  let _ = count(1)\n}\n"
---
package main

import "cmp"

func count[T cmp.Ordered](x T) int {
	m := make(map[T]int)
	m[x] = 1
	return len(m)
}

func main() {
	_ = count(1)
}
