source: tests/spec/emit/types.rs
description: |
  
  fn count<T: Ordered>(x: T) -> int {
    let mut m: Map<T, int> = Map.new()
    m[x] = 1
    m.length()
  }
  
  fn main() {
    let _ = count(1)
  }
---
package main

import "cmp"

func count[T cmp.Ordered](x T) int {
	m := make(map[T]int)
	m[x] = 1
	return len(m)
}

func main() {
	_ = count(1)
}
