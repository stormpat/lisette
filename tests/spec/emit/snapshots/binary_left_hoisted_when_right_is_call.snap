---
source: tests/spec/emit/expressions.rs
description: |
  
  fn bump(i: Ref<int>) -> int {
    i.* = 1
    10
  }
  
  fn main() {
    let mut i = 0
    let z = i + bump(&i)
    let _ = z
  }
---
package main

func bump(i *int) int {
	*i = 1
	return 10
}

func main() {
	i := 0
	z := i + bump(&i)
	_ = z
}
