package main

func MakeStatusReady() Status {
	return Status{Tag: StatusReady}
}

type StatusTag int

const (
	StatusReady StatusTag = iota
)

type Status struct {
	Tag StatusTag
}

func (s Status) MarshalJSON() ([]byte, error) {
	return ([]byte)(nil), nil
}
