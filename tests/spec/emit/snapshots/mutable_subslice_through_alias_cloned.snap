---
source: tests/spec/emit/types.rs
description: "input: \ntype Numbers = Slice<int>\n\nfn test() {\n  let xs: Numbers = [1, 2, 3]\n  let mut part = xs[0..2]\n  part[0] = 99\n  let _ = xs\n}\n"
---
package main

import "slices"

type Numbers = []int

func test() {
	xs := []int{1, 2, 3}
	part := slices.Clone(xs[0:2:2])
	part[0] = 99
	_ = xs
}
