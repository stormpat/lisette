---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Item { x: int }
  
  fn get() -> Ref<Item> { &Item { x: 0 } }
  
  fn main() {
    get().x = 1
  }
---
package main

type Item struct {
	x int
}

func get() *Item {
	return &Item{x: 0}
}

func main() {
	ref_1 := get()
	ref_1.x = 1
}
