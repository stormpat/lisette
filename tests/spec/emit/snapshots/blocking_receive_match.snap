---
source: tests/spec/emit/concurrency.rs
description: |
  
  fn test() -> int {
    let ch = Channel.new<int>();
    match ch.receive() {
      Some(v) => v,
      None => 0,
    }
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func test() int {
	ch := make(chan int)
	subject_1 := lisette.ChannelReceive(ch)
	if subject_1.Tag == lisette.OptionSome {
		return subject_1.SomeVal
	}
	return 0
}
