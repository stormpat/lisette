---
package main

import "example.com/shapes"

func sum(items []shapes.Shape) int {
	total := 0
	for _, item_1 := range items {
		asserted_2 := item_1.(shapes.Rect)
		w := asserted_2.W
		h := asserted_2.H
		total += w * h
	}
	return total
}
