---
source: tests/spec/emit/control_flow.rs
description: "input: \nimport \"go:fmt\"\n\nfn test() {\n  let result: Result<int, string> = Ok(42);\n  match result {\n    Ok(n) => fmt.Print(f\"success: {n}\\n\"),\n    Err(e) => fmt.Print(f\"error: {e}\\n\"),\n  }\n  fmt.Print(\"done\\n\");\n}\n"
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
)

func test() {
	result := lisette.MakeResultOk[int, string](42)
	if result.Tag == lisette.ResultOk {
		n := result.OkVal
		fmt.Printf("success: %d\n", n)
	} else {
		e := result.ErrVal
		fmt.Printf("error: %s\n", e)
	}
	fmt.Print("done\n")
}
