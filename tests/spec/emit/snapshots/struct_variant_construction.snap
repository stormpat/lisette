---
source: tests/spec/emit/patterns.rs
description: "input: \nenum Message {\n  Move { x: int, y: int },\n}\n\nfn make_move() -> Message {\n  Move { x: 10, y: 20 }\n}\n"
---
package main

import "fmt"

func MakeMessageMove(arg0 int, arg1 int) Message {
	return Message{Tag: MessageMove, X: arg0, Y: arg1}
}

type MessageTag int

const (
	MessageMove MessageTag = iota
)

type Message struct {
	Tag MessageTag
	X   int
	Y   int
}

func (m Message) String() string {
	switch m.Tag {
	case MessageMove:
		return fmt.Sprintf("Move { x: %v, y: %v }", m.X, m.Y)
	default:
		return fmt.Sprintf("Message(%d)", m.Tag)
	}
}

func (m Message) GoString() string {
	switch m.Tag {
	case MessageMove:
		return fmt.Sprintf("Message.Move { x: %v, y: %v }", m.X, m.Y)
	default:
		return fmt.Sprintf("Message(%d)", m.Tag)
	}
}

func make_move() Message {
	return Message{
		Tag: MessageMove,
		X:   10,
		Y:   20,
	}
}
