---
source: tests/spec/emit/expressions.rs
description: |
  
  import "go:fmt"
  
  struct S { x: int }
  
  fn get() -> Ref<S> {
    let _ = fmt.Println("get")
    let mut s = S { x: 1 }
    &s
  }
  
  fn arg() -> int { let _ = fmt.Println("arg"); 2 }
  
  fn main() {
    get().x = if arg() > 0 { 3 } else { 4 }
  }
---
package main

import "fmt"

type S struct {
	x int
}

func get() *S {
	fmt.Println("get")
	s := S{x: 1}
	return &s
}

func arg() int {
	fmt.Println("arg")
	return 2
}

func main() {
	ref_2 := get()
	var tmp_1 int
	if arg() > 0 {
		tmp_1 = 3
	} else {
		tmp_1 = 4
	}
	ref_2.x = tmp_1
}
