---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Inner { x: int }
  struct Wrap(Inner)
  
  fn main() {
    let mut w = Wrap(Inner { x: 0 })
    let mut m = Map.new<string, Ref<Wrap>>()
    m["a"] = &w
    let Some(r) = m.get("a") else { return; };
    let mut inner = r.0
    inner.x = 1
    r.* = Wrap(inner)
    let _ = w
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

type Inner struct {
	x int
}

type Wrap Inner

func main() {
	w := Wrap(Inner{x: 0})
	m := make(map[string]*Wrap)
	m["a"] = &w
	subject_1 := lisette.MapGet(m, "a")
	if subject_1.Tag != lisette.OptionSome {
		return
	}
	r := subject_1.SomeVal
	inner := Inner(*r)
	inner.x = 1
	*r = Wrap(inner)
	_ = w
}
