---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Inner { x: int }
  struct Wrap(Inner)
  
  fn main() {
    let mut w = Wrap(Inner { x: 0 })
    let mut m = Map.new<string, Ref<Wrap>>()
    m["a"] = &w
    let mut inner = m["a"].0
    inner.x = 1
    m["a"].* = Wrap(inner)
    let _ = w
  }
---
package main

type Inner struct {
	x int
}

type Wrap Inner

func main() {
	w := Wrap(Inner{x: 0})
	m := make(map[string]*Wrap)
	m["a"] = &w
	inner := Inner(*m["a"])
	inner.x = 1
	*m["a"] = Wrap(inner)
	_ = w
}
