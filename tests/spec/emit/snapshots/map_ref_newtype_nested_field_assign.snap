---
source: tests/spec/emit/expressions.rs
description: "input: \nstruct Inner { x: int }\nstruct Wrap(Inner)\n\nfn main() {\n  let mut w = Wrap(Inner { x: 0 })\n  let mut m = Map.new<string, Ref<Wrap>>()\n  m[\"a\"] = &w\n  let mut inner = m[\"a\"].0\n  inner.x = 1\n  m[\"a\"].* = Wrap(inner)\n  let _ = w\n}\n"
---
package main

type Inner struct {
	x int
}

type Wrap Inner

func main() {
	w := Wrap(Inner{x: 0})
	m := make(map[string]*Wrap)
	m["a"] = &w
	inner := Inner(*m["a"])
	inner.x = 1
	*m["a"] = Wrap(inner)
	_ = w
}
