---
source: tests/spec/emit/patterns.rs
description: |
  
  import "go:example.com/events"
  
  fn handle(e: events.Event, threshold: int) -> int {
    match e {
      events.Click { x } if x > threshold => x,
      events.Click { x } => x + 1,
      _ => 0,
    }
  }
---
package main

import "example.com/events"

func handle(e events.Event, threshold int) int {
	subject_1 := e
	switch subject_1 := subject_1.(type) {
	case events.Click:
		x := subject_1.X
		if x > threshold {
			return x
		}
		return subject_1.X + 1
	default:
		return 0
	}
}
