---
source: tests/spec/emit/go_interface_adapter.rs
description: "input: \nimport \"go:example.com/svc\"\n\nstruct Loader {}\n\nimpl Loader {\n  fn Load(self, key: string) -> Result<int, error> {\n    Ok(1)\n  }\n}\n\nfn run(s: svc.Alias) -> int {\n  match s.Load(\"k\") {\n    Ok(n) => n,\n    Err(_) => 0,\n  }\n}\n\nfn main() {\n  let l = Loader {}\n  let _ = run(l as svc.Alias)\n}\n"
---
package main

import (
	"example.com/svc"
	lisette "github.com/ivov/lisette/prelude"
)

type Loader struct{}

func (l Loader) Load(_ string) (int, error) {
	return 1, nil
}

func run(s svc.Alias) int {
	ret_2, ret_3 := s.Load("k")
	var result_4 lisette.Result[int, error]
	if ret_3 != nil {
		result_4 = lisette.MakeResultErr[int, error](ret_3)
	} else {
		result_4 = lisette.MakeResultOk[int, error](ret_2)
	}
	subject_1 := result_4
	if subject_1.Tag == lisette.ResultOk {
		return subject_1.OkVal
	}
	return 0
}

func main() {
	l := Loader{}
	_ = run(l)
}
