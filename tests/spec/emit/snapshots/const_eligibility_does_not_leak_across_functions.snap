description: "input: \nimport \"go:fmt\"\n\nfn make() -> int {\n  2\n}\n\nfn a() {\n  const X = 1\n  fmt.Println(X)\n}\n\nfn main() {\n  a()\n  let x = make()\n  const Y = x\n  fmt.Println(Y)\n}\n"
---
package main

import "fmt"

func make_() int {
	return 2
}

func a() {
	const X int = 1
	fmt.Println(X)
}

func main() {
	a()
	x := make_()
	var Y int = x
	fmt.Println(Y)
}
