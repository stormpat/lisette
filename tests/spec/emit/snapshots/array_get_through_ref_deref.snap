---
source: tests/spec/emit/arrays.rs
description: |
  
  fn at(a: Ref<Array<int, 3>>, i: int) -> Option<int> {
    a.get(i)
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func at(a *[3]int, i int) (int, bool) {
	v_1 := lisette.SliceGet((*a)[:], i)
	if v_1.Tag == lisette.OptionSome {
		return v_1.SomeVal, true
	}
	return 0, false
}
