---
source: tests/spec/emit/result_option_patterns.rs
description: |
  
  import "go:errors"
  
  fn fallible(ok: bool) -> Result<int, error> {
    if ok { Ok(1) } else { Err(errors.New("nope")) }
  }
  
  fn test() {
    match fallible(true) {
      Ok(x) => { let _ = x },
      Err(e) => {},
    }
  }
---
package main

import "errors"

func fallible(ok bool) (int, error) {
	if ok {
		return 1, nil
	}
	return 0, errors.New("nope")
}

func test() {
	ret_1, ret_2 := fallible(true)
	if ret_2 == nil {
		x := ret_1
		_ = x
	} else {
		e := ret_2
		_ = e
	}
}
