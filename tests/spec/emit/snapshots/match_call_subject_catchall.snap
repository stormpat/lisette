---
source: tests/spec/emit/control_flow.rs
description: |
  
  struct Point { x: int, y: int }
  
  fn make_point() -> Point {
    Point { x: 1, y: 2 }
  }
  
  fn test() -> int {
    match make_point() {
      Point { .. } => 1,
    }
  }
---
package main

type Point struct {
	x int
	y int
}

func make_point() Point {
	return Point{
		x: 1,
		y: 2,
	}
}

func test() int {
	_ = make_point()
	return 1
}
