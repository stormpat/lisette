---
source: tests/spec/emit/concurrency.rs
description: |
  
  import "go:fmt"
  
  struct Point { x: int }
  
  fn main() {
    let ch1 = Channel.buffered<Point>(1)
    let x = 99
  
    let result = select {
      let Some(Point { x }) = ch1.receive() => x,
      _ => x,
    }
  
    fmt.Println(result)
  }
---
package main

import "fmt"

type Point struct {
	x int
}

func main() {
	ch1 := make(chan Point, 1)
	x := 99
	var result int
	ch_1 := ch1
	for {
		select {
		case recv_2, ok := <-ch_1:
			if ok {
				result = recv_2.x
			} else {
				ch_1 = nil
				continue
			}
		default:
			result = x
		}
		break
	}
	fmt.Println(result)
}
