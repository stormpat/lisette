---
source: tests/spec/emit/concurrency.rs
description: "input: \nimport \"go:fmt\"\n\nstruct Point { x: int }\n\nfn main() {\n  let ch1 = Channel.buffered<Point>(1)\n  let x = 99\n\n  let result = select {\n    let Some(Point { x }) = ch1.receive() => x,\n    _ => x,\n  }\n\n  fmt.Println(result)\n}\n"
---
package main

import "fmt"

type Point struct {
	x int
}

func (p Point) String() string {
	return fmt.Sprintf("Point { x: %v }", p.x)
}

func main() {
	ch1 := make(chan Point, 1)
	x := 99
	var result int
	ch_1 := ch1
	for {
		select {
		case recv_2, ok := <-ch_1:
			if ok {
				result = recv_2.x
			} else {
				ch_1 = nil
				continue
			}
		default:
			result = x
		}
		break
	}
	fmt.Println(result)
}
