---
source: tests/spec/emit/recover.rs
description: |
  
  fn may_panic() -> int { 42 }
  
  fn test() -> Result<int, PanicValue> {
    recover { may_panic() }
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func may_panic() int {
	return 42
}

func test() lisette.Result[int, lisette.PanicValue] {
	recoverResult_1 := lisette.RecoverBlock(func() int {
		return may_panic()
	})
	return recoverResult_1
}
