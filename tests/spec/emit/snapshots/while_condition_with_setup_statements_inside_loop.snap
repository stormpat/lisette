---
source: tests/spec/emit/control_flow.rs
description: |
  
  fn bump(i: Ref<int>) -> int {
    i.* = i.* + 1
    i.*
  }
  fn test() {
    let mut i = 0
    while (i < 3, bump(&i)).0 {
      let _ = i
    }
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func bump(i *int) int {
	*i++
	return *i
}

func test() {
	i := 0
	for lisette.MakeTuple2(i < 3, bump(&i)).First {
		_ = i
	}
}
