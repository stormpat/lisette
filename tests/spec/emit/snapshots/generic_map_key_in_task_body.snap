---
source: tests/spec/emit/functions.rs
description: |
  
  fn use_map_in_task<K, V>(key: K, value: V) {
    task {
      let mut m: Map<K, V> = Map.new()
      m[key] = value
    }
  }
---
package main

func use_map_in_task[K comparable, V any](key K, value V) {
	go func() {
		m := make(map[K]V)
		m[key] = value
	}()
}
