---
source: tests/spec/emit/expressions.rs
description: "input: \nstruct Config {\n  range: int,\n  name: string,\n}\n\nfn test() {\n    let mut m = Map.new<string, Config>()\n    m[\"a\"] = Config { range: 10, name: \"first\" }\n    let mut entry = m[\"a\"]\n    entry.range = 20\n    m[\"a\"] = entry\n}\n"
---
package main

type Config struct {
	range_ int
	name   string
}

func test() {
	m := make(map[string]Config)
	m["a"] = Config{
		range_: 10,
		name:   "first",
	}
	entry := m["a"]
	entry.range_ = 20
	m["a"] = entry
}
