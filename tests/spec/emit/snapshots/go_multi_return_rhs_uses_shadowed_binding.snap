---
source: tests/spec/emit/functions.rs
description: |
  
  import "go:math"
  
  fn main() {
    let x = 1.25
    let (x, y) = math.Modf(x)
    let _ = (x, y)
  }
---
package main

import (
	lisette "github.com/ivov/lisette/prelude"
	"math"
)

func main() {
	x := 1.25
	x_1, y := math.Modf(x)
	_ = lisette.MakeTuple2(x_1, y)
}
