---
source: tests/spec/emit/result_option_patterns.rs
description: |
  
  fn test(flag: bool) -> Result<int, string> {
    let result = if flag { Ok(42) } else { Err("nope") };
    result
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func test(flag bool) lisette.Result[int, string] {
	var result lisette.Result[int, string]
	if flag {
		result = lisette.MakeResultOk[int, string](42)
	} else {
		result = lisette.MakeResultErr[int, string]("nope")
	}
	return result
}
