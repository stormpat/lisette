---
source: tests/spec/emit/types.rs
description: |
  
  pub interface Printable {
    fn display(self) -> string
  }
  
  struct Box {
    value: string,
  }
  
  impl Box {
    fn display(self) -> string {
      self.value
    }
  }
  
  fn describe(p: Printable) -> string {
    p.display()
  }
---
package main

type Printable interface {
	Display() string
}

type Box struct {
	value string
}

func (b Box) Display() string {
	return b.value
}

func describe(p Printable) string {
	return p.Display()
}
