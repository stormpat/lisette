---
source: tests/spec/emit/result_option_patterns.rs
description: |
  
  fn test() -> Result<(), string> {
    try {
      let _ = Ok(1)?
      let o = Some(1)
      while let Some(_v) = o {
        break
      }
    }
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func test() lisette.Result[struct{}, string] {
	tryResult_1 := func() lisette.Result[struct{}, string] {
		check_2 := lisette.MakeResultOk[int, string](1)
		if check_2.Tag != lisette.ResultOk {
			return lisette.MakeResultErr[struct{}, string](check_2.ErrVal)
		}
		o := lisette.MakeOptionSome(1)
		for {
			if o.Tag == lisette.OptionSome {
				break
			} else {
				break
			}
		}
		return lisette.MakeResultOk[struct{}, string](struct{}{})
	}()
	return tryResult_1
}
