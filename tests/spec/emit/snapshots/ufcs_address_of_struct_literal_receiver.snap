---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Counter { x: int }
  
  impl Counter {
    fn inc(self: Ref<Counter>) -> int {
      self.x = self.x + 1
      self.x
    }
  }
  
  fn main() {
    let _ = Counter.inc(&Counter { x: 0 })
  }
---
package main

type Counter struct {
	x int
}

func (c *Counter) inc() int {
	c.x++
	return c.x
}

func main() {
	_ = (&Counter{x: 0}).inc()
}
