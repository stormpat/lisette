package main

import (
	"example.com/dyn"
	lisette "github.com/ivov/lisette/prelude"
)

func main() {
	_ = dyn.Store("k", nil)
	opt_1 := lisette.MakeOptionSome(1)
	var unwrap_2 any
	if opt_1.Tag == lisette.OptionSome {
		unwrap_2 = opt_1.SomeVal
	}
	_ = dyn.Store("k", unwrap_2)
}
