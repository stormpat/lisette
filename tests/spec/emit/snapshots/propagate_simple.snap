---
source: tests/spec/emit/expressions.rs
description: "input: \nfn might_fail() -> Result<int, string> {\n  Ok(42)\n}\n\nfn get_value() -> Result<int, string> {\n  let result = might_fail()?;\n  Ok(result)\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func might_fail() lisette.Result[int, string] {
	return lisette.MakeResultOk[int, string](42)
}

func get_value() lisette.Result[int, string] {
	check_1 := might_fail()
	if check_1.Tag != lisette.ResultOk {
		return lisette.MakeResultErr[int, string](check_1.ErrVal)
	}
	return lisette.MakeResultOk[int, string](check_1.OkVal)
}
