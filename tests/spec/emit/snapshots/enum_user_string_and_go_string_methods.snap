---
source: tests/spec/emit/types.rs
description: "input: \nenum Color {\n  Red,\n  Blue,\n}\n\nimpl Color {\n  pub fn string(self) -> string {\n    \"custom display\"\n  }\n\n  pub fn goString(self) -> string {\n    \"custom debug\"\n  }\n}\n\nfn main() {\n  let c = Color.Red\n  let _ = c\n}\n"
---
package main

func MakeColorRed() Color {
	return Color{Tag: ColorRed}
}

func MakeColorBlue() Color {
	return Color{Tag: ColorBlue}
}

type ColorTag int

const (
	ColorRed ColorTag = iota
	ColorBlue
)

type Color struct {
	Tag ColorTag
}

func (c Color) String() string {
	return "custom display"
}

func (c Color) GoString() string {
	return "custom debug"
}

func main() {
	_ = MakeColorRed()
}
