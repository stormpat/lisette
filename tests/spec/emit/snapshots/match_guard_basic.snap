---
source: tests/spec/emit/control_flow.rs
description: |
  
  fn test(opt: Option<int>) -> string {
    match opt {
      Some(x) if x > 0 => "positive",
      Some(x) if x < 0 => "negative",
      Some(_) => "zero",
      None => "none",
    }
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func test(opt lisette.Option[int]) string {
	subject_1 := opt
	if subject_1.Tag == lisette.OptionSome {
		x := subject_1.SomeVal
		if x > 0 {
			return "positive"
		}
		if x < 0 {
			return "negative"
		}
		return "zero"
	}
	return "none"
}
