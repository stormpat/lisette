---
package main

import (
	"example.com/scheduler"
	lisette "github.com/ivov/lisette/prelude"
)

func main() {
	raw_1 := scheduler.MakeCmd()
	cmd := lisette.OptionFromNilable[scheduler.Cmd](raw_1, raw_1 == nil)
	if cmd.Tag == lisette.OptionSome {
		_ = cmd.SomeVal
	}
}
