---
source: tests/spec/emit/control_flow.rs
description: |
  
  struct P { v: int }
  fn test() -> int {
    let opt = Some(1)
    let result = opt.map(|x| {
      let p = P { v: x }
      match p {
        P { v } => (),
      }
      1
    })
    match result {
      Some(x) => x,
      None => 0,
    }
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

type P struct {
	v int
}

func test() int {
	opt := lisette.MakeOptionSome(1)
	result := lisette.OptionMap(opt, func(x int) int {
		p := P{v: x}
		_ = p
		return 1
	})
	if result.Tag == lisette.OptionSome {
		return result.SomeVal
	}
	return 0
}
