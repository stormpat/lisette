---
source: tests/spec/emit/patterns.rs
description: |
  
  import "go:fmt"
  
  struct Point { x: int, y: int }
  
  fn test(p: Point) -> int {
    let result = match p {
      Point { x, .. } as fmt => fmt.x + x,
    }
    fmt.Println(result)
    result
  }
---
package main

import "fmt"

type Point struct {
	x int
	y int
}

func test(p Point) int {
	var result int
	result = p.x + p.x
	fmt.Println(result)
	return result
}
