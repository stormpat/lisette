---
source: tests/spec/emit/patterns.rs
description: "input: \nimport \"go:fmt\"\n\nstruct Point { x: int, y: int }\n\nfn test(p: Point) -> int {\n  let result = match p {\n    Point { x, .. } as fmt => fmt.x + x,\n  }\n  fmt.Println(result)\n  result\n}\n"
---
package main

import "fmt"

type Point struct {
	x int
	y int
}

func (p Point) String() string {
	return fmt.Sprintf("Point { x: %v, y: %v }", p.x, p.y)
}

func test(p Point) int {
	var result int
	{
		x := p.x
		fmt := p
		result = fmt.x + x
	}
	fmt.Println(result)
	return result
}
