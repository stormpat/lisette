---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Inner { x: int }
  struct A(Inner)
  struct B(A)
  
  fn main() {
    let mut m = Map.new<string, B>()
    m["k"] = B(A(Inner { x: 1 }))
    let mut inner = m["k"].0.0
    inner.x = 2
    m["k"] = B(A(inner))
  }
---
package main

type Inner struct {
	x int
}

type A Inner

type B A

func main() {
	m := make(map[string]B)
	m["k"] = B(A(Inner{x: 1}))
	inner := Inner(A(m["k"]))
	inner.x = 2
	m["k"] = B(A(inner))
}
