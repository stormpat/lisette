---
source: tests/spec/emit/types.rs
description: |
  
  struct Point { pub x: int, pub y: int }
  
  type Location = Point
  type GeoPoint = Location
  
  fn origin() -> GeoPoint {
    Point { x: 0, y: 0 }
  }
---
package main

type Point struct {
	X int
	Y int
}

type Location = Point

type GeoPoint = Location

func origin() GeoPoint {
	return Point{
		X: 0,
		Y: 0,
	}
}
