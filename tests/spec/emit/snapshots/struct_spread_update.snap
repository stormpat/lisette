---
source: tests/spec/emit/types.rs
description: |
  
  struct Point { x: int, y: int }
  
  fn test() -> Point {
    let p = Point { x: 1, y: 2 };
    Point { x: 10, ..p }
  }
---
package main

type Point struct {
	x int
	y int
}

func test() Point {
	p := Point{
		x: 1,
		y: 2,
	}
	copy_1 := p
	copy_1.x = 10
	return copy_1
}
