package main

import lisette "github.com/ivov/lisette/prelude"

func opts() [2]lisette.Option[int] {
	return func() [2]lisette.Option[int] {
		var arr [2]lisette.Option[int]
		for i := range arr {
			arr[i] = lisette.MakeOptionNone[int]()
		}
		return arr
	}()
}
