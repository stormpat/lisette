---
source: tests/spec/emit/concurrency.rs
description: |
  
  fn get_ch() -> Channel<int> {
    Channel.buffered<int>(1)
  }
  
  fn main() -> int {
    let result = select {
      let Some(v) = get_ch().receive() => v,
      _ => 0,
    }
    let tmp_1 = result + 1
    tmp_1
  }
---
package main

func get_ch() chan int {
	return make(chan int, 1)
}

func main() int {
	var result int
	ch_1 := get_ch()
	for {
		select {
		case v, ok := <-ch_1:
			if ok {
				result = v
			} else {
				ch_1 = nil
				continue
			}
		default:
			result = 0
		}
		break
	}
	tmp_1 := result + 1
	return tmp_1
}
