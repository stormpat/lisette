source: tests/spec/emit/functions.rs
description: "input: \nimport \"go:fmt\"\nimport \"go:strconv\"\n\nfn main() {\n  let r = (strconv.Atoi)(\"42\")\n  fmt.Println(r)\n}\n"
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
	"strconv"
)

func main() {
	ret_1, ret_2 := strconv.Atoi("42")
	var r lisette.Result[int, error]
	if ret_2 != nil {
		r = lisette.MakeResultErr[int, error](ret_2)
	} else {
		r = lisette.MakeResultOk[int, error](ret_1)
	}
	fmt.Println(r)
}
