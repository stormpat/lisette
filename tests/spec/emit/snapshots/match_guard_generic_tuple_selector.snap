---
source: tests/spec/emit/control_flow.rs
description: |
  
  struct W<T>(T)
  
  fn test() -> int {
    match 1 {
      n if W(1).0 == 1 => n,
      _ => 0,
    }
  }
---
package main

type W[T any] struct {
	F0 T
}

func test() int {
	{
		n := 1
		if (W[int]{F0: 1}).F0 == 1 {
			return n
		}
	}
	{
		return 0
	}
}
