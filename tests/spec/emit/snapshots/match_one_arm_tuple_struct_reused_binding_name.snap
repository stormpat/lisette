---
source: tests/spec/emit/patterns.rs
description: "input: \nstruct Pair(int, int)\nstruct Name(string)\n\nfn test() -> string {\n  let p = Pair(1, 2);\n  let a = match p {\n    Pair(x, y) => x + y,\n  };\n\n  let n = Name(\"hello\");\n  let b = match n {\n    Name(x) => x,\n  };\n\n  b\n}\n"
---
package main

type Pair struct {
	F0 int
	F1 int
}

type Name string

func test() string {
	p := Pair{
		F0: 1,
		F1: 2,
	}
	_ = p.F0 + p.F1
	n := Name("hello")
	var b string
	b = string(n)
	return b
}
