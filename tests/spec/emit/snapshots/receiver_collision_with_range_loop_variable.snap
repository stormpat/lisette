description: |
  
  import "go:fmt"
  
  struct IntList {
    items: Slice<int>,
  }
  
  impl IntList {
    fn display(self) -> string {
      let mut s = "["
      for i in 0..self.items.length() {
        if i > 0 {
          s = s + ", "
        }
        let item = self.items[i]
        s = s + f"{item}"
      }
      s + "]"
    }
  }
  
  fn main() {
    let list = IntList { items: [1, 2, 3] }
    fmt.Println(list.display())
  }
---
package main

import "fmt"

type IntList struct {
	items []int
}

func (i IntList) display() string {
	s := "["
	_bound_1 := len(i.items)
	for i_2 := 0; i_2 < _bound_1; i_2++ {
		if i_2 > 0 {
			s += ", "
		}
		item := i.items[i_2]
		s += fmt.Sprint(item)
	}
	return s + "]"
}

func main() {
	list := IntList{items: []int{1, 2, 3}}
	fmt.Println(list.display())
}
