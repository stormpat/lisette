source: tests/spec/emit/types.rs
description: "input: \nenum Marker {\n  Value,\n}\n\nfn test() -> Marker {\n  Marker.Value\n}\n"
---
package main

import "fmt"

func MakeMarkerValue() Marker {
	return Marker{Tag: MarkerValue}
}

type MarkerTag int

const (
	MarkerValue MarkerTag = iota
)

type Marker struct {
	Tag MarkerTag
}

func (m Marker) String() string {
	switch m.Tag {
	case MarkerValue:
		return "Value"
	default:
		return fmt.Sprintf("Marker(%d)", m.Tag)
	}
}

func (m Marker) GoString() string {
	switch m.Tag {
	case MarkerValue:
		return "Marker.Value"
	default:
		return fmt.Sprintf("Marker(%d)", m.Tag)
	}
}

func test() Marker {
	return MakeMarkerValue()
}
