---
source: tests/spec/emit/patterns.rs
description: |
  
  struct Point { x: int }
  
  fn make() -> Point {
    Point { x: 1 }
  }
  
  fn test() -> string {
    match make() {
      _ => "subject_1",
    }
  }
---
package main

type Point struct {
	x int
}

func make_() Point {
	return Point{x: 1}
}

func test() string {
	_ = make_()
	return "subject_1"
}
