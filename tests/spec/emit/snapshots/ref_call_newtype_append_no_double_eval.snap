description: "input: \nimport \"go:fmt\"\n\nstruct Wrap(Slice<int>)\n\nfn get() -> Ref<Wrap> {\n  let _ = fmt.Println(\"get\")\n  let mut w = Wrap([1])\n  &w\n}\n\nfn main() {\n  get().0.append(2)\n}\n"
---
package main

import "fmt"

type Wrap []int

func get() *Wrap {
	fmt.Println("get")
	w := Wrap([]int{1})
	return &w
}

func main() {
	_ = append([]int(*get()), 2)
}
