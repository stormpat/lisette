package main

import "fmt"

type Foo struct {
	x int
}

func (f Foo) String() string {
	return fmt.Sprintf("Foo { x: %v }", f.x)
}

func main() {
	items := []Foo{Foo{x: 1}, Foo{x: 2}}
	for range items {
	}
}
