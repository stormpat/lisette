---
source: tests/spec/emit/result_option_patterns.rs
description: "input: \nfn f() -> Result<int, string> {\n  Err(\"e\")?\n}\n\nfn test() -> Result<int, string> {\n  f()\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func f() lisette.Result[int, string] {
	check_1 := lisette.MakeResultErr[lisette.Result[int, string], string]("e")
	if check_1.Tag != lisette.ResultOk {
		return lisette.MakeResultErr[int, string](check_1.ErrVal)
	}
	return check_1.OkVal
}

func test() lisette.Result[int, string] {
	return f()
}
