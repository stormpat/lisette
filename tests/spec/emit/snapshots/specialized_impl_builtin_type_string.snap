---
source: tests/spec/emit/types.rs
description: |
  
  struct Wrapper<T> {
    value: T,
  }
  
  impl Wrapper<string> {
    fn greet(self) -> string {
      "hello"
    }
  }
  
  fn test() -> string {
    let w = Wrapper { value: "world" };
    w.greet()
  }
---
package main

type Wrapper[T any] struct {
	value T
}

func Wrapper_greet(_ Wrapper[string]) string {
	return "hello"
}

func test() string {
	w := Wrapper[string]{value: "world"}
	return Wrapper_greet(w)
}
