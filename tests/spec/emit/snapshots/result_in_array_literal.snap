---
source: tests/spec/emit/result_option_patterns.rs
description: "input: \nfn try_value(x: int) -> Result<int, string> {\n  if x > 0 { Ok(x) } else { Err(\"negative\") }\n}\n\nfn test() {\n  let arr = [try_value(1), try_value(-1), try_value(3)];\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func try_value(x int) lisette.Result[int, string] {
	var tmp_1 lisette.Result[int, string]
	if x > 0 {
		tmp_1 = lisette.MakeResultOk[int, string](x)
	} else {
		tmp_1 = lisette.MakeResultErr[int, string]("negative")
	}
	return tmp_1
}

func test() {
	_ = []lisette.Result[int, string]{try_value(1), try_value(-1), try_value(3)}
}
