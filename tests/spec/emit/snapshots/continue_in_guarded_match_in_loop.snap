---
source: tests/spec/emit/control_flow.rs
description: |
  
  fn sum_positives(items: Slice<int>) -> int {
    let mut sum = 0
    for item in items {
      match item {
        n if n > 0 => sum += n,
        _ => continue,
      }
    }
    sum
  }
---
package main

func sum_positives(items []int) int {
	sum := 0
loop_1:
	for _, item := range items {
		subject_1 := item
	match_2:
		for {
			{
				n := subject_1
				if n > 0 {
					sum += n
					break match_2
				}
			}
			{
				continue loop_1
			}
		}
	}
	return sum
}
