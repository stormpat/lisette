---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Inner { x: int }
  struct Wrap(Inner)
  
  fn main() {
    let mut m = Map.new<string, Wrap>()
    m["a"] = Wrap(Inner { x: 1 })
    let mut inner = m["a"].0
    inner.x = 2
    m["a"] = Wrap(inner)
  }
---
package main

type Inner struct {
	x int
}

type Wrap Inner

func main() {
	m := make(map[string]Wrap)
	m["a"] = Wrap(Inner{x: 1})
	inner := Inner(m["a"])
	inner.x = 2
	m["a"] = Wrap(inner)
}
