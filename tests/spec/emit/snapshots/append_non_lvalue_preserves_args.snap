---
source: tests/spec/emit/expressions.rs
description: |
  
  import "go:fmt"
  
  fn get() -> Slice<int> { [1] }
  fn arg() -> int { let _ = fmt.Println(1); 2 }
  
  fn main() {
    get().append(arg())
  }
---
package main

import "fmt"

func get() []int {
	return []int{1}
}

func arg() int {
	fmt.Println(1)
	return 2
}

func main() {
	recv_1 := get()
	_ = append(recv_1[:len(recv_1):len(recv_1)], arg())
}
