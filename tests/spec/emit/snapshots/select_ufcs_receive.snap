---
source: tests/spec/emit/concurrency.rs
description: "\nfn main() {\n  let ch = Channel.new<int>()\n  select {\n    let Some(value) = Channel.receive(ch) => { let _ = value },\n    _ => {},\n  }\n}\n"
---
package main

func main() {
	ch := make(chan int)
	ch_1 := ch
	for {
		select {
		case value, ok := <-ch_1:
			if ok {
				_ = value
			} else {
				ch_1 = nil
				continue
			}
		default:
		}
		break
	}
}
