package main

type Cloner[T any] interface {
	Clone() T
}

type Foo struct{}

func (f Foo) Clone() Foo {
	return Foo{}
}

func squiggle[A Cloner[B], B any](_ A, _ B) {}

func main() {
	squiggle(Foo{}, Foo{})
}
