package main

import (
	"flag"
	lisette "github.com/ivov/lisette/prelude"
)

func main() {
	raw_1 := flag.Lookup("verbose")
	r := lisette.OptionFromNilable[*flag.Flag](raw_1, raw_1 == nil)
	if r.Tag == lisette.OptionSome {
		_ = r.SomeVal
	}
}
