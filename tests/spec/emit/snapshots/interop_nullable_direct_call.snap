source: tests/spec/emit/interop_matrix.rs
description: |
  
  import "go:flag"
  
  fn main() {
    let r = flag.Lookup("verbose")
    match r {
      Some(f) => { let _ = f },
      None => {},
    }
  }
---
package main

import (
	"flag"
	lisette "github.com/ivov/lisette/prelude"
)

func main() {
	raw_1 := flag.Lookup("verbose")
	r := lisette.OptionFromNilable[*flag.Flag](raw_1, raw_1 == nil)
	if r.Tag == lisette.OptionSome {
		_ = r.SomeVal
	}
}
