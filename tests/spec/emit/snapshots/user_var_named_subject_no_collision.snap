---
source: tests/spec/emit/expressions.rs
description: "input: \nfn test(opt: Option<int>) -> int {\n  let subject_1 = 42\n  let val = match opt {\n    Some(v) => v,\n    None => 0,\n  }\n  subject_1 + val\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func test(opt lisette.Option[int]) int {
	subject_1 := 42
	var val int
	if opt.Tag == lisette.OptionSome {
		val = opt.SomeVal
	} else {
		val = 0
	}
	return subject_1 + val
}
