---
source: tests/spec/emit/expressions.rs
description: "input: \nfn run() -> int {\n  let mut a = 10\n  let mut b = 20\n  let mut p = &a\n  let repoint = || -> int { p = &b; 5 }\n  p.* = repoint()\n  a\n}\n"
---
package main

func run() int {
	a := 10
	b := 20
	p := &a
	repoint := func() int {
		p = &b
		return 5
	}
	ref_1 := p
	*ref_1 = repoint()
	return a
}
