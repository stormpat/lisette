---
package main

func make_bound() int {
	return 3
}

func main() {
	sum := 0
	_bound_1 := make_bound()
	for i := 0; i < _bound_1; i++ {
		sum += i
	}
	_bound_1_2 := 7
	_ = sum
	_ = _bound_1_2
}
