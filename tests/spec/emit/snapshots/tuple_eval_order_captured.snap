---
source: tests/spec/emit/expressions.rs
description: |
  
  fn bump(i: Ref<int>) -> int {
    i.* = 1
    10
  }
  
  fn main() {
    let mut i = 0
    let t = (i, bump(&i))
    let _ = t
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func bump(i *int) int {
	*i = 1
	return 10
}

func main() {
	i := 0
	_v_1 := i
	t := lisette.MakeTuple2(_v_1, bump(&i))
	_ = t
}
