---
source: tests/spec/emit/control_flow.rs
description: |
  
  fn risky() -> Result<int, string> { Ok(1) }
  fn do_something() { }
  
  fn test() {
    let r = try {
      let x = risky()?;
      task { do_something() };
      x
    };
    let _ = r;
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func risky() lisette.Result[int, string] {
	return lisette.MakeResultOk[int, string](1)
}

func do_something() {}

func test() {
	var r lisette.Result[int, string]
	tryResult_1 := func() lisette.Result[int, string] {
		check_2 := risky()
		if check_2.Tag != lisette.ResultOk {
			return lisette.MakeResultErr[int, string](check_2.ErrVal)
		}
		x := check_2.OkVal
		go func() {
			do_something()
		}()
		return lisette.MakeResultOk[int, string](x)
	}()
	r = tryResult_1
	_ = r
}
