---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Box {
    items: Slice<int>,
  }
  
  fn main() {
    let mut m = Map.new<string, Box>()
    m["a"] = Box { items: [] }
    let r = &m
    let mut entry = r.*["a"]
    entry.items = entry.items.append(1)
    r.*["a"] = entry
  }
---
package main

type Box struct {
	items []int
}

func main() {
	m := make(map[string]Box)
	m["a"] = Box{}
	r := &m
	entry := (*r)["a"]
	entry.items = append(entry.items, 1)
	base_1 := r
	(*base_1)["a"] = entry
}
