package main

import "fmt"

type Box struct {
	x int
}

func make_i() int {
	fmt.Println("i")
	return 0
}

func main() {
	maps := make(map[int]map[string]Box)
	inner := make(map[string]Box)
	inner["k"] = Box{x: 0}
	maps[0] = inner
	i := make_i()
	entry := maps[i]["k"]
	entry.x = 1
	base_1 := maps[i]
	base_1["k"] = entry
}
