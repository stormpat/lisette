source: tests/spec/emit/expressions.rs
description: |
  
  import "go:fmt"
  
  struct Box { x: int }
  
  fn make_i() -> int {
    fmt.Println("i")
    0
  }
  
  fn main() {
    let mut maps: Map<int, Map<string, Box>> = Map.new()
    let mut inner = Map.new<string, Box>()
    inner["k"] = Box { x: 0 }
    maps[0] = inner
    let i = make_i()
    let mut entry = maps[i]["k"]
    entry.x = 1
    maps[i]["k"] = entry
  }
---
package main

import "fmt"

type Box struct {
	x int
}

func make_i() int {
	fmt.Println("i")
	return 0
}

func main() {
	maps := make(map[int]map[string]Box)
	inner := make(map[string]Box)
	inner["k"] = Box{x: 0}
	maps[0] = inner
	i := make_i()
	entry := maps[i]["k"]
	entry.x = 1
	base_1 := maps[i]
	base_1["k"] = entry
}
