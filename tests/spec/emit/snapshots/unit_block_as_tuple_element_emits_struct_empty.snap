---
source: tests/spec/emit/expressions.rs
description: |
  
  import "go:fmt"
  
  fn side() {
    fmt.Println("side")
  }
  
  fn test() -> int {
    let t = ({ side() }, 1)
    t.1
  }
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
)

func side() {
	fmt.Println("side")
}

func test() int {
	side()
	t := lisette.MakeTuple2(struct{}{}, 1)
	return t.Second
}
