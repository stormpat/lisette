---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Wrap(Slice<int>)
  
  fn main() {
    let mut w = Wrap([1])
    let r = &w
    let _ = r.0.append(2)
  }
---
package main

type Wrap []int

func main() {
	w := Wrap([]int{1})
	r := &w
	recv_1 := []int(*r)
	_ = append(recv_1[:len(recv_1):len(recv_1)], 2)
}
