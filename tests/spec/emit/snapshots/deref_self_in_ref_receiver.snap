---
source: tests/spec/emit/expressions.rs
description: "input: \nstruct Foo { x: int }\n\nimpl Foo {\n  fn copy_out(self: Ref<Foo>) -> Foo {\n    let copy = self.*\n    Foo { x: copy.x }\n  }\n}\n"
---
package main

type Foo struct {
	x int
}

func (f *Foo) copy_out() Foo {
	copy_ := *f
	return Foo{x: copy_.x}
}
