---
source: tests/spec/emit/expressions.rs
description: "input: \nstruct Inner {\n  items: Slice<int>,\n}\nstruct Wrap(Inner)\n\nfn main() {\n  let mut m = Map.new<string, Wrap>()\n  m[\"a\"] = Wrap(Inner { items: [] })\n  let mut inner = m[\"a\"].0\n  inner.items = inner.items.append(1)\n  m[\"a\"] = Wrap(inner)\n}\n"
---
package main

type Inner struct {
	items []int
}

type Wrap Inner

func main() {
	m := make(map[string]Wrap)
	m["a"] = Wrap(Inner{})
	inner := Inner(m["a"])
	inner.items = append(inner.items, 1)
	m["a"] = Wrap(inner)
}
