---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Inner {
    items: Slice<int>,
  }
  struct Wrap(Inner)
  
  fn main() {
    let mut m = Map.new<string, Wrap>()
    m["a"] = Wrap(Inner { items: [] })
    let mut inner = m["a"].0
    inner.items = inner.items.append(1)
    m["a"] = Wrap(inner)
  }
---
package main

type Inner struct {
	items []int
}

type Wrap Inner

func main() {
	m := make(map[string]Wrap)
	m["a"] = Wrap(Inner{})
	inner := Inner(m["a"])
	inner.items = append(inner.items, 1)
	m["a"] = Wrap(inner)
}
