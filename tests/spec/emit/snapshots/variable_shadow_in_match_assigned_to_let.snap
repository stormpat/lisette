---
source: tests/spec/emit/patterns.rs
description: |
  
  fn test() -> int {
    let val = Some(42)
    let result = match val {
      Some(x) => {
        let x = x * 2
        x
      },
      None => 0,
    }
    result
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func test() int {
	val := lisette.MakeOptionSome(42)
	var result int
	if val.Tag == lisette.OptionSome {
		x := val.SomeVal * 2
		result = x
	} else {
		result = 0
	}
	return result
}
