---
source: tests/spec/emit/interop_matrix.rs
description: |
  
  import "go:os"
  
  fn apply(f: fn(string) -> Option<string>, key: string) -> string {
    match f(key) {
      Some(v) => v,
      None => "unset",
    }
  }
  
  fn main() {
    let r = apply(os.LookupEnv, "HOME")
    let _ = r
  }
---
package main

import (
	lisette "github.com/ivov/lisette/prelude"
	"os"
)

func apply(f func(string) (string, bool), key string) string {
	option_2 := lisette.OptionFromCommaOk[string](f(key))
	subject_1 := option_2
	if subject_1.Tag == lisette.OptionSome {
		return subject_1.SomeVal
	}
	return "unset"
}

func main() {
	r := apply(os.LookupEnv, "HOME")
	_ = r
}
