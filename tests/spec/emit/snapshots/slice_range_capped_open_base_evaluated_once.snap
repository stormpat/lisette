---
source: tests/spec/emit/expressions.rs
description: "input: \nfn make_items() -> Slice<int> { [10, 20, 30] }\n\nfn test() -> int {\n  let ys = make_items()[1..]\n  ys.length()\n}\n"
---
package main

func make_items() []int {
	return []int{10, 20, 30}
}

func test() int {
	base_1 := make_items()
	len_2 := len(base_1)
	ys := base_1[1:len_2:len_2]
	return len(ys)
}
