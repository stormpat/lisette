  fn main() {
    let n = parse_with(strconv.Atoi, "42")
    fmt.Println(n)
  }
---
package main

import (
	"fmt"
	"strconv"
)

func parse_with(f func(string) (int, error), s string) int {
	ret_1, ret_2 := f(s)
	if ret_2 == nil {
		n := ret_1
		return n
	} else {
		return 0
	}
}

func main() {
	n := parse_with(strconv.Atoi, "42")
	fmt.Println(n)
}
