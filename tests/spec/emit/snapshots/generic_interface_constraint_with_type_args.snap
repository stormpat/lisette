---
source: tests/spec/emit/types.rs
description: |
  
  interface Mapper<A, B> {
    fn map_value(a: A) -> B
  }
  
  fn apply_mapper<M: Mapper<int, string>>(m: M, val: int) -> string {
    m.map_value(val)
  }
---
package main

type Mapper[A any, B any] interface {
	map_value(A) B
}

func apply_mapper[M Mapper[int, string]](m M, val int) string {
	return m.map_value(val)
}
