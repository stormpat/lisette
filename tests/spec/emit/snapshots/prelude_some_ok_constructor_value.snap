---
source: tests/spec/emit/types.rs
description: |
  
  fn main() {
    let f = Some
    let x = f(42)
    let _ = x
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func main() {
	cb_1 := lisette.MakeOptionSome[int]
	f := func(arg0 int) (int, bool) {
		opt_2 := cb_1(arg0)
		if opt_2.Tag == lisette.OptionSome {
			return opt_2.SomeVal, true
		}
		return *new(int), false
	}
	option_3 := lisette.OptionFromCommaOk[int](f(42))
	x := option_3
	_ = x
}
