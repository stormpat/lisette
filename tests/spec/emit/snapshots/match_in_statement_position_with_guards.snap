---
source: tests/spec/emit/control_flow.rs
description: "input: \nimport \"go:fmt\"\n\nfn test() {\n  let result: Result<int, string> = Ok(42);\n  match result {\n    Ok(n) if n > 0 => fmt.Print(f\"positive: {n}\\n\"),\n    Ok(n) => fmt.Print(f\"non-positive: {n}\\n\"),\n    Err(e) => fmt.Print(f\"error: {e}\\n\"),\n  }\n}\n"
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
)

func test() {
	result := lisette.MakeResultOk[int, string](42)
	subject_1 := result
match_2:
	for {
		if subject_1.Tag == lisette.ResultOk {
			n := subject_1.OkVal
			if n > 0 {
				fmt.Printf("positive: %v\n", n)
				break match_2
			}
			fmt.Printf("non-positive: %v\n", n)
			break match_2
		}
		fmt.Printf("error: %v\n", subject_1.ErrVal)
		break match_2
	}
}
