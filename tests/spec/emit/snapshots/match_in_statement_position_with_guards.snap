---
source: tests/spec/emit/control_flow.rs
description: |
  
  import "go:fmt"
  
  fn test() {
    let result: Result<int, string> = Ok(42);
    match result {
      Ok(n) if n > 0 => fmt.Print(f"positive: {n}\n"),
      Ok(n) => fmt.Print(f"non-positive: {n}\n"),
      Err(e) => fmt.Print(f"error: {e}\n"),
    }
  }
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
)

func test() {
	result := lisette.MakeResultOk[int, string](42)
	subject_1 := result
match_2:
	for {
		if subject_1.Tag == lisette.ResultOk {
			if subject_1.OkVal > 0 {
				fmt.Printf("positive: %d\n", subject_1.OkVal)
				break match_2
			}
			fmt.Printf("non-positive: %d\n", subject_1.OkVal)
			break match_2
		}
		e := subject_1.ErrVal
		fmt.Printf("error: %s\n", e)
		break match_2
	}
}
