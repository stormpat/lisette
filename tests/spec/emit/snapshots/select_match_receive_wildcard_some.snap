---
source: tests/spec/emit/concurrency.rs
description: |
  
  fn process_close() {}
  
  fn test() {
    let ch = Channel.new<int>();
    select {
      match ch.receive() {
        Some(_) => {},
        None => process_close(),
      },
      _ => {},
    }
  }
---
package main

func process_close() {}

func test() {
	ch := make(chan int)
	select {
	case _, ok := <-ch:
		if !ok {
			process_close()
		}
	default:
	}
}
