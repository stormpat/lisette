---
source: tests/spec/emit/result_option_patterns.rs
description: |
  
  fn maybe_int(b: bool) -> Option<int> {
    if b { Some(42) } else { None }
  }
  
  fn unwrap_or(o: Option<int>, fallback: int) -> int {
    match o { Some(v) => v, None => fallback }
  }
  
  fn test() -> int {
    unwrap_or(maybe_int(true), 0)
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func maybe_int(b bool) (int, bool) {
	if b {
		return 42, true
	}
	return 0, false
}

func unwrap_or(o lisette.Option[int], fallback int) int {
	if o.Tag == lisette.OptionSome {
		return o.SomeVal
	}
	return fallback
}

func test() int {
	option_1 := lisette.OptionFromCommaOk[int](maybe_int(true))
	return unwrap_or(option_1, 0)
}
