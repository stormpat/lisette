---
source: tests/spec/emit/types.rs
description: "input: \nstruct A { a: string }\n\nimpl A {\n  fn String(self) -> string {\n    self.a + \"asdf\"\n  }\n}\n\nfn main() {\n  let a = A { a: \"text\" }\n  let _ = a\n}\n"
---
package main

type A struct {
	a string
}

func (a A) String() string {
	return a.a + "asdf"
}

func main() {
	a := A{a: "text"}
	_ = a
}
