description: |
  
  import "go:errors"
  
  fn might_fail(n: int) -> Result<int, error> {
    if n < 0 {
      return Err(errors.New("negative"))
    }
    Ok(n)
  }
---
package main

import "errors"

func might_fail(n int) (int, error) {
	if n < 0 {
		return *new(int), errors.New("negative")
	}
	return n, nil
}
