---
source: tests/spec/emit/types.rs
description: "input: \nenum List<T> {\n  Nil,\n  Cons(T, List<T>)\n}\n\nfn test() -> List<int> {\n  List.Cons(1, List.Cons(2, List.Nil))\n}\n"
---
package main

func MakeListNil[T any]() List[T] {
	return List[T]{Tag: ListNil}
}

func MakeListCons[T any](arg0 T, arg1 *List[T]) List[T] {
	return List[T]{Tag: ListCons, Cons0: arg0, Cons1: arg1}
}

type ListTag int

const (
	ListNil ListTag = iota
	ListCons
)

type List[T any] struct {
	Tag   ListTag
	Cons0 T
	Cons1 *List[T]
}

func test() List[int] {
	ptr_1 := MakeListNil[int]()
	ptr_2 := MakeListCons(2, &ptr_1)
	return MakeListCons(1, &ptr_2)
}
