---
source: tests/spec/emit/types.rs
description: "input: \nenum List<T> {\n  Nil,\n  Cons(T, List<T>)\n}\n\nfn test() -> List<int> {\n  List.Cons(1, List.Cons(2, List.Nil))\n}\n"
---
package main

import "fmt"

func MakeListNil[T any]() List[T] {
	return List[T]{Tag: ListNil}
}

func MakeListCons[T any](arg0 T, arg1 *List[T]) List[T] {
	return List[T]{Tag: ListCons, Cons0: arg0, Cons1: arg1}
}

type ListTag int

const (
	ListNil ListTag = iota
	ListCons
)

type List[T any] struct {
	Tag   ListTag
	Cons0 T
	Cons1 *List[T]
}

func (l List[T]) String() string {
	switch l.Tag {
	case ListNil:
		return "Nil"
	case ListCons:
		return fmt.Sprintf("Cons(%v, %v)", l.Cons0, l.Cons1)
	default:
		return fmt.Sprintf("List(%d)", l.Tag)
	}
}

func (l List[T]) GoString() string {
	switch l.Tag {
	case ListNil:
		return "List.Nil"
	case ListCons:
		return fmt.Sprintf("List.Cons(%v, %v)", l.Cons0, l.Cons1)
	default:
		return fmt.Sprintf("List(%d)", l.Tag)
	}
}

func test() List[int] {
	ptr_1 := MakeListNil[int]()
	ptr_2 := MakeListCons(2, &ptr_1)
	return MakeListCons(1, &ptr_2)
}
