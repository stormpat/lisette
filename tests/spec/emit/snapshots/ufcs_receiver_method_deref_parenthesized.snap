---
source: tests/spec/emit/expressions.rs
description: "input: \nstruct Box { x: int }\n\nimpl Box {\n  fn add(self, y: int) -> int { self.x + y }\n}\n\nfn make_ref() -> Ref<Box> { &Box { x: 1 } }\n\nfn main() {\n  let _ = Box.add(make_ref().*, 1);\n}\n"
---
package main

type Box struct {
	x int
}

func (b Box) add(y int) int {
	return b.x + y
}

func make_ref() *Box {
	return &Box{x: 1}
}

func main() {
	_ = (*make_ref()).add(1)
}
