---
source: tests/spec/emit/expressions.rs
description: |
  
  struct Player {
    name: string,
    score: int,
  }
  
  fn test() {
    let mut players = Map.new<string, Player>()
    players["alice"] = Player { name: "Alice", score: 0 }
    let mut entry = players["alice"]
    entry.score = 100
    players["alice"] = entry
  }
---
package main

type Player struct {
	name  string
	score int
}

func test() {
	players := make(map[string]Player)
	players["alice"] = Player{
		name:  "Alice",
		score: 0,
	}
	entry := players["alice"]
	entry.score = 100
	players["alice"] = entry
}
