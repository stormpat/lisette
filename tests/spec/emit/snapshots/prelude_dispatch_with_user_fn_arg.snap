---
source: tests/spec/emit/prelude.rs
description: |
  
  fn doubler(x: int) -> Option<int> { Some(x * 2) }
  fn main() {
    let opt: Option<int> = Some(1)
    let r = opt.and_then(doubler)
    let _ = r
  }
---
package main

import lisette "github.com/ivov/lisette/prelude"

func doubler(x int) (int, bool) {
	return x * 2, true
}

func main() {
	opt := lisette.MakeOptionSome(1)
	_arg_4 := opt
	cb_1 := doubler
	tagged_3 := func(arg0 int) lisette.Option[int] {
		option_2 := lisette.OptionFromCommaOk[int](cb_1(arg0))
		return option_2
	}
	r := lisette.OptionAndThen(_arg_4, tagged_3)
	_ = r
}
